            <article class="<%= h message_article_class(message) %>" data-role="<%= h message.role %>" data-message-fingerprint="<%= h message_fingerprint(message.role, message_fingerprint_text(message), message.timestamp) %>"<%= ' data-final-assistant-response="true"' if message.final_assistant_response %>>
              <header class="message-header">
                <div class="role"><%= h message_display_role_label(message) %></div>
                <% if message_metadata(message) %>
                  <div class="message-meta"><%= h message_metadata(message) %></div>
                <% end %>
                <% if message.role == "assistant" && !message.compact && !message.thinking %>
                  <button type="button" class="copy-button" data-copy-target="message">Copy</button>
                <% end %>
              </header>
              <% visible_images = Array(message.images) %>
              <% visible_images = Array(defined?(attachment_images) ? attachment_images : []) if visible_images.empty? %>
              <% if message.thinking %>
                <div class="message-body message-body--thinking message-body--markdown"><%= render_message_body(message) %></div>
              <% elsif message.compact %>
                <div class="message-details message-details--always-open">
                  <div class="message-details-summary"><span class="compact-summary"><%= message.tool_summary_html || h(message.summary) %></span></div>
                  <% if message.tool_prompt.to_s != "" %>
                    <details class="subagent-prompt" data-subagent-prompt>
                      <summary class="subagent-prompt-summary">
                        <span class="subagent-prompt-label">Prompt</span>
                        <span class="subagent-prompt-preview" data-subagent-prompt-preview><%= h message.tool_prompt %></span>
                        <span class="subagent-prompt-action" aria-hidden="true"></span>
                      </summary>
                    </details>
                  <% end %>
                  <% if compact_message_text(message) != "" %>
                    <% if collapsible_tool_output?(message) %>
                      <div class="tool-output-collapse" data-tool-output-collapse data-tool-output-collapsible="true" data-collapsed="true">
                        <div class="tool-output-collapse-control" data-tool-output-collapse-control>
                          <span class="tool-output-hidden-count tool-output-hidden-count--desktop">… (<%= h tool_output_hidden_line_count(message, Web::ViewHelpers::TOOL_OUTPUT_DESKTOP_TAIL_LINES) %> earlier lines)</span>
                          <span class="tool-output-hidden-count tool-output-hidden-count--mobile">… (<%= h tool_output_hidden_line_count(message, Web::ViewHelpers::TOOL_OUTPUT_MOBILE_TAIL_LINES) %> earlier lines)</span>
                          <button type="button" class="tool-output-toggle" data-tool-output-toggle aria-expanded="false">Expand</button>
                        </div>
                        <pre class="message-body<%= ' message-body--edit-preview' if message.tool_preview %>" data-tool-output-body><%= render_tool_output_tail(message) %></pre>
                        <template data-tool-output-full><%= render_compact_message_body(message) %></template>
                        <template data-tool-output-tail><%= render_tool_output_tail(message) %></template>
                      </div>
                    <% else %>
                      <pre class="message-body<%= ' message-body--edit-preview' if message.tool_preview %>" data-tool-output-body><%= render_compact_message_body(message) %></pre>
                    <% end %>
                  <% end %>
                  <% unless message.tool_answer.nil? || message.tool_answer.empty? %>
                    <div class="subagent-answer message-body message-body--markdown" data-subagent-answer><%= render_subagent_answer(message) %></div>
                  <% end %>
                  <% unless message.tool_usage.nil? || message.tool_usage.empty? %>
                    <div class="subagent-usage" data-subagent-usage><%= h message.tool_usage %></div>
                  <% end %>
                </div>
              <% else %>
                <% if message.role == "assistant" %>
                  <div class="message-body message-body--markdown"><%= render_message_body(message) %></div>
                <% else %>
                  <pre class="message-body"><%= render_message_body(message) %></pre>
                <% end %>
              <% end %>
              <% if visible_images.any? %>
                <div class="message-images"><%= render_message_images(visible_images) %></div>
              <% elsif message.role == "user" && attachment_count.to_i.positive? %>
                <div class="message-attachments"><%= h attachment_label(attachment_count) %></div>
              <% end %>
            </article>
