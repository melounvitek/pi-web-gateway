            <article class="<%= h message_article_class(message) %>" data-role="<%= h message.role %>" data-message-fingerprint="<%= h message_fingerprint(message.role, message.text, message.timestamp) %>"<%= " data-message-index=\"#{h message_index}\"" if defined?(message_index) && message_index %><%= ' data-final-assistant-response="true"' if message.final_assistant_response %>>
              <header class="message-header">
                <div class="role"><%= h message_role_label(message.role) %></div>
                <% if message_metadata(message) %>
                  <div class="message-meta"><%= h message_metadata(message) %></div>
                <% end %>
                <% if message.role == "assistant" && !message.compact && !message.thinking %>
                  <button type="button" class="copy-button" data-copy-target="message">Copy</button>
                <% end %>
              </header>
              <% if message.thinking %>
                <div class="message-body message-body--thinking"><%= render_message_body(message) %></div>
              <% elsif message.compact %>
                <div class="message-details message-details--always-open">
                  <div class="message-details-summary"><span class="compact-summary"><%= message.tool_summary_html || h(message.summary) %></span></div>
                  <pre class="message-body<%= ' message-body--edit-preview' if message.tool_preview %>"><%= render_compact_message_body(message) %></pre>
                  <% if message.raw_details.to_s != "" %>
                    <% if defined?(message_index) && message_index && defer_raw_details?(message) %>
                      <details class="raw-details" data-deferred-raw-details="true" data-message-index="<%= h message_index %>" data-raw-details-url="<%= h raw_details_url(message_index, message) %>">
                        <summary>Raw details available</summary>
                        <pre></pre>
                      </details>
                    <% else %>
                      <details class="raw-details">
                        <summary>Raw details</summary>
                        <pre><%= h message.raw_details %></pre>
                      </details>
                    <% end %>
                  <% end %>
                </div>
              <% else %>
                <% if message.role == "assistant" %>
                  <div class="message-body message-body--markdown"><%= render_message_body(message) %></div>
                <% else %>
                  <pre class="message-body"><%= render_message_body(message) %></pre>
                <% end %>
              <% end %>
              <% if message.role == "user" && attachment_count.to_i.positive? %>
                <div class="message-attachments"><%= h attachment_label(attachment_count) %></div>
              <% end %>
            </article>
