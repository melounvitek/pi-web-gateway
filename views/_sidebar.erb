    <aside class="session-sidebar">
      <div class="session-sidebar-header">
        <h1>Pi Sessions</h1>
        <label for="mobile-session-toggle" class="mobile-sessions-button mobile-sessions-close-button" aria-label="Close sessions"><span class="hamburger-icon" aria-hidden="true"></span></label>
      </div>
      <div class="session-sidebar-content">
      <% if @groups.empty? %>
        <p class="empty">No sessions found.</p>
      <% else %>
        <section class="recent-sessions">
          <% shortcut_index = 0 %>
          <% if sidebar_current_session %>
            <%= erb :_sidebar_session, layout: false, locals: { session: sidebar_current_session, shortcut: nil } %>
          <% end %>
          <% if unread_sidebar_sessions.any? %>
          <div class="recent-sessions-header">
            <h2>Unread</h2>
          </div>
            <% unread_sidebar_sessions.each do |session| %>
              <% shortcut_index += 1 %>
              <% shortcut = shortcut_index <= 9 ? shortcut_index : nil %>
              <%= erb :_sidebar_session, layout: false, locals: { session: session, shortcut: shortcut } %>
            <% end %>
          <% end %>
          <div class="recent-sessions-header">
            <h2>Sessions</h2>
            <button type="button" class="sidebar-icon-button" title="New session" aria-label="New session" data-modal-open="new-session-modal">+</button>
          </div>
          <form class="sidebar-project-filter-form" method="get" action="/">
            <% if @selected_session %>
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
            <% end %>
            <% if show_all_sidebar_sessions? %>
              <input type="hidden" name="show_all_sessions" value="1">
            <% end %>
            <% if sidebar_sessions_limit_param %>
              <input type="hidden" name="sidebar_sessions_limit" value="<%= h sidebar_sessions_limit_param %>">
            <% end %>
            <select class="sidebar-project-filter" name="project" aria-label="Filter sessions by project" data-sidebar-project-filter>
              <option value="">All projects</option>
              <% known_session_cwds.each do |cwd| %>
                <option value="<%= h cwd %>"<%= cwd == selected_project_cwd ? " selected" : "" %>><%= h File.basename(cwd) %></option>
              <% end %>
            </select>
          </form>
          <% regular_sidebar_sessions.each do |session| %>
            <% shortcut_index += 1 %>
            <% shortcut = shortcut_index <= 9 ? shortcut_index : nil %>
            <%= erb :_sidebar_session, layout: false, locals: { session: session, shortcut: shortcut } %>
          <% end %>
          <% if sidebar_sessions_overflow? %>
            <a class="sidebar-load-more" href="<%= h sidebar_sessions_load_more_url %>" data-sidebar-load-more>
              <span class="sidebar-load-more-spinner" aria-hidden="true"></span>
              <span class="sidebar-load-more-label">Load <%= h [SIDEBAR_SESSION_PAGE_SIZE, sidebar_sessions_remaining_count].min %> more</span>
            </a>
          <% end %>
        </section>
      <% end %>
      </div>


      <a class="sidebar-notification-test-link" href="/notification-test">Notifications</a>
    </aside>
