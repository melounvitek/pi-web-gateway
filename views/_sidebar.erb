    <aside class="session-sidebar">
      <div class="session-sidebar-header">
        <h1>Pi Sessions</h1>
        <label for="mobile-session-toggle" class="mobile-sessions-button mobile-sessions-close-button" aria-label="Close sessions"><span class="hamburger-icon" aria-hidden="true"></span></label>
      </div>
      <div class="session-sidebar-content">
      <% if @groups.empty? %>
        <p class="empty">No sessions found.</p>
      <% else %>
        <section class="recent-sessions">
          <% shortcut_index = 0 %>
          <% if sidebar_current_session %>
            <%= erb :_sidebar_session, layout: false, locals: { session: sidebar_current_session, shortcut: nil } %>
          <% end %>
          <% if unread_sidebar_sessions.any? %>
          <div class="recent-sessions-header">
            <h2>Unread</h2>
          </div>
            <% unread_sidebar_sessions.each do |session| %>
              <% shortcut_index += 1 %>
              <% shortcut = shortcut_index <= 9 ? shortcut_index : nil %>
              <%= erb :_sidebar_session, layout: false, locals: { session: session, shortcut: shortcut } %>
            <% end %>
          <% end %>
          <div class="recent-sessions-header">
            <h2>Sessions</h2>
            <button type="button" class="sidebar-icon-button" title="New session" aria-label="New session" data-modal-open="new-session-modal">+</button>
          </div>
          <% regular_sidebar_sessions.each do |session| %>
            <% shortcut_index += 1 %>
            <% shortcut = shortcut_index <= 9 ? shortcut_index : nil %>
            <%= erb :_sidebar_session, layout: false, locals: { session: session, shortcut: shortcut } %>
          <% end %>
          <% if sidebar_sessions_overflow? %>
            <a class="cwd-toggle" href="<%= h sidebar_sessions_toggle_url(show_all: true) %>">Show all <%= h sorted_sidebar_sessions.length %> sessions</a>
          <% elsif show_all_sidebar_sessions? && sorted_sidebar_sessions.length > RECENT_SIDEBAR_SESSION_LIMIT %>
            <a class="cwd-toggle" href="<%= h sidebar_sessions_toggle_url(show_all: false) %>">Show recent sessions</a>
          <% end %>
        </section>
      <% end %>
      </div>


      <a class="sidebar-notification-test-link" href="/notification-test">Notifications</a>
    </aside>
