    <aside class="session-sidebar" data-unread-session-count="<%= h unread_sidebar_session_count %>">
      <div class="session-sidebar-header">
        <div class="sidebar-title">
          <h1>Pi Sessions</h1>
          <div class="sidebar-server-origin"><%= h request.base_url %></div>
        </div>
        <label for="mobile-session-toggle" class="mobile-sessions-button mobile-sessions-close-button" aria-label="Close sessions"><span class="hamburger-icon" aria-hidden="true"></span><% if unread_sidebar_session_count.positive? %><span class="mobile-sessions-unread-badge" aria-label="<%= h unread_sidebar_session_aria_label %>" title="<%= h unread_sidebar_session_aria_label %>"><%= h unread_sidebar_session_count_label %></span><% end %></label>
      </div>
      <div class="session-sidebar-content">
      <% if @groups.empty? %>
        <div class="empty sidebar-empty">
          <span>No sessions yet.</span>
          <button type="button" class="sidebar-empty-action" data-modal-open="new-session-modal">Choose directory</button>
        </div>
      <% else %>
        <section class="recent-sessions">
          <% shortcut_index = 0 %>
          <% separate_current_session = sidebar_separate_current_session %>
          <% if separate_current_session %>
            <section class="current-session-section">
              <div class="recent-sessions-header">
                <h2>Current session</h2>
              </div>
              <%= erb :_sidebar_session, layout: false, locals: { session: separate_current_session, shortcut: nil } %>
            </section>
          <% end %>
          <div class="recent-sessions-header">
            <h2>Sessions</h2>
            <button type="button" class="sidebar-icon-button sidebar-search-toggle<%= sidebar_filters? ? " is-active" : "" %>" title="Search sessions" aria-label="Search sessions" aria-expanded="<%= sidebar_filters? ? "true" : "false" %>" aria-controls="sidebar-session-search" data-sidebar-search-toggle>⌕</button>
            <button type="button" class="sidebar-icon-button" title="New session" aria-label="New session" data-modal-open="new-session-modal">+</button>
          </div>
          <form id="sidebar-session-search" class="sidebar-session-search<%= sidebar_filters? ? " is-open" : "" %>" method="get" action="/" role="search">
            <% if @selected_session %>
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
            <% end %>
            <% if selected_project_cwd %>
              <input type="hidden" name="project" value="<%= h selected_project_cwd %>">
            <% end %>
            <input type="search" name="session_search" value="<%= h sidebar_session_search_query %>" placeholder="Search sessions" aria-label="Search sessions">
          </form>
          <form class="sidebar-project-filter-form" method="get" action="/">
            <% if @selected_session %>
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
            <% end %>
            <% if sidebar_session_search? %>
              <input type="hidden" name="session_search" value="<%= h sidebar_session_search_query %>">
            <% end %>
            <div class="sidebar-filter-row">
              <div class="project-select" data-project-select>
                <select class="sidebar-project-filter" name="project" aria-label="Filter sessions by project" data-sidebar-project-filter>
                  <option value="" data-project-option-kind="all">All projects</option>
                  <% known_session_cwds.each do |cwd| %>
                    <% identity = project_identity(cwd) %>
                    <option value="<%= h cwd %>" data-project-monogram="<%= h identity[:monogram] %>" data-project-background="<%= h identity[:background] %>" data-project-foreground="<%= h identity[:foreground] %>"<%= cwd == selected_project_cwd ? " selected" : "" %>><%= h File.basename(cwd) %></option>
                  <% end %>
                </select>
              </div>
              <span class="sidebar-filter-spinner" aria-hidden="true"></span>
              <% if sidebar_filters? %>
                <a class="sidebar-filters-clear" href="<%= h sidebar_filters_clear_url %>" data-sidebar-filters-clear>Clear filters</a>
              <% end %>
            </div>
          </form>
          <div class="sessions-list">
            <% sidebar_sessions.each do |session| %>
              <% unless selected?(session) %>
                <% shortcut_index += 1 %>
              <% end %>
              <% shortcut = !selected?(session) && shortcut_index <= 9 ? shortcut_index : nil %>
              <%= erb :_sidebar_session, layout: false, locals: { session: session, shortcut: shortcut } %>
            <% end %>
          </div>
          <% if sidebar_filters? && sidebar_session_pool.empty? %>
            <p class="empty sidebar-search-empty">No sessions match these filters.</p>
          <% end %>
          <% if sidebar_sessions_overflow? %>
            <a class="sidebar-load-more" href="<%= h sidebar_sessions_load_more_url %>" data-sidebar-load-more>
              <span class="sidebar-load-more-spinner" aria-hidden="true"></span>
              <span class="sidebar-load-more-label">Load <%= h [SIDEBAR_SESSION_PAGE_SIZE, sidebar_sessions_remaining_count].min %> more</span>
            </a>
          <% end %>
        </section>
      <% end %>
      </div>


      <button type="button" class="sidebar-notification-toggle" title="Enable notifications" aria-label="Enable notifications" data-notification-toggle>
        <span class="sidebar-notification-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="16" height="16" focusable="false">
            <path d="M18 16v-5a6 6 0 0 0-12 0v5l-1.5 2h15L18 16Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M9.5 20a2.7 2.7 0 0 0 5 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="sidebar-notification-label">Notifications</span>
        <span class="sidebar-notification-state" data-notification-toggle-state>Enable</span>
      </button>
    </aside>
