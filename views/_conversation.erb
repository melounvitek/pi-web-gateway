    <main class="conversation-panel">
      <% if @selected_session %>
        <header class="session-header">
          <label for="mobile-session-toggle" class="mobile-sessions-button" aria-label="Open sessions"><span class="hamburger-icon" aria-hidden="true"></span><% if unread_sidebar_session_count.positive? %><span class="mobile-sessions-unread-badge" aria-label="<%= h unread_sidebar_session_aria_label %>" title="<%= h unread_sidebar_session_aria_label %>"><%= h unread_sidebar_session_count_label %></span><% end %></label>
          <div class="session-header-title" title="<%= h @selected_session.display_name %> · <%= h project_label(@selected_session) %>">
            <h1 class="session-header-name" title="<%= h @selected_session.display_name %>"><%= h @selected_session.display_name %></h1>
            <div class="session-header-project" title="<%= h project_label(@selected_session) %>"><%= h project_label(@selected_session) %></div>
            <% if session_parent(@selected_session) || session_children(@selected_session).any? %>
              <details class="session-relation-tree" aria-label="Related sessions">
                <summary class="session-relation-tree-heading">Related sessions</summary>
                <ul class="session-relation-tree-root">
                  <%= erb :_session_relation_tree_node, layout: false, locals: { session: session_family_root(@selected_session), current_session: @selected_session } %>
                </ul>
              </details>
            <% end %>
          </div>
          <div class="session-header-actions">
            <button type="submit" class="danger abort-button session-abort-button composer-stop-button" form="abort-form" hidden disabled title="Abort running Pi" aria-label="Abort running Pi"><span aria-hidden="true">⏹</span></button>
          </div>
        </header>

        <section class="conversation-scroll" id="conversation-scroll" tabindex="0" data-has-older-messages="<%= @conversation_has_older_messages ? "true" : "false" %>" data-older-message-count="<%= h @conversation_older_message_count.to_i %>" data-older-message-cursor="<%= h @conversation_start_index.to_i %>" data-older-messages-url="/conversation_older?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
          <div class="jump-controls jump-controls--top">
            <button type="button" class="jump-button jump-to-first" aria-label="Top">↑↑</button>
          </div>
          <% if @conversation_has_older_messages %>
            <div class="conversation-history-status" data-conversation-history-status>Loading earlier messages…</div>
          <% end %>
          <% if @messages.empty? %>
            <p class="empty">No messages in this session.</p>
          <% end %>

          <% @messages.each.with_index(@conversation_start_index.to_i) do |message, message_index| %>
            <%= erb :_message_article, layout: false, locals: { message: message, message_index: message_index, attachment_count: @attachment_counts[message.object_id], attachment_images: @attachment_images[message.object_id] } %>
          <% end %>

          <% busy_since = rpc_clients.busy_since(@selected_session.path) %>
          <section id="live-output" data-events-url="/events?session=<%= h Rack::Utils.escape(@selected_session.path) %>" data-events-after="<%= h rpc_clients.event_sequence(@selected_session.path) %>" data-composer-state="<%= rpc_clients.busy?(@selected_session.path) ? "running" : "idle" %>" data-composer-state-since="<%= h(busy_since ? (busy_since.to_f * 1000).to_i : "") %>" data-agent-running="<%= rpc_clients.agent_running?(@selected_session.path) ? "true" : "false" %>"></section>
          <div class="jump-controls jump-controls--bottom">
            <button type="button" class="jump-button jump-to-latest" aria-label="Bottom">↓↓</button>
          </div>
        </section>

        <div class="composer">
          <div class="composer-inner">
            <details class="command-list" id="command-list" data-loaded="false" data-commands-url="/commands?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
              <summary>Slash commands</summary>
              <div class="command-list-message" data-queued-slash-message hidden>Slash commands are not supported in queued follow-up messages.</div>
            </details>

            <form method="post" action="/abort" class="abort-form" id="abort-form">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <% if selected_project_cwd %>
                <input type="hidden" name="project" value="<%= h selected_project_cwd %>">
              <% end %>
              <% if sidebar_session_search? %>
                <input type="hidden" name="session_search" value="<%= h sidebar_session_search_query %>">
              <% end %>
            </form>

            <div class="session-reconnect" role="status" aria-live="polite">
              <span>Session may be stale.</span>
              <button type="button" class="secondary reconnect-button">Reconnect</button>
            </div>

            <form method="post" action="/prompt" class="prompt-form" enctype="multipart/form-data">
              <% if @viewing_older_tree_leaf && @latest_tree_leaf_id %>
                <div class="tree-position-banner" role="status">
                  <div>
                    <strong>Viewing earlier tree point.</strong>
                    <span>Your next message will branch from here.</span>
                  </div>
                  <button type="button" class="secondary" data-tree-entry-id="<%= h @latest_tree_leaf_id %>" data-tree-latest-entry-id="<%= h @latest_tree_leaf_id %>">Jump to latest</button>
                </div>
              <% end %>
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <% if selected_project_cwd %>
                <input type="hidden" name="project" value="<%= h selected_project_cwd %>">
              <% end %>
              <% if sidebar_session_search? %>
                <input type="hidden" name="session_search" value="<%= h sidebar_session_search_query %>">
              <% end %>
              <span class="composer-state" data-state="idle" aria-live="polite"></span>
              <div class="attachment-tray" aria-live="polite"></div>
              <div class="composer-input-row">
                <input class="image-input" id="image-input" type="file" accept="image/*" multiple>
                <label for="image-input" class="attach-button" title="Attach images" aria-label="Attach images">＋</label>
                <textarea name="message" rows="1" placeholder="Ask Pi… Enter to send, Shift+Enter for newline."></textarea>
                <button type="submit" class="send-button">Send</button>
              </div>
              <div class="composer-controls">
                <div class="session-status-bar" id="session-status-bar" data-status-url="/status?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
                  <% session_status_items(@session_status).each do |label, value| %>
                    <span class="session-status-item" data-status-key="<%= h label.downcase %>"><span class="session-status-label"><%= h label %></span> <span class="session-status-value"><%= h value %></span></span>
                  <% end %>
                </div>
              </div>
            </form>
          </div>
        </div>
      <% else %>
        <header class="session-header">
          <label for="mobile-session-toggle" class="mobile-sessions-button" aria-label="Open sessions"><span class="hamburger-icon" aria-hidden="true"></span><% if unread_sidebar_session_count.positive? %><span class="mobile-sessions-unread-badge" aria-label="<%= h unread_sidebar_session_aria_label %>" title="<%= h unread_sidebar_session_aria_label %>"><%= h unread_sidebar_session_count_label %></span><% end %></label>
          <h1>Welcome to Pi</h1>
        </header>
        <section class="conversation-scroll" id="conversation-scroll" tabindex="0">
          <div class="empty empty-state">
            <div class="empty-state-title">No sessions yet</div>
            <p>Choose an existing project directory to start your first Pi session.</p>
            <div class="empty-state-actions">
              <button type="button" data-modal-open="new-session-modal">Choose directory</button>
            </div>
          </div>
        </section>
      <% end %>
    </main>
