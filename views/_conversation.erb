    <main class="conversation-panel">
      <% if @selected_session %>
        <% session_sync_blocked = [:external_follow, :conflict].include?(@session_sync_mode) %>
        <header class="session-header">
          <% unless session_only? %>
            <label for="mobile-session-toggle" class="mobile-sessions-button" aria-label="Open sessions"><span class="hamburger-icon" aria-hidden="true"></span><% if unread_sidebar_session_count.positive? %><span class="mobile-sessions-unread-badge" aria-label="<%= h unread_sidebar_session_aria_label %>" title="<%= h unread_sidebar_session_aria_label %>"><%= h unread_sidebar_session_count_label %></span><% end %></label>
          <% end %>
          <% identity = project_identity(@selected_session.cwd) %>
          <div class="session-header-title">
            <h1 class="session-header-name" title="<%= h @selected_session.display_name %>"><%= h @selected_session.display_name %></h1>
            <div class="session-header-project" style="--project-identity-bg: <%= h identity[:background] %>; --project-identity-fg: <%= h identity[:foreground] %>">
              <span class="project-identity-icon session-header-project-icon" aria-hidden="true"><%= h identity[:monogram] %></span>
              <span class="session-header-project-label" title="<%= h project_label(@selected_session) %>"><%= h project_label(@selected_session) %></span>
              <span class="session-header-project-separator" aria-hidden="true">·</span>
              <select class="session-header-view-select" data-conversation-view-select aria-label="Transcript view">
                <option value="full" selected>All details</option>
                <option value="conversation">Messages only</option>
              </select>
            </div>
            <% if session_parent(@selected_session) || session_children(@selected_session).any? %>
              <details class="session-relation-tree" aria-label="Related sessions">
                <summary class="session-relation-tree-heading">Related sessions</summary>
                <ul class="session-relation-tree-root">
                  <%= erb :_session_relation_tree_node, layout: false, locals: { session: session_family_root(@selected_session), current_session: @selected_session } %>
                </ul>
              </details>
            <% end %>
          </div>
          <div class="session-header-actions">
            <% unless session_only? %>
              <a class="session-header-action session-header-window-action" href="<%= h session_only_url(@selected_session.path) %>" target="_blank" rel="noopener" title="Open session in new window" aria-label="Open session in new window">↗</a>
            <% end %>
            <button type="submit" class="danger abort-button session-abort-button composer-stop-button" form="abort-form" hidden disabled title="Abort running Pi" aria-label="Abort running Pi"><span aria-hidden="true">⏹</span></button>
          </div>
        </header>

        <section class="conversation-scroll" id="conversation-scroll" tabindex="0" data-has-older-messages="<%= @conversation_has_older_messages ? "true" : "false" %>" data-older-message-count="<%= h @conversation_older_message_count.to_i %>" data-older-message-cursor="<%= h @conversation_start_index.to_i %>" data-older-messages-url="/conversation_older?session=<%= h Rack::Utils.escape(@selected_session.path) %>&amp;tree_leaf=<%= h Rack::Utils.escape(@conversation_tree_leaf_id.to_s) %>">
          <div class="current-session-find" data-current-session-find hidden>
            <input type="search" data-current-session-find-input aria-label="Find in conversation" autocomplete="off" spellcheck="false">
            <output class="current-session-find-count" data-current-session-find-count aria-live="polite">0 / 0</output>
            <button type="button" class="secondary current-session-find-button" data-current-session-find-previous aria-label="Previous match" title="Previous match">↑</button>
            <button type="button" class="secondary current-session-find-button" data-current-session-find-next aria-label="Next match" title="Next match">↓</button>
            <button type="button" class="secondary current-session-find-button" data-current-session-find-close aria-label="Close find" title="Close find">×</button>
            <label class="current-session-find-conversation-only"><input type="checkbox" data-current-session-find-conversation-only> Conversation only</label>
          </div>
          <div class="jump-controls jump-controls--top">
            <button type="button" class="jump-button jump-to-first" aria-label="Top">↑↑</button>
          </div>
          <% if @conversation_has_older_messages %>
            <button type="button" class="conversation-history-status" data-conversation-history-status>Earlier messages available</button>
          <% end %>
          <% if @messages.empty? %>
            <p class="empty">No messages in this session.</p>
          <% end %>

          <% @messages.each do |message| %>
            <%= erb :_message_article, layout: false, locals: { message: message, attachment_count: @attachment_counts[message.object_id], attachment_images: @attachment_images[message.object_id] } %>
          <% end %>

          <% live_snapshot = @live_snapshot || rpc_clients.live_snapshot(@selected_session.path) %>
          <% event_sequence = @conversation_history_persisted ? live_snapshot.fetch(:event_sequence) : live_snapshot.fetch(:event_replay_cursor) { rpc_clients.event_replay_cursor(@selected_session.path) } %>
          <% busy = live_snapshot.fetch(:busy, false) %>
          <% busy_since = live_snapshot[:busy_since] %>
          <% compacting = live_snapshot.fetch(:compacting, false) %>
          <% composer_state_since = live_snapshot[:compacting_since] || busy_since %>
          <% active_tool_events = live_snapshot.fetch(:active_tool_events) %>
          <% queued_messages = live_snapshot.fetch(:queued_messages, { "steering" => [], "followUp" => [] }) %>
          <% extension_ui_state = live_snapshot.fetch(:extension_ui, { pending_dialogs: [], statuses: [], widgets: [], title: nil }) %>
          <% active_tool_context = @subagent_tool_call_context.slice(*active_tool_events.filter_map { |event| event["toolCallId"] }) %>
          <% active_tool_timestamps = active_tool_context.filter_map { |tool_call_id, details| [tool_call_id, details[:timestamp]] if details[:timestamp] }.to_h %>
          <% active_tool_prompts = active_tool_context.filter_map { |tool_call_id, details| [tool_call_id, details[:prompt]] unless details[:prompt].to_s.empty? }.to_h %>
          <section id="live-output" data-events-url="/events?session=<%= h Rack::Utils.escape(@selected_session.path) %>" data-events-after="<%= h event_sequence %>" data-active-tool-events="<%= h JSON.generate(active_tool_events) %>" data-active-tool-timestamps="<%= h JSON.generate(active_tool_timestamps) %>" data-active-tool-prompts="<%= h JSON.generate(active_tool_prompts) %>" data-queued-messages="<%= h JSON.generate(queued_messages) %>" data-extension-ui-state="<%= h JSON.generate(extension_ui_state) %>" data-composer-state="<%= busy ? "running" : "idle" %>" data-composer-state-since="<%= h(composer_state_since ? (composer_state_since.to_f * 1000).to_i : "") %>" data-composer-busy-since="<%= h(busy_since ? (busy_since.to_f * 1000).to_i : "") %>" data-composer-compacting="<%= compacting ? "true" : "false" %>" data-agent-running="<%= live_snapshot.fetch(:agent_running, false) ? "true" : "false" %>" data-session-sync-mode="<%= h @session_sync_mode %>" data-session-sync-revision="<%= h @session_sync_revision %>"></section>
          <div class="jump-controls jump-controls--bottom">
            <button type="button" class="jump-button jump-to-latest" aria-label="Bottom">↓↓</button>
          </div>
        </section>

        <div class="composer">
          <div class="pending-messages" data-pending-messages role="status" aria-live="polite" hidden></div>
          <div class="composer-inner">
            <div class="extension-widgets" data-extension-widgets-above hidden></div>
            <details class="command-list<%= " is-disabled" if session_sync_blocked %>" id="command-list" data-loaded="false" data-commands-url="/commands?session=<%= h Rack::Utils.escape(@selected_session.path) %>"<%= ' data-session-sync-blocked="true"' if session_sync_blocked %>>
              <summary>Slash commands</summary>
              <div class="command-list-message" data-queued-slash-message hidden>Slash commands are not supported in steering or follow-up messages.</div>
            </details>

            <form method="post" action="/abort" class="abort-form" id="abort-form">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <% if session_only? %>
                <input type="hidden" name="session_only" value="1">
              <% end %>
              <% if selected_project_cwd %>
                <input type="hidden" name="project" value="<%= h selected_project_cwd %>">
              <% end %>
              <% if sidebar_session_search? %>
                <input type="hidden" name="session_search" value="<%= h sidebar_session_search_query %>">
              <% end %>
            </form>

            <div class="session-reconnect" role="status" aria-live="polite">
              <span>Session may be stale.</span>
              <button type="button" class="secondary reconnect-button">Reconnect</button>
            </div>

            <form method="post" action="/prompt" class="prompt-form" enctype="multipart/form-data">
              <% if session_sync_blocked %>
                <div class="session-sync-banner<%= " session-sync-banner--conflict" if @session_sync_mode == :conflict %>" role="status" data-session-sync-banner>
                  <div>
                    <% if @session_sync_mode == :external_follow %>
                      <strong>Session changed outside the gateway.</strong>
                      <span>Following external activity. Finish using this session in Pi CLI before continuing here.</span>
                    <% else %>
                      <strong>Session synchronization needs attention.</strong>
                      <span><%= h @session_sync_error %></span>
                    <% end %>
                    <span class="session-sync-error" data-session-sync-error hidden></span>
                  </div>
                  <button type="button" class="secondary" data-session-takeover<%= " disabled" if busy %>><%= busy ? "Waiting for gateway task…" : "Take over in gateway" %></button>
                </div>
              <% elsif @viewing_older_tree_leaf && @latest_tree_leaf_id %>
                <div class="tree-position-banner" role="status">
                  <div>
                    <strong>Viewing earlier tree point.</strong>
                    <span>Your next message will branch from here.</span>
                    <span class="tree-position-error" data-tree-latest-error aria-live="polite" hidden></span>
                  </div>
                  <button type="button" class="secondary" data-tree-latest-entry-id="<%= h @latest_tree_leaf_id %>">Jump to latest</button>
                </div>
              <% end %>
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <% if session_only? %>
                <input type="hidden" name="session_only" value="1">
              <% end %>
              <% if selected_project_cwd %>
                <input type="hidden" name="project" value="<%= h selected_project_cwd %>">
              <% end %>
              <% if sidebar_session_search? %>
                <input type="hidden" name="session_search" value="<%= h sidebar_session_search_query %>">
              <% end %>
              <span class="composer-state" data-state="idle" aria-live="polite"></span>
              <div class="attachment-tray" aria-live="polite"></div>
              <div class="composer-input-row">
                <input class="image-input" id="image-input" type="file" accept="image/*" multiple<%= " disabled" if session_sync_blocked %>>
                <label for="image-input" class="attach-button<%= " is-disabled" if session_sync_blocked %>" title="Attach images" aria-label="Attach images"<%= ' aria-disabled="true"' if session_sync_blocked %>>＋</label>
                <div class="composer-textarea-wrap">
                  <textarea name="message" rows="1" placeholder="<%= session_sync_blocked ? "Finish using this session in Pi CLI, then take over in the gateway." : "Ask Pi…" %>"<%= " disabled" if session_sync_blocked %>></textarea>
                  <div class="composer-path-list" id="composer-path-list" role="listbox" aria-label="Path suggestions" hidden></div>
                </div>
                <div class="send-control">
                  <button type="submit" class="send-button"<%= " disabled" if session_sync_blocked %>>Send</button>
                  <button type="button" class="send-menu-toggle" data-send-menu-toggle aria-label="More send options" aria-controls="send-options" aria-expanded="false" hidden<%= " disabled" if session_sync_blocked %>>⌄</button>
                  <div class="send-menu" id="send-options" data-send-menu hidden>
                    <button type="button" data-streaming-behavior="steer" aria-pressed="true">Steer</button>
                    <button type="button" data-streaming-behavior="follow_up" aria-pressed="false">Queue follow-up</button>
                  </div>
                </div>
              </div>
              <div class="extension-widgets" data-extension-widgets-below hidden></div>
              <div class="composer-controls">
                <div class="session-status-bar" id="session-status-bar" data-status-url="/status?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
                  <% session_status_items(@session_status).each do |label, value| %>
                    <% if label == "Model" %>
                      <button type="button" class="session-status-item model-settings-chip" data-status-key="model" data-modal-open="model-settings-modal" aria-label="Open model and thinking settings" <%= "disabled" if busy || session_sync_blocked %>><span class="session-status-label"><%= h label %></span> <span class="session-status-value"><%= h value %></span></button>
                    <% else %>
                      <span class="session-status-item" data-status-key="<%= h label.downcase %>"><span class="session-status-label"><%= h label %></span> <span class="session-status-value"><%= h value %></span></span>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </form>
          </div>
        </div>
      <% else %>
        <header class="session-header">
          <% unless session_only? %>
            <label for="mobile-session-toggle" class="mobile-sessions-button" aria-label="Open sessions"><span class="hamburger-icon" aria-hidden="true"></span><% if unread_sidebar_session_count.positive? %><span class="mobile-sessions-unread-badge" aria-label="<%= h unread_sidebar_session_aria_label %>" title="<%= h unread_sidebar_session_aria_label %>"><%= h unread_sidebar_session_count_label %></span><% end %></label>
          <% end %>
          <h1>Welcome to Pi</h1>
        </header>
        <section class="conversation-scroll" id="conversation-scroll" tabindex="0">
          <div class="empty empty-state">
            <div class="empty-state-title"><%= @all_sessions.any? ? "Select a session" : "No sessions yet" %></div>
            <p><%= @all_sessions.any? ? "Choose a session from the sidebar or start a new Pi session." : "Choose an existing project directory to start your first Pi session." %></p>
            <div class="empty-state-actions">
              <button type="button" data-modal-open="new-session-modal">Choose directory</button>
            </div>
          </div>
        </section>
      <% end %>
    </main>
