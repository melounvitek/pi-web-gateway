    <main class="conversation-panel">
      <% if @selected_session %>
        <header class="session-header">
          <label for="mobile-session-toggle" class="mobile-sessions-button"><span class="mobile-sessions-label">Sessions</span><span class="mobile-sessions-hide-label">Hide</span></label>
          <h1 title="<%= h @selected_session.display_name %>"><%= h @selected_session.display_name %></h1>
        </header>

        <section class="conversation-scroll" id="conversation-scroll">
          <div class="jump-controls jump-controls--top">
            <button type="button" class="jump-button jump-to-first">first ↑</button>
            <button type="button" class="jump-button jump-to-previous-user">previous ↑</button>
          </div>
          <% if @messages.empty? %>
            <p class="empty">No messages in this session.</p>
          <% end %>

          <% @messages.each do |message| %>
            <article class="<%= h message_article_class(message) %>" data-role="<%= h message.role %>" data-message-fingerprint="<%= h message_fingerprint(message.role, message.text, message.timestamp) %>">
              <header class="message-header">
                <div class="role"><%= h message_role_label(message.role) %></div>
                <% if message_metadata(message) %>
                  <div class="message-meta"><%= h message_metadata(message) %></div>
                <% end %>
                <% if message.role == "assistant" && !message.compact && !message.thinking %>
                  <button type="button" class="copy-button" data-copy-target="message">Copy</button>
                <% end %>
              </header>
              <% if message.thinking %>
                <div class="message-body message-body--thinking"><span class="thinking-prefix">Thinking:</span> <%= render_message_body(message) %></div>
              <% elsif message.compact %>
                <details class="message-details"<%= " open" if message.expanded %>>
                  <summary><span class="compact-summary"><%= message.tool_summary_html || h(message.summary) %></span></summary>
                  <pre class="message-body"><%= h message.text %></pre>
                  <% if message.raw_details.to_s != "" %>
                    <details class="raw-details">
                      <summary>Raw details</summary>
                      <pre><%= h message.raw_details %></pre>
                    </details>
                  <% end %>
                  <button type="button" class="details-collapse-button" data-collapse-details>▴ Collapse details</button>
                </details>
              <% else %>
                <% if message.role == "assistant" %>
                  <div class="message-body message-body--markdown"><%= render_message_body(message) %></div>
                <% else %>
                  <pre class="message-body"><%= render_message_body(message) %></pre>
                <% end %>
              <% end %>
            </article>
          <% end %>

          <section id="live-output" data-events-url="/events?session=<%= h Rack::Utils.escape(@selected_session.path) %>" data-events-after="<%= h rpc_clients.event_sequence(@selected_session.path) %>" data-composer-state="<%= rpc_clients.busy?(@selected_session.path) ? "running" : "idle" %>"></section>
          <div class="jump-controls jump-controls--bottom">
            <button type="button" class="jump-button jump-to-next-user">next ↓</button>
            <button type="button" class="jump-button jump-to-latest">latest ↓</button>
          </div>
        </section>

        <div class="composer">
          <div class="composer-inner">
            <details class="command-list" id="command-list" data-loaded="false" data-commands-url="/commands?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
              <summary>Slash commands</summary>
            </details>

            <form method="post" action="/abort" class="abort-form" id="abort-form">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
            </form>

            <div class="session-reconnect" role="status" aria-live="polite">
              <span>Session may be stale.</span>
              <button type="button" class="secondary reconnect-button">Reconnect</button>
            </div>

            <form method="post" action="/prompt" class="prompt-form" enctype="multipart/form-data">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <% expanded_cwds.each do |expanded_cwd| %>
                <input type="hidden" name="expanded_cwd[]" value="<%= h expanded_cwd %>">
              <% end %>
              <span class="composer-state" data-state="idle" aria-live="polite"></span>
              <div class="attachment-tray" aria-live="polite"></div>
              <div class="composer-input-row">
                <input class="image-input" id="image-input" type="file" accept="image/*" multiple>
                <label for="image-input" class="attach-button" title="Attach images" aria-label="Attach images">＋</label>
                <textarea name="message" rows="1" placeholder="Ask Pi… Enter to send, Shift+Enter for newline."></textarea>
                <button type="submit" class="send-button">Send</button>
                <button type="submit" class="danger abort-button session-abort-button composer-stop-button" form="abort-form" hidden disabled title="Abort running Pi" aria-label="Abort running Pi"><span aria-hidden="true">⏹</span></button>
              </div>
              <div class="composer-controls">
                <div class="session-status-bar" id="session-status-bar" data-status-url="/status?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
                  <% session_status_items(@session_status).each do |label, value| %>
                    <span class="session-status-item" data-status-key="<%= h label.downcase %>"><span class="session-status-label"><%= h label %></span> <span class="session-status-value"><%= h value %></span></span>
                  <% end %>
                </div>
              </div>
            </form>
          </div>
        </div>
      <% else %>
        <header class="session-header">
          <label for="mobile-session-toggle" class="mobile-sessions-button"><span class="mobile-sessions-label">Sessions</span><span class="mobile-sessions-hide-label">Hide</span></label>
          <h1>No session selected</h1>
        </header>
        <section class="conversation-scroll" id="conversation-scroll">
          <p class="empty empty-state">Create a Pi session first, then refresh this page.</p>
        </section>
      <% end %>
    </main>
