<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pi Web Gateway</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#18181e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Pi Gateway">
  <style>
    :root { color-scheme: dark; --bg: #18181e; --sidebar: #1e1e24; --panel: #1e1e24; --panel-soft: #282832; --panel-softer: #3a3a4a; --border: #505050; --text: #d4d4d4; --muted: #808080; --muted-soft: #666666; --accent: #8abeb7; --accent-hover: #00d7ff; --success: #b5bd68; --danger: #cc6666; --danger-soft: #3c2828; --code: #18181e; --link: #81a2be; --warning: #ffff00; --button-text: #18181e; }
    html, body { height: 100%; }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--text); background: var(--bg); overflow: hidden; }
    .app-shell { display: grid; grid-template-columns: 22rem minmax(0, 1fr); height: 100vh; min-height: 0; }
    .session-sidebar { min-height: 0; display: flex; flex-direction: column; border-right: 1px solid var(--border); padding: 1rem; overflow: hidden; background: var(--sidebar); }
    .session-sidebar-content { flex: 1 1 auto; min-height: 0; overflow-y: auto; scrollbar-gutter: stable; }
    .conversation-panel { display: grid; grid-template-rows: auto minmax(0, 1fr) auto; min-width: 0; min-height: 0; background: var(--panel); }
    .session-header { position: sticky; top: 0; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 1.5rem 0.75rem; border-bottom: 1px solid var(--border); background: rgba(30, 30, 36, 0.96); backdrop-filter: blur(8px); box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18); }
    .session-header-title { flex: 1 1 auto; min-width: 0; display: grid; gap: 0.15rem; }
    .session-header h1 { min-width: 0; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .session-header-project { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--muted); font-size: 0.84rem; font-weight: 650; }
    .session-header-new-form { flex: 0 0 auto; margin: 0; }
    .conversation-scroll { min-height: 0; overflow-y: auto; overflow-x: hidden; scrollbar-gutter: stable; padding: 1.5rem; }
    .composer { position: sticky; bottom: 0; padding: 0.75rem 1.5rem 1rem; border-top: 1px solid var(--border); background: rgba(30, 30, 36, 0.97); box-shadow: 0 -10px 24px rgba(0, 0, 0, 0.16); }
    .composer-inner { display: grid; gap: 0.6rem; }
    .attachment-tray { display: none; flex-wrap: wrap; gap: 0.5rem; padding: 0.5rem; border: 1px dashed var(--border); border-radius: 0.55rem; background: var(--panel-soft); }
    .attachment-tray.has-attachments { display: flex; }
    .attachment { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.25rem 0.4rem; border-radius: 0.45rem; background: var(--panel-softer); color: var(--muted); font-size: 0.82rem; }
    .attachment img { width: 2rem; height: 2rem; border-radius: 0.35rem; object-fit: cover; }
    .attachment button { padding: 0.1rem 0.35rem; background: transparent; border: 1px solid var(--border); color: var(--muted); }
    .attachment button:hover { color: var(--text); background: var(--panel-soft); transform: none; }
    .composer-input-row { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: end; gap: 0.55rem; }
    .image-input { position: fixed; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
    .attach-button { display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; min-width: 2.75rem; min-height: 2.75rem; padding: 0; border-radius: 0.55rem; background: var(--panel-softer); color: var(--text); font-weight: 800; cursor: pointer; }
    .attach-button:hover { background: var(--border); }
    h1 { font-size: 1.25rem; line-height: 1.2; margin: 0 0 1rem; letter-spacing: -0.01em; }
    h2 { font-size: 0.78rem; margin: 0; color: var(--muted-soft); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-sidebar-header { display: block; }
    .sidebar-project-filter-form { margin: -0.25rem 0 0.65rem; }
    .sidebar-project-filter { width: 100%; padding: 0.5rem 0.65rem; color: var(--muted); font-size: 0.84rem; font-weight: 700; background: rgba(40, 40, 50, 0.72); }
    .recent-sessions { margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(80, 80, 80, 0.7); }
    .recent-sessions-header { display: flex; align-items: center; gap: 0.4rem; margin: 0.75rem 0 0.5rem; }
    .recent-sessions-header h2 { flex: 1; min-width: 0; }
    .cwd-header { display: flex; align-items: center; gap: 0.4rem; margin: 1.25rem 0 0.5rem; }
    .cwd-header h2 { flex: 1; min-width: 0; }
    .cwd-toggle { display: inline-block; margin: 0.35rem 0 0.5rem; font-size: 0.8rem; color: var(--muted); text-decoration: none; }
    .cwd-toggle:hover { color: var(--text); text-decoration: underline; }
    .sidebar-load-more { display: flex; align-items: center; justify-content: center; gap: 0.45rem; margin: 0.7rem 0 0.5rem; padding: 0.6rem 0.75rem; border-radius: 0.6rem; background: var(--panel-softer); color: var(--text); font-size: 0.84rem; font-weight: 800; text-decoration: none; }
    .sidebar-load-more:hover { background: var(--border); }
    .sidebar-load-more-spinner { display: none; width: 0.95rem; height: 0.95rem; border: 2px solid rgba(138, 190, 183, 0.25); border-top-color: var(--accent); border-radius: 999px; animation: session-switch-spin 800ms linear infinite; }
    .sidebar-load-more.is-loading { pointer-events: none; opacity: 0.82; }
    .sidebar-load-more.is-loading .sidebar-load-more-spinner { display: inline-block; }
    a.session { position: relative; display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 0.5rem; padding: 0.65rem 0.75rem; margin: 0.25rem 0; border-radius: 0.6rem; color: inherit; text-decoration: none; border: 1px solid transparent; transition: background 120ms ease, border-color 120ms ease, transform 120ms ease; }
    a.session:hover { background: var(--panel-soft); border-color: var(--border); transform: translateX(1px); }
    a.session.selected { background: linear-gradient(90deg, rgba(138, 190, 183, 0.22), rgba(138, 190, 183, 0.08)); border-color: rgba(138, 190, 183, 0.55); }
    a.session.selected::before { content: ""; position: absolute; left: -1rem; top: 0.7rem; bottom: 0.7rem; width: 4px; border-radius: 999px; background: var(--accent); }
    a.session.unread .session-title { color: var(--text); font-weight: 800; }
    a.session.unread .session-indicators::before { content: "new"; padding: 0.1rem 0.35rem; border: 1px solid rgba(138, 190, 183, 0.45); border-radius: 999px; color: var(--accent); background: rgba(138, 190, 183, 0.08); font-size: 0.62rem; font-weight: 800; line-height: 1; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-content { min-width: 0; }
    .session-indicators { display: inline-flex; align-items: center; justify-content: flex-end; gap: 0.35rem; min-width: 0.7rem; }
    .session-shortcut { display: none; align-items: center; justify-content: center; width: 1.35rem; height: 1.35rem; border: 1px solid rgba(138, 190, 183, 0.55); border-radius: 999px; background: rgba(138, 190, 183, 0.14); color: var(--accent); font-size: 0.76rem; font-weight: 800; line-height: 1; font-variant-numeric: tabular-nums; }
    body.session-shortcuts-visible .recent-session .session-shortcut { display: inline-flex; }
    .session-title { font-weight: 650; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-notification-test-link { display: flex; align-items: center; justify-content: center; margin-top: 1.25rem; padding: 0.65rem 0.75rem; border-radius: 0.6rem; background: var(--panel-softer); color: var(--text); font-size: 0.86rem; font-weight: 800; text-decoration: none; }
    .sidebar-notification-test-link:hover { background: var(--border); }
    .session-project { display: inline-block; max-width: 100%; margin-top: 0.32rem; padding: 0.1rem 0.42rem; border: 1px solid rgba(138, 190, 183, 0.28); border-radius: 999px; background: rgba(138, 190, 183, 0.08); color: var(--accent); font-size: 0.72rem; font-weight: 800; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; vertical-align: top; }
    .session-meta { font-size: 0.8rem; color: var(--muted); margin-top: 0.2rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-icon-button { flex: 0 0 auto; min-height: 1.65rem; padding: 0.2rem 0.55rem; border-radius: 999px; line-height: 1; }
    .session-rename { display: none; gap: 0.35rem; grid-template-columns: minmax(0, 1fr) auto; margin: 0.3rem 0 0.55rem; }
    a.session.selected + .session-rename { display: grid; }
    .session-rename input { min-width: 0; padding: 0.45rem 0.55rem; font-size: 0.82rem; }
    .session-rename button { padding: 0.45rem 0.6rem; font-size: 0.82rem; }
    .session-running-indicator { display: inline-flex; align-items: center; gap: 0.3rem; color: var(--success); font-size: 0.75rem; font-weight: 700; }
    .session-running-indicator::before { content: ""; width: 0.5rem; height: 0.5rem; border-radius: 999px; background: var(--success); box-shadow: 0 0 0 4px rgba(181, 189, 104, 0.16); animation: progress-blink 1000ms ease-in-out infinite; }
    .empty { color: var(--muted); background: var(--panel-soft); border: 1px solid var(--border); border-radius: 0.75rem; padding: 1rem; }
    .empty-state { max-width: 34rem; margin: 2rem auto; text-align: center; }
    .message { position: relative; min-width: 0; max-width: 100%; border: 1px solid var(--border); border-radius: 0.9rem; padding: 0.9rem; margin-bottom: 0.85rem; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12); scroll-margin-top: 3.5rem; }
    .message--user { margin-left: 10%; background: #343541; border-color: rgba(69, 133, 255, 0.72); color: #d4d4d4; }
    .message--assistant { margin-right: 10%; background: #080d20; border-color: rgba(69, 133, 255, 0.32); color: #f0c7a4; }
    .message--thinking { margin-right: 16%; background: #080d20; border-color: rgba(69, 133, 255, 0.22); border-style: dashed; color: #7f7f88; box-shadow: none; }
    .message--status { background: rgba(24, 24, 30, 0.72); color: var(--muted); box-shadow: none; }
    .message--tool { background: #080d20; border-color: rgba(69, 133, 255, 0.32); border-style: dashed; color: var(--text); }
    .message--tool-transcript { background: #283228; border-color: rgba(181, 189, 104, 0.28); color: #d8ded8; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
    .message--tool-transcript .message-details summary { color: #d8ded8; }
    .message--tool-transcript .message-body { color: rgba(216, 222, 216, 0.68); line-height: 1.35; tab-size: 2; }
    .tool-command { color: var(--text); font-weight: 800; }
    .tool-path { color: var(--accent); font-weight: 500; }
    .tool-range { color: var(--warning); font-weight: 600; }
    .message--error, .message--tool-error { background: var(--danger-soft); border-color: rgba(242, 63, 66, 0.55); color: #ffb4b6; }
    .message--compact { padding: 0.75rem 0.9rem; box-shadow: none; }
    .message--live { box-shadow: 0 0 0 1px rgba(138, 190, 183, 0.45) inset, 0 6px 18px rgba(0, 0, 0, 0.12); }
    .message-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
    .message-turn-nav { position: absolute; top: 0.6rem; right: 0.6rem; display: inline-flex; gap: 0.3rem; pointer-events: none; }
    .message-turn-button { display: inline-flex; align-items: center; justify-content: center; width: 1.75rem; height: 1.75rem; padding: 0; border: 0; border-radius: 0.48rem; background: rgba(138, 190, 183, 0.88); color: var(--button-text); font-size: 0.78rem; font-weight: 800; line-height: 1; text-decoration: none; box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2); opacity: 0.72; pointer-events: auto; transition: background 120ms ease, opacity 120ms ease, transform 120ms ease; }
    .message-turn-button:hover { background: var(--accent-hover); opacity: 1; transform: translateY(-1px); }
    .message--user .message-header { margin-bottom: 0.75rem; padding-right: 4.35rem; }
    .role { font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
    .message--error .role { color: #ffb4b6; }
    .message-meta { font-size: 0.75rem; color: var(--muted-soft); }
    .message-details { min-width: 0; max-width: 100%; }
    .message-details summary { cursor: pointer; font-weight: 700; color: var(--muted); }
    .message--tool .message-details summary, .message--tool-transcript .message-details summary { max-width: 100%; overflow-x: auto; white-space: nowrap; }
    .message--tool .message-body, .message--tool-transcript .message-body, .raw-details pre { max-width: 100%; overflow-x: auto; }
    .message-details summary:hover { color: var(--text); }
    .message-details[open] summary { margin-bottom: 0.5rem; }
    .details-collapse-button { margin-top: 0.75rem; border: 0; background: transparent; color: var(--muted); cursor: pointer; font: inherit; font-weight: 700; padding: 0; }
    .details-collapse-button:hover { color: var(--text); }
    .compact-summary { margin-left: 0.25rem; }
    .message-body--thinking { font-size: 0.95rem; font-style: italic; line-height: 1.45; color: var(--muted); }
    .thinking-prefix { font-style: normal; font-weight: 700; color: var(--muted-soft); }
    .message-body--markdown { line-height: 1.6; overflow-wrap: anywhere; }
    .message-body--markdown[data-rendering="pending"]:empty::before { content: "…"; color: var(--muted); }
    .message-body--markdown > :first-child { margin-top: 0; }
    .message-body--markdown > :last-child { margin-bottom: 0; }
    .message-body--markdown h1, .message-body--markdown h2, .message-body--markdown h3 { margin: 1rem 0 0.4rem; color: var(--text); }
    .message-body--markdown h1 { font-size: 1.35rem; }
    .message-body--markdown h2 { font-size: 1.15rem; white-space: normal; overflow: visible; text-overflow: clip; text-transform: none; letter-spacing: 0; }
    .message-body--markdown h3 { font-size: 1rem; }
    .message-body--markdown ul, .message-body--markdown ol { padding-left: 1.4rem; }
    .message-body--markdown blockquote { margin: 0.75rem 0; padding-left: 1rem; border-left: 3px solid var(--accent); color: var(--muted); }
    .message-body--markdown code { padding: 0.1rem 0.25rem; border-radius: 0.25rem; background: var(--code); font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.92em; }
    .message-body--markdown pre { padding: 0.85rem; border-radius: 0.6rem; background: var(--code); color: var(--text); overflow-x: auto; white-space: pre; border: 1px solid var(--border); }
    .message-body--markdown pre code { padding: 0; background: transparent; color: inherit; }
    .message-body--markdown a { color: var(--link); }
    .message-attachments { display: inline-flex; align-items: center; gap: 0.35rem; margin-top: 0.6rem; padding: 0.25rem 0.45rem; border-radius: 0.45rem; background: rgba(138, 190, 183, 0.12); color: var(--muted); font-size: 0.82rem; font-weight: 700; }
    .message--tool-error .message-details summary { color: #ffb4b6; }
    .raw-details { margin-top: 0.75rem; }
    .raw-details summary { font-size: 0.8rem; font-weight: 600; color: var(--muted-soft); }
    pre { white-space: pre-wrap; overflow-wrap: anywhere; margin: 0; font-family: inherit; }
    .prompt-form, .inline-form { display: grid; gap: 0.5rem; margin: 0; }
    .command-list { display: none; border: 1px solid var(--border); border-radius: 0.75rem; padding: 0.75rem; scrollbar-gutter: stable; background: var(--panel-soft); }
    .command-list.is-visible { display: block; }
    .command-list summary { cursor: pointer; font-size: 0.85rem; font-weight: 700; color: var(--muted); }
    .command-list summary:hover { color: var(--text); }
    .command-list h3 { font-size: 0.75rem; text-transform: uppercase; color: var(--muted-soft); margin: 0.75rem 0 0.25rem; }
    .command-list h3:first-child { margin-top: 0.75rem; }
    .command-filter { width: 100%; margin-top: 0.6rem; padding: 0.45rem 0.6rem; font-size: 0.9rem; }
    .command { font-size: 0.9rem; margin: 0.25rem 0; padding: 0.2rem 0.25rem; border-radius: 0.35rem; cursor: pointer; }
    .command:hover { background: var(--panel-softer); }
    .command code { font-weight: 700; color: var(--accent); }
    .composer-state { display: none; align-items: center; gap: 0.4rem; min-height: 1.1rem; font-size: 0.85rem; color: var(--muted); }
    .composer-state::before { content: ""; width: 0.48rem; height: 0.48rem; border-radius: 999px; background: var(--muted-soft); }
    .composer-state[data-state="running"], .composer-state[data-state="sending"] { display: inline-flex; color: var(--accent); font-weight: 700; }
    .composer-state[data-state="running"]::before, .composer-state[data-state="sending"]::before { background: var(--success); box-shadow: 0 0 0 4px rgba(181, 189, 104, 0.15); }
    .composer-state[data-state="error"] { display: inline-flex; color: #ffb4b6; }
    .composer-state[data-state="error"]::before { background: var(--danger); }
    .composer-controls { display: flex; justify-content: flex-end; }
    .composer-controls:has(.session-status-bar:empty) { display: none; }
    .session-status-bar { display: flex; justify-content: flex-end; gap: 0.9rem; color: var(--muted-soft); font-size: 0.78rem; font-variant-numeric: tabular-nums; }
    .session-status-item { display: inline-flex; gap: 0.25rem; white-space: nowrap; }
    .session-status-label { color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-reconnect { display: none; align-items: center; justify-content: space-between; gap: 0.75rem; padding: 0.65rem 0.75rem; border: 1px solid rgba(255, 255, 0, 0.28); border-radius: 0.65rem; background: rgba(255, 255, 0, 0.08); color: var(--text); font-size: 0.9rem; }
    .session-reconnect.is-visible { display: flex; }
    .reconnect-button { flex: 0 0 auto; padding: 0.35rem 0.6rem; font-size: 0.82rem; }
    .abort-form { display: none; }
    input, select, textarea { box-sizing: border-box; font: inherit; padding: 0.75rem; border: 1px solid var(--border); border-radius: 0.55rem; color: var(--text); background: var(--panel-soft); outline: none; }
    input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(138, 190, 183, 0.2); }
    textarea { width: 100%; resize: none; min-height: 2.75rem; max-height: 12rem; line-height: 1.4; overflow-y: hidden; }
    .send-button, .composer-stop-button { display: none; }
    .session-header .composer-stop-button.is-visible { position: relative; isolation: isolate; display: inline-flex; align-self: center; }
    .composer-stop-button.is-visible:not(:disabled)::before { content: ""; position: absolute; inset: -0.34rem; z-index: -1; border: 2px solid rgba(204, 102, 102, 0.78); border-radius: inherit; animation: stop-button-pulse 1400ms ease-out infinite; pointer-events: none; }
    .attach-button.is-disabled { opacity: 0.48; cursor: not-allowed; pointer-events: none; }
    button { justify-self: end; padding: 0.5rem 0.9rem; border: 0; border-radius: 0.55rem; background: var(--accent); color: var(--button-text); font-weight: 700; cursor: pointer; transition: background 120ms ease, transform 120ms ease; }
    button:hover { background: var(--accent-hover); transform: translateY(-1px); }
    button:disabled { opacity: 0.48; cursor: not-allowed; transform: none; }
    button:disabled:hover { background: var(--accent); transform: none; }
    [hidden] { display: none !important; }
    button.secondary { background: var(--panel-softer); color: var(--text); }
    button.secondary:hover { background: var(--border); }
    button.danger { background: #a55353; color: white; }
    button.danger:hover { background: var(--danger); }
    button.danger:disabled:hover { background: #b83b3e; }
    .session-abort-button { flex: 0 0 auto; display: inline-flex; align-items: center; justify-content: center; width: 2.1rem; height: 2.1rem; padding: 0; border-radius: 999px; font-size: 1rem; line-height: 1; }
    .copy-button { margin-left: auto; padding: 0.2rem 0.5rem; font-size: 0.75rem; background: transparent; border: 1px solid var(--border); color: var(--muted); }
    .copy-button:hover { color: var(--text); background: var(--panel-softer); transform: none; }
    .jump-controls { position: sticky; z-index: 3; display: flex; justify-content: center; gap: 0.35rem; height: 0; margin: 0 auto; overflow: visible; visibility: hidden; opacity: 0; pointer-events: none; }
    .jump-controls.is-visible { visibility: visible; opacity: 1; }
    .jump-controls--top { top: 0.75rem; }
    .jump-controls--bottom { bottom: 0.75rem; transform: translateY(-100%); }
    .jump-button { display: none; box-shadow: 0 8px 22px rgba(0, 0, 0, 0.28); pointer-events: auto; }
    .jump-button.is-visible { display: inline-flex; }
    .session-switch-overlay { position: fixed; inset: 0; z-index: 140; display: none; place-items: center; background: rgba(24, 24, 30, 0.5); backdrop-filter: blur(2px); }
    body.session-switching .session-switch-overlay { display: grid; }
    .session-switch-indicator { display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 999px; background: rgba(30, 30, 36, 0.94); color: var(--text); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35); font-weight: 700; }
    .session-switch-spinner { width: 1.1rem; height: 1.1rem; border: 2px solid rgba(138, 190, 183, 0.25); border-top-color: var(--accent); border-radius: 999px; animation: session-switch-spin 800ms linear infinite; }
    .browser-access-overlay { position: fixed; inset: 0; z-index: 110; display: none; place-items: start center; padding: 1rem; background: rgba(24, 24, 30, 0.38); pointer-events: none; }
    .browser-access-overlay.is-visible { display: grid; }
    .browser-access-card { width: min(38rem, 100%); display: grid; gap: 0.65rem; padding: 0.85rem 1rem; border: 1px solid rgba(138, 190, 183, 0.5); border-radius: 0.9rem; background: rgba(30, 30, 36, 0.97); box-shadow: 0 14px 34px rgba(0, 0, 0, 0.36); pointer-events: auto; }
    .browser-access-title { font-weight: 850; }
    .browser-access-meta { color: var(--muted); font-size: 0.85rem; overflow-wrap: anywhere; }
    .browser-access-actions { display: flex; justify-content: flex-end; gap: 0.5rem; }
    .modal-overlay { position: fixed; inset: 0; z-index: 120; display: grid; place-items: center; padding: 1rem; background: rgba(0, 0, 0, 0.55); backdrop-filter: blur(3px); }
    .modal-card { width: min(34rem, 100%); max-height: calc(100dvh - 2rem); display: grid; gap: 1rem; overflow-y: auto; padding: 1rem; border: 1px solid var(--border); border-radius: 0.95rem; background: var(--panel); box-shadow: 0 18px 48px rgba(0, 0, 0, 0.45); }
    .modal-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .modal-header h2 { color: var(--text); font-size: 1rem; text-transform: none; letter-spacing: 0; }
    .modal-close-button { width: 2rem; height: 2rem; padding: 0; border-radius: 999px; font-size: 1.2rem; line-height: 1; }
    .modal-field { display: grid; gap: 0.35rem; color: var(--muted); font-size: 0.85rem; font-weight: 700; }
    .modal-field input, .modal-field select { width: 100%; min-width: 0; }
    .new-session-cwd-form { display: grid; gap: 0.75rem; }
    .cwd-validation-message { min-height: 1.2rem; color: var(--muted); font-size: 0.85rem; }
    .cwd-validation-message.is-valid { color: var(--success); }
    .cwd-validation-message.is-invalid { color: #ffb4b6; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 0.5rem; }
    @keyframes session-switch-spin { to { transform: rotate(360deg); } }
    @keyframes stop-button-pulse { 0% { transform: scale(0.82); opacity: 0.9; } 70%, 100% { transform: scale(1.28); opacity: 0; } }
    @keyframes progress-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.32; } }
    @media (prefers-reduced-motion: reduce) { .composer-stop-button.is-visible:not(:disabled)::before, .session-running-indicator::before { animation: none; opacity: 1; } }
    .mobile-session-toggle, .mobile-sessions-button, .mobile-sidebar-backdrop { display: none; }
    .hamburger-icon { position: relative; display: inline-block; width: 1.25rem; height: 0.9rem; border-top: 2px solid currentColor; border-bottom: 2px solid currentColor; }
    .hamburger-icon::before { content: ""; position: absolute; left: 0; right: 0; top: 50%; border-top: 2px solid currentColor; transform: translateY(-50%); }
    @supports (height: 100dvh) { .app-shell { height: 100dvh; } }
    @media (max-width: 760px) {
      html, body { width: 100%; max-width: 100vw; overflow-x: hidden; }
      .app-shell { display: block; width: 100%; max-width: 100vw; height: 100dvh; overflow-x: hidden; }
      .session-sidebar { position: fixed; inset: 0 auto 0 0; z-index: 10; display: flex; flex-direction: column; width: min(21rem, calc(100vw - 3rem)); max-height: none; padding: calc(0.75rem + env(safe-area-inset-top)) 0.75rem calc(0.75rem + env(safe-area-inset-bottom)); border-right: 1px solid var(--border); border-bottom: 0; transform: translateX(-105%); transition: transform 160ms ease; }
      .mobile-session-toggle:checked + .session-sidebar { transform: translateX(0); }
      .mobile-sidebar-backdrop { position: fixed; inset: 0; z-index: 9; background: rgba(0, 0, 0, 0.46); }
      .mobile-session-toggle:checked ~ .mobile-sidebar-backdrop { display: block; }
      .mobile-sessions-button { display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; width: 2.4rem; height: 2.4rem; padding: 0; border-radius: 0.55rem; background: var(--panel-softer); color: var(--text); cursor: pointer; }
      .session-sidebar-header { position: sticky; top: calc(-0.75rem - env(safe-area-inset-top)); z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin: calc(-0.75rem - env(safe-area-inset-top)) -0.75rem 0.5rem; padding: calc(0.75rem + env(safe-area-inset-top)) 0.75rem 0.5rem; background: rgba(30, 30, 36, 0.96); backdrop-filter: blur(8px); }
      .mobile-sessions-close-button { margin-left: auto; }
      .session-sidebar h1 { margin: 0; font-size: 1rem; }
      .cwd-header { margin: 0.85rem 0 0.4rem; }
      a.session { padding: 0.55rem 0.65rem; }
      a.session.selected::before { left: -0.75rem; }
      .conversation-panel { width: 100%; max-width: 100vw; height: 100dvh; min-width: 0; min-height: 0; overflow-x: hidden; }
      .session-header { width: 100%; max-width: 100vw; min-width: 0; padding: 0.75rem 1rem 0.6rem; gap: 0.75rem; overflow: hidden; }
      .session-header-title { flex: 1 1 0; }
      .session-header h1 { font-size: 1rem; }
      .session-header-project { font-size: 0.76rem; }
      .session-abort-button { width: 2.4rem; height: 2.4rem; }
      .conversation-scroll { padding: 0.75rem; }
      .jump-controls.is-visible { transition: opacity 140ms ease, visibility 140ms ease; }
      body:not(.is-conversation-scrolling) .jump-controls.is-visible { visibility: hidden; opacity: 0; pointer-events: none; }
      .message { margin-bottom: 0.65rem; padding: 0.75rem; border-radius: 0.75rem; }
      .message--user, .message--assistant { margin-left: 0; margin-right: 0; }
      .message-header { flex-wrap: wrap; }
      .copy-button { min-height: 2rem; padding: 0.3rem 0.65rem; }
      .message-body--markdown { line-height: 1.5; }
      .message-body--markdown pre { font-size: 0.82rem; }
      .message, .message-body--markdown, .message--tool-transcript .message-body, pre { min-width: 0; overflow-wrap: anywhere; word-break: break-word; }
      .message--tool-transcript .message-body, pre { white-space: pre-wrap; }
      .composer, .composer-inner, .prompt-form, .composer-controls { width: 100%; max-width: 100%; min-width: 0; }
      .composer { padding: 0.65rem 0.75rem calc(0.75rem + env(safe-area-inset-bottom)); overflow-x: hidden; }
      .composer-input-row { width: 100%; max-width: 100%; min-width: 0; grid-template-columns: 2.75rem minmax(0, 1fr) 3.25rem; gap: 0.4rem; }
      .attach-button, .send-button { min-width: 0; width: 100%; min-height: 2.75rem; padding: 0; }
      .attach-button { font-size: 1.3rem; }
      .send-button { display: inline-flex; align-items: center; justify-content: center; font-size: 0; }
      .send-button::before { content: "↑"; font-size: 1.35rem; line-height: 1; }
      .command-list { max-height: 30dvh; overflow-y: auto; }
      .composer-controls { justify-content: flex-start; }
      .session-status-bar { width: 100%; max-width: 100%; min-width: 0; justify-content: center; text-align: center; flex-wrap: wrap; gap: 0.35rem 0.7rem; overflow: hidden; font-size: 0.72rem; }
      .session-status-item { min-width: 0; }
      .session-status-value { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      input, select, textarea { font-size: 16px; }
      textarea { min-height: 2.75rem; max-height: 8rem; padding: 0.65rem 0.7rem; }
      textarea::placeholder { font-size: 0.95rem; }
      .attachment { max-width: 100%; }
      .attachment span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .modal-overlay { place-items: end stretch; padding: 0; }
      .modal-card { width: 100%; max-height: min(82dvh, calc(100dvh - env(safe-area-inset-top) - 1rem)); padding: 1rem; padding-bottom: calc(1rem + env(safe-area-inset-bottom)); border-right: 0; border-bottom: 0; border-left: 0; border-radius: 1rem 1rem 0 0; }
      .modal-header h2 { font-size: 1.1rem; }
      .modal-actions { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 0.6rem; }
      .modal-actions button { width: 100%; justify-self: stretch; padding: 0.8rem 0.75rem; }
      .session-sidebar-content, .conversation-scroll, .command-list { scrollbar-width: none; }
      .session-sidebar-content::-webkit-scrollbar, .conversation-scroll::-webkit-scrollbar, .command-list::-webkit-scrollbar { display: none; }
    }
  </style>
</head>
<body data-browser-access-enabled="<%= browser_access_enabled? ? "true" : "false" %>">
  <div class="app-shell">
    <input type="checkbox" class="mobile-session-toggle" id="mobile-session-toggle">
    <%= erb :_sidebar, layout: false %>
    <label for="mobile-session-toggle" class="mobile-sidebar-backdrop" aria-label="Hide sessions"></label>

    <%= erb :_conversation, layout: false %>
  </div>
  <%= erb :_new_session_modal, layout: false %>
  <div class="session-switch-overlay" role="status" aria-live="polite" aria-label="Loading">
    <div class="session-switch-indicator"><span class="session-switch-spinner" aria-hidden="true"></span> Loading…</div>
  </div>
  <div class="browser-access-overlay" data-browser-access-overlay aria-live="polite">
    <div class="browser-access-card">
      <div class="browser-access-title" data-browser-access-title></div>
      <div class="browser-access-meta" data-browser-access-meta></div>
      <div class="browser-access-actions">
        <button class="secondary" type="button" data-browser-access-deny>Deny</button>
        <button type="button" data-browser-access-allow>Allow</button>
      </div>
    </div>
  </div>
  <script>
    let sessionSidebar = null;
    let conversationPanel = null;
    let liveOutput = null;
    let promptForm = null;
    let abortForm = null;
    let promptTextarea = null;
    let promptSessionInput = null;
    let sendButton = null;
    let composerStopButton = null;
    let attachButton = null;
    let attachmentTray = null;
    let imageInput = null;
    let composerState = null;
    let abortButton = null;
    let commandList = null;
    let commandFilter = null;
    let conversationScroll = null;
    let topJumpControls = null;
    let bottomJumpControls = null;
    let jumpToFirstButton = null;
    let jumpToLatestButton = null;
    let sessionStatusBar = null;
    let reconnectBanner = null;
    let reconnectButton = null;
    let browserAccessOverlay = null;
    let browserAccessCurrentCode = null;
    let browserAccessPollTimer = null;
    let liveAssistantMessage = null;
    let liveAssistantSegments = new Map();
    let liveAssistantSeen = false;
    let liveAgentRunning = false;
    let liveBashToolCalls = new Map();
    let liveToolExecutions = new Map();
    let liveUserMessages = new Map();
    let liveStatusModel = null;
    let liveStatusThinking = null;
    let pendingImages = [];
    let eventPollTimer = null;
    let sidebarRefreshTimer = null;
    let sidebarUpdateGeneration = 0;
    let eventPollInFlight = false;
    let eventPollAbortController = null;
    let eventPollResumeTimer = null;
    let staleSessionRefreshInFlight = false;
    let hiddenAt = null;
    let lastEventPollSuccessAt = Date.now();
    let lastEventSeq = 0;
    let waitingForOutputSince = null;
    let waitingForOutputTimer = null;
    let emptyEventPollCount = 0;
    let autoScrollEnabled = true;
    let forceBottomAutoScroll = false;
    let programmaticScroll = false;
    let lastConversationScrollTop = 0;
    let conversationScrollDirection = null;
    let scheduledAutoScrollFrame = null;
    let sessionViewGeneration = 0;
    let sessionSwitchGeneration = 0;
    const staleSessionRefreshAfterMs = 60 * 1000;
    let conversationScrollRevealTimer = null;
    let conversationScrollRevealDelayTimer = null;
    let lastConversationScrollRevealAt = 0;
    let lastSidebarInteractionAt = 0;
    let cwdValidationTimer = null;
    let cwdValidationController = null;
    let notificationRegistration = null;
    const notifiedFinalReplyKeys = new Set();

    function bindSessionDom() {
      sessionSidebar = document.querySelector(".session-sidebar");
      conversationPanel = document.querySelector(".conversation-panel");
      liveOutput = document.getElementById("live-output");
      promptForm = document.querySelector(".prompt-form");
      abortForm = document.getElementById("abort-form");
      promptTextarea = promptForm?.querySelector("textarea") || null;
      promptSessionInput = promptForm?.querySelector('input[name="session"]') || null;
      sendButton = promptForm?.querySelector(".send-button") || null;
      composerStopButton = document.querySelector(".session-header .composer-stop-button") || null;
      attachButton = promptForm?.querySelector(".attach-button") || null;
      attachmentTray = promptForm?.querySelector(".attachment-tray") || null;
      imageInput = promptForm?.querySelector(".image-input") || null;
      composerState = document.querySelector(".composer-state");
      abortButton = document.querySelector(".abort-button");
      commandList = document.getElementById("command-list");
      commandFilter = commandList?.querySelector(".command-filter") || null;
      conversationScroll = document.getElementById("conversation-scroll");
      lastConversationScrollTop = conversationScroll?.scrollTop || 0;
      conversationScrollDirection = null;
      topJumpControls = document.querySelector(".jump-controls--top");
      bottomJumpControls = document.querySelector(".jump-controls--bottom");
      jumpToFirstButton = document.querySelector(".jump-to-first");
      jumpToLatestButton = document.querySelector(".jump-to-latest");
      sessionStatusBar = document.getElementById("session-status-bar");
      const existingModelStatus = sessionStatusBar?.querySelector('[data-status-key="model"] .session-status-value')?.textContent || "";
      const existingModelMatch = existingModelStatus.match(/^(.*?)(?:\s+\(([^)]*)\))?$/);
      liveStatusModel = existingModelMatch?.[1] || null;
      liveStatusThinking = existingModelMatch?.[2] || null;
      reconnectBanner = document.querySelector(".session-reconnect");
      reconnectButton = document.querySelector(".reconnect-button");
      bindSidebarScrollTracking();
      syncMessageTurnNavs();
    }

    function markSidebarInteraction() {
      lastSidebarInteractionAt = Date.now();
    }

    function bindSidebarScrollTracking() {
      const scrollContainer = sidebarScrollContainer();
      if (!scrollContainer) return;
      scrollContainer.onscroll = markSidebarInteraction;
      scrollContainer.onwheel = markSidebarInteraction;
      scrollContainer.ontouchstart = markSidebarInteraction;
      scrollContainer.onpointerdown = markSidebarInteraction;
    }

    function nearConversationTop() {
      if (!conversationScroll) return false;
      return conversationScroll.scrollTop < 120;
    }

    function nearConversationBottom() {
      if (!conversationScroll) return false;
      return conversationScroll.scrollHeight - conversationScroll.scrollTop - conversationScroll.clientHeight < 120;
    }

    function latestReadableAssistantMessageIsVisible() {
      const latestAssistant = latestReadableAssistantMessage();
      if (!conversationScroll || !latestAssistant) return false;
      const scrollRect = conversationScroll.getBoundingClientRect();
      const elementRect = latestAssistant.getBoundingClientRect();
      return elementRect.bottom > scrollRect.top && elementRect.top < scrollRect.bottom;
    }

    function hideConversationJumpControlsSoon() {
      if (conversationScrollRevealTimer) clearTimeout(conversationScrollRevealTimer);
      conversationScrollRevealTimer = setTimeout(() => {
        document.body.classList.remove("is-conversation-scrolling");
        conversationScrollRevealTimer = null;
      }, 1400);
    }

    function updateConversationJumpControlsReveal() {
      lastConversationScrollRevealAt = Date.now();
      if (document.body.classList.contains("is-conversation-scrolling")) {
        hideConversationJumpControlsSoon();
        return;
      }
      if (conversationScrollRevealDelayTimer) return;

      conversationScrollRevealDelayTimer = setTimeout(() => {
        conversationScrollRevealDelayTimer = null;
        if (Date.now() - lastConversationScrollRevealAt > 120) return;
        document.body.classList.add("is-conversation-scrolling");
        hideConversationJumpControlsSoon();
      }, 300);
    }

    function updateScrollJumpButtons() {
      const showFirst = conversationScrollDirection === "up" && !autoScrollEnabled && !nearConversationTop();
      const showLatest = conversationScrollDirection === "down" && !nearConversationBottom() && !latestReadableAssistantMessageIsVisible();
      jumpToFirstButton?.classList.toggle("is-visible", showFirst);
      jumpToLatestButton?.classList.toggle("is-visible", showLatest);
      topJumpControls?.classList.toggle("is-visible", showFirst);
      bottomJumpControls?.classList.toggle("is-visible", showLatest);
    }

    function userMessages() {
      return [...(conversationScroll?.querySelectorAll('[data-role="user"].message') || [])];
    }

    function makeMessageTurnButton(direction, label, text) {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "message-turn-button";
      button.dataset.direction = direction;
      button.setAttribute("aria-label", label);
      button.textContent = text;
      return button;
    }

    function syncMessageTurnNavs() {
      const messages = userMessages();
      messages.forEach((message, index) => {
        let nav = [...message.children].find((child) => child.classList?.contains("message-turn-nav"));
        if (!nav) {
          nav = document.createElement("nav");
          nav.className = "message-turn-nav";
          nav.setAttribute("aria-label", "User message navigation");
          message.prepend(nav);
        }

        nav.replaceChildren();
        if (index > 0) nav.append(makeMessageTurnButton("previous", "Previous user message", "↑"));
        if (index < messages.length - 1) nav.append(makeMessageTurnButton("next", "Next user message", "↓"));
      });
    }

    function latestReadableAssistantMessage() {
      const messages = conversationScroll?.querySelectorAll('[data-role="assistant"].message--assistant:not(.message--thinking):not(.message--compact)');
      return messages?.[messages.length - 1] || null;
    }

    function latestMessageElement() {
      const messages = conversationScroll?.querySelectorAll('.message');
      return messages?.[messages.length - 1] || null;
    }

    function scrollElementTopIntoView(element, behavior = "smooth", topOffset = 0) {
      if (!conversationScroll || !element) return;
      const scrollRect = conversationScroll.getBoundingClientRect();
      const elementRect = element.getBoundingClientRect();
      const top = conversationScroll.scrollTop + elementRect.top - scrollRect.top - topOffset;
      conversationScroll.scrollTo({ top, behavior });
    }

    function withProgrammaticScroll(callback) {
      programmaticScroll = true;
      callback();
      setTimeout(() => { programmaticScroll = false; }, 120);
    }

    function applyAutoScroll(behavior = "auto") {
      if (!conversationScroll || !autoScrollEnabled) return;

      withProgrammaticScroll(() => {
        const latestAssistant = latestReadableAssistantMessage();
        if (!forceBottomAutoScroll && latestAssistant && latestAssistant === latestMessageElement() && latestAssistant.offsetHeight > conversationScroll.clientHeight) {
          scrollElementTopIntoView(latestAssistant, behavior);
        } else {
          conversationScroll.scrollTo({ top: conversationScroll.scrollHeight, behavior });
        }
      });
      updateScrollJumpButtons();
    }

    function scheduleAutoScroll(behavior = "auto") {
      if (!conversationScroll || !autoScrollEnabled) return;
      if (scheduledAutoScrollFrame) cancelAnimationFrame(scheduledAutoScrollFrame);
      scheduledAutoScrollFrame = requestAnimationFrame(() => requestAnimationFrame(() => {
        scheduledAutoScrollFrame = null;
        applyAutoScroll(behavior);
      }));
    }

    function scrollToTop(behavior = "smooth") {
      if (!conversationScroll) return;
      autoScrollEnabled = false;
      forceBottomAutoScroll = false;
      withProgrammaticScroll(() => {
        conversationScroll.scrollTo({ top: 0, behavior });
      });
      updateScrollJumpButtons();
    }

    function topJumpControlsOffset() {
      const remSize = parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      return remSize * 3.5;
    }

    function scrollToUserMessage(message, behavior = "smooth") {
      if (!message) return;
      autoScrollEnabled = false;
      forceBottomAutoScroll = false;
      withProgrammaticScroll(() => scrollElementTopIntoView(message, behavior, topJumpControlsOffset()));
      updateScrollJumpButtons();
    }

    function scrollToBottom(behavior = "auto", { force = false } = {}) {
      if (!conversationScroll) return;
      autoScrollEnabled = true;
      forceBottomAutoScroll = force;
      withProgrammaticScroll(() => {
        conversationScroll.scrollTo({ top: conversationScroll.scrollHeight, behavior });
      });
      updateScrollJumpButtons();
    }

    function followLiveOutput(forceScroll = false) {
      const shouldScroll = forceScroll || autoScrollEnabled || nearConversationBottom();
      if (shouldScroll) autoScrollEnabled = true;
      return shouldScroll;
    }

    function afterLiveOutputChange(shouldScroll, live = true) {
      syncMessageTurnNavs();
      if (shouldScroll && autoScrollEnabled) scheduleAutoScroll();
      else if (live) updateScrollJumpButtons();
    }

    function shouldAutofocusPrompt() {
      return window.matchMedia?.("(pointer: fine)").matches !== false;
    }

    function updatePromptPlaceholder() {
      if (!promptTextarea) return;
      if (composerState?.dataset.state === "running") {
        promptTextarea.placeholder = "Send to queue…";
        return;
      }
      if (promptTextarea.disabled) {
        promptTextarea.placeholder = "Sending…";
        return;
      }
      promptTextarea.placeholder = window.matchMedia?.("(max-width: 760px)").matches ? "Ask Pi…" : "Ask Pi… Enter to send, Shift+Enter for newline.";
    }

    function setStatusItem(key, label, value) {
      if (!sessionStatusBar || value === null || value === undefined || value === "") return;

      let item = sessionStatusBar.querySelector(`[data-status-key="${key}"]`);
      if (!item) {
        item = document.createElement("span");
        item.className = "session-status-item";
        item.dataset.statusKey = key;
        const labelElement = document.createElement("span");
        labelElement.className = "session-status-label";
        labelElement.textContent = label;
        const valueElement = document.createElement("span");
        valueElement.className = "session-status-value";
        item.append(labelElement, " ", valueElement);
        sessionStatusBar.append(item);
      }

      item.querySelector(".session-status-value").textContent = value;
    }

    function removeStatusItem(key) {
      sessionStatusBar?.querySelector(`[data-status-key="${key}"]`)?.remove();
    }

    function renderModelStatus() {
      if (!liveStatusModel) {
        removeStatusItem("thinking");
        return;
      }

      setStatusItem("model", "Model", [liveStatusModel, liveStatusThinking ? `(${liveStatusThinking})` : null].filter(Boolean).join(" "));
      removeStatusItem("thinking");
    }

    function compactNumber(value) {
      const number = Number(value);
      if (!Number.isFinite(number) || number <= 0) return String(value || "");
      if (number < 1000) return String(Math.round(number));
      if (number < 1000000) return `${(number / 1000).toFixed(1).replace(/\.0$/, "")}k`;
      return `${(number / 1000000).toFixed(1).replace(/\.0$/, "")}M`;
    }

    function updateStatusFromMessage(message) {
      const usage = message?.usage;
      if (!usage) return;

      const tokens = usage.totalTokens || usage.total_tokens || usage.tokens;
      if (tokens) setStatusItem("ctx", "CTX", compactNumber(tokens));
      if (message.provider || message.model) {
        liveStatusModel = [message.provider, message.model].filter(Boolean).join("/");
        renderModelStatus();
      }
    }

    function notificationAvailable() {
      return "Notification" in window && "serviceWorker" in navigator;
    }

    async function ensureNotificationWorker() {
      if (!notificationAvailable() || Notification.permission !== "granted") return null;
      notificationRegistration ||= await navigator.serviceWorker.register("/service-worker.js");
      await navigator.serviceWorker.ready;
      return notificationRegistration;
    }

    async function showPiNotification(title, body, url, tag) {
      const worker = await ensureNotificationWorker();
      if (!worker) return;
      if (worker.active) {
        worker.active.postMessage({ type: "pi-notification", title, body, url, tag });
      } else {
        await worker.showNotification(title, { body, tag, renotify: true, icon: "/app-icon.svg", badge: "/app-icon.svg", data: { url } });
      }
    }

    function sessionUrl(sessionPath) {
      const url = new URL("/", window.location.origin);
      const currentProject = new URLSearchParams(window.location.search).get("project");
      url.searchParams.set("session", sessionPath);
      if (currentProject) url.searchParams.set("project", currentProject);
      return `${url.pathname}${url.search}`;
    }

    function sessionIsActivelyViewed(sessionPath) {
      return sessionPath && sessionPath === currentSessionPath() && !document.hidden && document.hasFocus();
    }

    function finalAssistantReplyKey(sessionPath, event) {
      const message = eventMessage(event);
      const text = messageText(message);
      return [sessionPath, message?.id || message?.messageId || event.id || event.messageId || lastEventSeq, stableTextHash(text)].join(":");
    }

    function finalAssistantReplySegments(message) {
      const segments = message?.content ? contentSegments(message.content, message) : [{ text: messageText(message), compact: false }];
      return segments.filter((segment) => segment.text && !segment.compact && !segment.thinking);
    }

    function finalAssistantReplyText(message) {
      return finalAssistantReplySegments(message).map((segment) => segment.text).join("\n");
    }

    function eventHasFinalAssistantText(event) {
      return finalAssistantReplySegments(eventMessage(event)).length > 0;
    }

    function notificationReplyPreview(text) {
      const preview = String(text || "").replace(/\s+/g, " ").trim();
      if (!preview) return "New reply.";
      return preview.length > 180 ? `${preview.slice(0, 177)}…` : preview;
    }

    function notifyFinalAssistantReply(event) {
      const message = eventMessage(event);
      const roleName = liveEventRole(event, message);
      if (roleName !== "assistant" || event.type !== "message_end") return;
      if (!eventHasFinalAssistantText(event)) return;

      const sessionPath = currentSessionPath();
      if (!sessionPath) return;
      if (sessionIsActivelyViewed(sessionPath)) return;

      const key = finalAssistantReplyKey(sessionPath, event);
      if (notifiedFinalReplyKeys.has(key)) return;
      notifiedFinalReplyKeys.add(key);
      const name = document.querySelector(".session-header-name")?.textContent.trim() || "current session";
      const body = notificationReplyPreview(finalAssistantReplyText(message));
      showPiNotification(name, body, window.location.href, `pi-final-reply:${sessionPath}`).catch(() => {});
    }

    function updateStatusFromEvent(event) {
      if (event.type === "model_change" || event.type === "model_select") {
        const provider = event.provider || event.model?.provider;
        const model = event.modelId || event.model?.id || event.model;
        if (provider || model) {
          liveStatusModel = [provider, model].filter(Boolean).join("/");
          renderModelStatus();
        }
      }
      if (event.type === "thinking_level_change" || event.type === "thinking_level_select") {
        liveStatusThinking = event.thinkingLevel || event.level;
        renderModelStatus();
      }
      updateStatusFromMessage(event.message);
    }

    async function refreshSessionStatus(generation = sessionViewGeneration) {
      const statusBar = sessionStatusBar;
      const statusUrl = statusBar?.dataset.statusUrl;
      if (!statusBar || !statusUrl) return;

      const response = await fetch(statusUrl);
      if (!response.ok || generation !== sessionViewGeneration || statusBar !== sessionStatusBar) return;
      const status = await response.json();
      if (generation !== sessionViewGeneration || statusBar !== sessionStatusBar) return;
      setStatusItem("ctx", "CTX", status.context);
      liveStatusModel = status.model;
      liveStatusThinking = status.thinking;
      renderModelStatus();
    }

    function formatWaitDuration(milliseconds) {
      const seconds = Math.max(0, Math.floor(milliseconds / 1000));
      if (seconds < 60) return `${seconds}s`;
      const minutes = Math.floor(seconds / 60);
      return `${minutes}m ${String(seconds % 60).padStart(2, "0")}s`;
    }

    function updateWaitingForOutputStatus() {
      if (!composerState || composerState.dataset.state !== "running" || !waitingForOutputSince) return;

      const elapsed = Date.now() - waitingForOutputSince;
      composerState.textContent = `Pi is running… ${formatWaitDuration(elapsed)}`;
    }

    function startWaitingForOutput(since = Date.now()) {
      waitingForOutputSince = since || Date.now();
      clearInterval(waitingForOutputTimer);
      updateWaitingForOutputStatus();
      waitingForOutputTimer = setInterval(updateWaitingForOutputStatus, 1000);
    }

    function stopWaitingForOutput() {
      waitingForOutputSince = null;
      clearInterval(waitingForOutputTimer);
      waitingForOutputTimer = null;
    }

    function setComposerState(state, label, since = null) {
      if (state === "running" && (since || !waitingForOutputSince)) startWaitingForOutput(since || Date.now());
      if (!["running", "sending"].includes(state)) stopWaitingForOutput();
      if (composerState) {
        composerState.dataset.state = state;
        composerState.textContent = ["running", "sending", "error"].includes(state) ? label : "";
        if (state === "running") updateWaitingForOutputStatus();
      }
      const agentBusy = ["running", "sending"].includes(state);
      const submitting = state === "sending";
      if (abortButton) abortButton.disabled = !agentBusy;
      if (sendButton) {
        sendButton.hidden = submitting;
        sendButton.textContent = state === "running" ? "Queue" : state === "sending" ? "Sending…" : "Send";
        sendButton.setAttribute("aria-label", state === "running" ? "Send to queue" : "Send message");
      }
      if (composerStopButton) {
        composerStopButton.hidden = !agentBusy;
        composerStopButton.disabled = !agentBusy;
        composerStopButton.classList.toggle("is-visible", agentBusy);
      }
      if (promptTextarea) promptTextarea.disabled = submitting;
      const attachmentsDisabled = agentBusy;
      if (imageInput) imageInput.disabled = attachmentsDisabled;
      if (attachButton) {
        attachButton.classList.toggle("is-disabled", attachmentsDisabled);
        attachButton.setAttribute("aria-disabled", attachmentsDisabled ? "true" : "false");
      }
      updatePromptPlaceholder();
    }

    function resizePromptTextarea() {
      if (!promptTextarea) return;

      promptTextarea.style.height = "auto";
      const maxHeight = parseFloat(getComputedStyle(promptTextarea).maxHeight);
      const hasMaxHeight = Number.isFinite(maxHeight) && maxHeight > 0;
      const nextHeight = hasMaxHeight ? Math.min(promptTextarea.scrollHeight, maxHeight) : promptTextarea.scrollHeight;

      promptTextarea.style.height = `${nextHeight}px`;
      promptTextarea.style.overflowY = hasMaxHeight && promptTextarea.scrollHeight > maxHeight ? "auto" : "hidden";
    }

    function imageAttachmentLabel(count) {
      return `${count} image${count === 1 ? "" : "s"} attached`;
    }

    function sessionNameSlashCommand(message) {
      const trimmed = message.trim();
      if (/^\/(?:name|rename)$/.test(trimmed)) return { valid: false };
      if (/^\/(?:name|rename)[ \t]+[^\r\n]+$/.test(trimmed)) return { valid: true };
      return null;
    }

    function updateSessionHeaderName(name) {
      if (!name) return;
      const headerName = document.querySelector(".session-header-name");
      if (!headerName) return;
      headerName.textContent = name;
      headerName.title = name;
      const title = headerName.closest(".session-header-title");
      const project = title?.querySelector(".session-header-project")?.textContent.trim();
      if (title) title.title = project ? `${name} · ${project}` : name;
      document.title = `${name} · Pi Web Gateway`;
    }

    function sessionTitleFromEvent(event) {
      if (event.type === "session_info") return event.name;
      if (event.type === "custom" && event.customType === "pi-extensions-session-title") return event.data?.title;
      if (event.type === "custom_message" && event.customType === "session-title-update") {
        return String(event.content || "").match(/^Session renamed to: `(.+)`$/)?.[1];
      }
      return null;
    }

    function renderAttachments() {
      if (!attachmentTray) return;
      attachmentTray.replaceChildren();
      attachmentTray.classList.toggle("has-attachments", pendingImages.length > 0);

      pendingImages.forEach((entry, index) => {
        const wrapper = document.createElement("span");
        wrapper.className = "attachment";

        const image = document.createElement("img");
        image.src = entry.url;
        image.alt = "Attached image preview";

        const label = document.createElement("span");
        label.textContent = entry.file.name || `Image ${index + 1}`;

        const remove = document.createElement("button");
        remove.type = "button";
        remove.textContent = "Remove";
        remove.addEventListener("click", () => {
          URL.revokeObjectURL(entry.url);
          pendingImages.splice(index, 1);
          renderAttachments();
        });

        wrapper.append(image, label, remove);
        attachmentTray.append(wrapper);
      });
    }

    function addImageFiles(files) {
      if (promptTextarea?.disabled || composerState?.dataset.state === "running") return false;

      const imageFiles = [...files].filter((file) => file.type.startsWith("image/"));
      if (imageFiles.length === 0) return false;

      imageFiles.forEach((file) => {
        pendingImages.push({ file, url: URL.createObjectURL(file) });
      });
      renderAttachments();
      return true;
    }

    function clearAttachments() {
      pendingImages.forEach((entry) => URL.revokeObjectURL(entry.url));
      pendingImages = [];
      renderAttachments();
    }

    function compactContentPart(part) {
      return part && typeof part === "object" && ["toolCall", "toolResult"].includes(part.type);
    }

    function thinkingPart(part) {
      return part && typeof part === "object" && part.type === "thinking";
    }

    function stripThinkingHeading(text) {
      return String(text || "").replace(/^\s*\*\*[^\n*][^\n]*\*\*\s*\n{2,}/, "");
    }

    function bashCommandLine(part) {
      const args = part?.arguments || {};
      const timeout = args.timeout ? ` (timeout ${args.timeout}s)` : "";
      return `$ ${args.command || ""}${timeout}`;
    }

    function contentPartText(part) {
      if (!part) return "";
      if (typeof part === "string") return part;
      if (part.text) return part.text;
      if (part.type === "thinking" || part.thinking) return stripThinkingHeading(part.thinking);
      if (part.type === "toolCall") {
        if (part.name === "bash") return bashCommandLine(part);
        if (["read", "edit", "write"].includes(part.name)) return transcriptToolCallText(part.name, part.arguments || {});
        const args = part.arguments ? `\n${JSON.stringify(part.arguments, null, 2)}` : "";
        return `[tool: ${part.name || "tool"}]${args}`;
      }
      if (part.type === "toolResult") return part.output || part.result || "[tool result]";
      return "";
    }

    function toolSummaryPlain(name, args = {}) {
      const path = args.path ? ` ${args.path}` : "";
      const range = name === "read" && args.offset && args.limit ? `:${args.offset}-${Number(args.offset) + Number(args.limit) - 1}` : "";
      return `${name}${path}${range}`;
    }

    function formatToolCallPlain(name, args = {}) {
      if (name === "bash") return `$ ${args.command || ""}${args.timeout ? ` (timeout ${args.timeout}s)` : ""}`;
      if (["read", "edit", "write"].includes(name)) return toolSummaryPlain(name, args);
      if (name === "grep") return `grep /${args.pattern || ""}/ in ${args.path || "."}`;
      return name || "tool";
    }

    function transcriptToolCallText(name, args = {}) {
      const summary = toolSummaryPlain(name, args);
      if (name !== "edit") return summary;

      const edits = Array.isArray(args.edits) ? args.edits : [];
      const editPreview = edits.map((edit, index) => {
        if (!edit || typeof edit !== "object") return "";
        return [
          `Edit ${index + 1}`,
          previewText("-", edit.oldText),
          previewText("+", edit.newText)
        ].filter(Boolean).join("\n");
      }).filter(Boolean).join("\n\n");

      return [summary, editPreview].filter(Boolean).join("\n");
    }

    function previewText(prefix, text) {
      const lines = String(text || "").split("\n");
      if (lines[lines.length - 1] === "") lines.pop();
      if (lines.length === 0) return "";
      const preview = lines.slice(0, 6).map((line) => `${prefix} ${line}`);
      if (lines.length > 6) preview.push(`${prefix} …`);
      return preview.join("\n");
    }

    function toolSummaryParts(name, args = {}) {
      if (!["read", "edit", "write"].includes(name)) return null;
      return {
        name,
        path: args.path || "",
        range: name === "read" && args.offset && args.limit ? `${args.offset}-${Number(args.offset) + Number(args.limit) - 1}` : ""
      };
    }

    function contentPartLabel(part) {
      if (!part || typeof part !== "object") return null;
      if (part.type === "thinking" || part.thinking) return part.thinking ? "thinking" : null;
      if (part.type === "toolCall" && part.name === "bash") return bashCommandLine(part);
      if (part.type === "toolCall" || part.type === "toolResult") return part.name || part.toolName || "tool";
      return null;
    }

    function contentSegments(content, message = {}) {
      const parts = Array.isArray(content) ? content : [content];
      const groups = [];
      parts.forEach((part, index) => {
        const compact = message.role === "toolResult" || compactContentPart(part);
        const bashCall = part && typeof part === "object" && part.type === "toolCall" && part.name === "bash";
        const lastGroup = groups[groups.length - 1];
        if (thinkingPart(part) && message.role !== "toolResult") {
          groups.push({ compact: false, parts: [part], startIndex: index, endIndex: index });
        } else if (!bashCall && !compact && lastGroup && lastGroup.compact === false && !thinkingPart(lastGroup.parts[0])) {
          lastGroup.parts.push(part);
          lastGroup.endIndex = index;
        } else {
          groups.push({ compact, parts: [part], startIndex: index, endIndex: index });
        }
      });

      return groups.map((group) => {
        const text = message.toolName === "edit" && message.details?.diff ? message.details.diff : group.parts.map(contentPartText).filter(Boolean).join("\n");
        const labels = group.parts.map(contentPartLabel).filter(Boolean);
        const toolPart = group.parts.find((part) => part && typeof part === "object" && ["toolCall", "toolResult"].includes(part.type));
        const toolName = message.toolName || toolPart?.name || toolPart?.toolName;
        const summaryParts = toolSummaryParts(toolName, toolPart?.arguments || {});
        const rawDetails = group.parts
          .filter((part) => part && typeof part === "object" && ["toolCall", "toolResult"].includes(part.type))
          .map((part) => JSON.stringify(part, null, 2))
          .join("\n\n") || (message.role === "toolResult" ? JSON.stringify(message, null, 2) : "");
        return {
          text,
          compact: group.compact,
          thinking: group.parts.length === 1 && thinkingPart(group.parts[0]) && message.role !== "toolResult",
          summary: message.toolName || [...new Set(labels)].join(" + ") || "tool output",
          summaryParts,
          expanded: false,
          error: message.isError === true,
          startIndex: group.startIndex,
          endIndex: group.endIndex,
          toolCallId: message.toolCallId || toolPart?.id || toolPart?.toolCallId,
          toolName,
          isToolResult: message.role === "toolResult" || toolPart?.type === "toolResult",
          toolTranscript: ["read", "edit", "write"].includes(toolName),
          rawDetails
        };
      }).filter((segment) => segment.text);
    }

    function eventMessage(event) {
      return event.message || event.delta || event.item || event;
    }

    function messageText(message) {
      if (!message) return "";
      if (typeof message === "string") return message;
      if (message.text) return message.text;
      if (message.content) return contentSegments(message.content, message).map((segment) => segment.text).join("\n");
      return "";
    }

    function messageRoleKey(roleName) {
      if (["assistant", "user", "error"].includes(roleName)) return roleName;
      if (["tool", "toolResult"].includes(roleName)) return "tool";
      return "status";
    }

    function messageRoleLabel(roleName) {
      if (roleName === "assistant") return "pi";
      if (roleName === "toolResult") return "tool result";
      if (["custom", "session_info"].includes(roleName)) return "status";
      return roleName || "status";
    }

    function liveEventRole(event, message) {
      if (["custom", "custom_message", "session_info", "queue_update", "compaction_start", "compaction_end"].includes(event.type)) {
        return "status";
      }

      const role = message?.role;
      if (["assistant", "user", "tool", "toolResult", "error"].includes(role)) return role;
      if (["custom", "system", "status"].includes(role)) return "status";
      if (["message_start", "message_update", "message_end"].includes(event.type)) return "assistant";
      return "status";
    }

    function eventStatusText(event) {
      if (event.type === "session_info" && event.name) return `Session renamed to “${event.name}”`;
      if (event.type === "custom_message" && event.content) return event.content;
      if (event.type === "custom" && event.customType) return `${event.customType} updated`;
      if (event.type === "queue_update") return "Queued follow-up work updated";
      if (event.type === "compaction_start") return "Compaction started";
      if (event.type === "compaction_end") return event.aborted ? "Compaction aborted" : "Compaction finished";
      return event.message || event.text || event.type || "Status update";
    }

    function renderAssistantMarkdown(body, text, delay = 120) {
      body.dataset.plainText = text;
      body.dataset.rendering = "pending";
      clearTimeout(body.markdownRenderTimeout);
      body.markdownRenderTimeout = setTimeout(async () => {
        try {
          const formData = new FormData();
          formData.set("text", text);
          const response = await fetch("/markdown", { method: "POST", body: formData });
          if (!response.ok || body.dataset.plainText !== text) return;

          const payload = await response.json();
          if (body.dataset.plainText === text) {
            body.innerHTML = payload.html;
            delete body.dataset.rendering;
            if (autoScrollEnabled && body.closest(".message") === latestReadableAssistantMessage()) scheduleAutoScroll();
          }
        } catch (_error) {
        }
      }, delay);
    }

    function normalizedMessageText(text) {
      return String(text || "").replace(/\r\n?/g, "\n").trim();
    }

    function stableTextHash(text) {
      const bytes = new TextEncoder().encode(text);
      let hash = 5381;
      bytes.forEach((byte) => { hash = (((hash << 5) + hash) + byte) >>> 0; });
      return hash.toString(16);
    }

    function messageTimestampKey(timestamp) {
      if (!timestamp) return "";
      const date = new Date(timestamp);
      if (Number.isNaN(date.getTime())) return "";
      return String(Math.floor(date.getTime() / 1000));
    }

    function messageFingerprint(roleName, text, timestampKey) {
      if (!timestampKey) return "";
      return `${messageRoleKey(roleName)}:${timestampKey}:${stableTextHash(normalizedMessageText(text))}`;
    }

    function liveMessageAlreadyRendered(roleName, text, timestampKey) {
      const fingerprint = messageFingerprint(roleName, text, timestampKey);
      if (!fingerprint) return false;
      return [...(conversationScroll?.querySelectorAll(".message:not(.message--live)[data-message-fingerprint]") || [])].some((message) => message.dataset.messageFingerprint === fingerprint);
    }

    function optimisticUserMessage(text) {
      return [...(conversationScroll?.querySelectorAll('.message--live[data-role="user"][data-optimistic="true"]') || [])]
        .find((message) => normalizedMessageText(message.dataset.optimisticText || message.querySelector(".message-body")?.textContent) === normalizedMessageText(text));
    }

    function optimisticUserMessageAlreadyRendered(text) {
      return !!optimisticUserMessage(text);
    }

    function formatTimestamp(timestamp) {
      const date = timestamp ? new Date(timestamp) : new Date();
      if (Number.isNaN(date.getTime())) return "";
      const pad = (value) => String(value).padStart(2, "0");
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}`;
    }

    function eventTimestamp(event) {
      return event?.timestamp || event?.message?.timestamp || event?.delta?.timestamp || event?.item?.timestamp;
    }

    function appendMessage(roleName, text, live = true, forceScroll = false, timestamp = null, options = {}) {
      const timestampKey = messageTimestampKey(timestamp);
      if (live && roleName === "user" && !options.optimistic && optimisticUserMessageAlreadyRendered(text)) return null;
      if (live && liveMessageAlreadyRendered(roleName, text, timestampKey)) return null;

      const shouldScroll = followLiveOutput(forceScroll);
      const roleKey = messageRoleKey(roleName);

      const article = document.createElement("article");
      article.className = `message message--${roleKey}${options.thinking ? " message--thinking" : ""}${live ? " message--live" : ""}`;
      article.dataset.role = roleName;
      article.dataset.messageTimestamp = timestampKey;
      article.dataset.messageFingerprint = messageFingerprint(roleName, text, timestampKey);
      if (options.optimistic) {
        article.dataset.optimistic = "true";
        article.dataset.optimisticText = options.optimisticText ?? text;
      }

      const header = document.createElement("header");
      header.className = "message-header";

      const role = document.createElement("div");
      role.className = "role";
      role.textContent = messageRoleLabel(roleName);

      const body = document.createElement(roleName === "assistant" ? "div" : "pre");
      body.className = options.thinking ? "message-body message-body--thinking" : (roleName === "assistant" ? "message-body message-body--markdown" : "message-body");
      if (options.thinking) {
        const prefix = document.createElement("span");
        prefix.className = "thinking-prefix";
        prefix.textContent = "Thinking:";
        body.append(prefix, " ", document.createTextNode(text));
      } else if (roleName === "assistant") {
        renderAssistantMarkdown(body, text);
      } else {
        body.textContent = text;
      }

      const meta = document.createElement("div");
      meta.className = "message-meta";
      meta.textContent = formatTimestamp(timestamp);

      header.append(role);
      if (meta.textContent) header.append(meta);
      if (roleName === "assistant" && !options.thinking) header.append(makeCopyButton());
      article.append(header);
      article.append(body);
      liveOutput.append(article);
      afterLiveOutputChange(shouldScroll, live);
      return { article, body, compact: false };
    }

    function appendCompactMessage(roleName, summary, text, expanded = false, live = true, forceScroll = false, rawDetails = "", timestamp = null, options = {}) {
      const timestampKey = messageTimestampKey(timestamp);
      if (live && liveMessageAlreadyRendered(roleName, text, timestampKey)) return null;

      const shouldScroll = followLiveOutput(forceScroll);
      const roleKey = messageRoleKey(roleName);

      const article = document.createElement("article");
      article.className = `message message--${roleKey} message--compact${options.toolTranscript ? " message--tool-transcript" : ""}${options.error === true ? " message--tool-error" : ""}${live ? " message--live" : ""}`;
      article.dataset.role = roleName;
      article.dataset.messageTimestamp = timestampKey;
      article.dataset.messageFingerprint = messageFingerprint(roleName, text, timestampKey);

      const header = document.createElement("header");
      header.className = "message-header";
      const role = document.createElement("div");
      role.className = "role";
      role.textContent = messageRoleLabel(roleName);
      const meta = document.createElement("div");
      meta.className = "message-meta";
      meta.textContent = formatTimestamp(timestamp);
      header.append(role);
      if (meta.textContent) header.append(meta);

      const details = document.createElement("details");
      details.className = "message-details";
      details.open = options.open === true;
      const summaryElement = document.createElement("summary");
      const summaryText = document.createElement("span");
      summaryText.className = "compact-summary";
      renderToolSummary(summaryText, options.summaryParts, summary);
      summaryElement.append(summaryText);
      const body = document.createElement("pre");
      body.className = "message-body";
      body.textContent = text;
      const collapseButton = document.createElement("button");
      collapseButton.type = "button";
      collapseButton.className = "details-collapse-button";
      collapseButton.dataset.collapseDetails = "";
      collapseButton.textContent = "▴ Collapse details";
      details.append(summaryElement, body);

      let rawBody = null;
      if (rawDetails) {
        const rawDetailsElement = document.createElement("details");
        rawDetailsElement.className = "raw-details";
        const rawSummary = document.createElement("summary");
        rawSummary.textContent = "Raw details";
        rawBody = document.createElement("pre");
        rawBody.textContent = rawDetails;
        rawDetailsElement.append(rawSummary, rawBody);
        details.append(rawDetailsElement);
      }
      details.append(collapseButton);

      article.append(header, details);
      liveOutput.append(article);
      afterLiveOutputChange(shouldScroll, live);
      return { article, details, body, summaryText, rawBody, compact: true };
    }

    function renderToolSummary(container, parts, fallback) {
      container.replaceChildren();
      if (!parts) {
        container.textContent = fallback;
        return;
      }

      const command = document.createElement("span");
      command.className = "tool-command";
      command.textContent = parts.name;
      container.append(command);
      if (parts.path) {
        container.append(" ");
        const path = document.createElement("span");
        path.className = "tool-path";
        path.textContent = parts.path;
        container.append(path);
      }
      if (parts.range) {
        const range = document.createElement("span");
        range.className = "tool-range";
        range.textContent = `:${parts.range}`;
        container.append(range);
      }
    }

    function makeCopyButton() {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "copy-button";
      button.dataset.copyTarget = "message";
      button.textContent = "Copy";
      return button;
    }

    function showStatus(_text, _forceScroll = false) {}

    function resetLiveAssistantTracking() {
      liveAssistantMessage = null;
      liveAssistantSegments = new Map();
      liveBashToolCalls = new Map();
      liveToolExecutions = new Map();
      liveUserMessages = new Map();
      liveAssistantSeen = false;
    }

    function segmentIdentity(event, segment, fallbackIndex) {
      const update = event.assistantMessageEvent || {};
      if (segment.toolCallId) return `${segment.toolCallId}-${segment.compact ? "compact" : "text"}`;
      const contentIndex = segment.startIndex ?? update.contentIndex ?? fallbackIndex;
      return `${contentIndex}-${segment.compact ? "compact" : "text"}`;
    }

    function forgetLiveEntry(entry) {
      liveAssistantSegments.forEach((storedEntry, key) => {
        if (storedEntry === entry) liveAssistantSegments.delete(key);
      });
      liveBashToolCalls.forEach((storedEntry, key) => {
        if (storedEntry === entry) liveBashToolCalls.delete(key);
      });
      liveToolExecutions.forEach((storedEntry, key) => {
        if (storedEntry === entry) liveToolExecutions.delete(key);
      });
      liveUserMessages.forEach((storedEntry, key) => {
        if (storedEntry === entry) liveUserMessages.delete(key);
      });
    }

    function markLiveEntryRendered(entry, roleName, text, timestamp = null) {
      const timestampKey = messageTimestampKey(timestamp) || entry.article.dataset.messageTimestamp;
      if (liveMessageAlreadyRendered(roleName, text, timestampKey)) {
        entry.article.remove();
        forgetLiveEntry(entry);
        return false;
      }
      entry.article.dataset.messageTimestamp = timestampKey;
      entry.article.dataset.messageFingerprint = messageFingerprint(roleName, text, timestampKey);
      return true;
    }

    function updateLiveSegment(entry, roleName, segment, shouldScroll, timestamp = null) {
      if (entry.compact !== segment.compact) return null;
      const displayText = roleName === "user" && entry.userDisplayText ? entry.userDisplayText : segment.text;

      if (segment.compact) {
        renderToolSummary(entry.summaryText, segment.summaryParts, segment.summary);
        entry.body.textContent = segment.text;
        if (entry.rawBody) entry.rawBody.textContent = segment.rawDetails || "";
      } else {
        if (segment.thinking) {
          const prefix = entry.body.querySelector(".thinking-prefix");
          entry.body.textContent = "";
          if (prefix) entry.body.append(prefix, " ");
          entry.body.append(document.createTextNode(segment.text));
        } else if (roleName === "assistant") {
          renderAssistantMarkdown(entry.body, segment.text);
        } else {
          entry.body.textContent = displayText;
        }
      }

      if (!markLiveEntryRendered(entry, roleName, segment.text, timestamp)) return null;
      afterLiveOutputChange(shouldScroll);
      return entry;
    }

    function liveUserIdentity(event, segment, fallbackIndex, timestamp) {
      const message = eventMessage(event);
      const id = message?.id || message?.messageId || event.id || event.messageId;
      const index = segment.startIndex ?? fallbackIndex;
      if (id) return `${id}-${index}`;

      const timestampKey = messageTimestampKey(timestamp);
      const textHash = stableTextHash(normalizedMessageText(segment.text));
      return `${timestampKey || "untimed"}-${textHash}-${index}`;
    }

    function optimisticUserEntry(segment, timestamp) {
      const article = optimisticUserMessage(segment.text);
      if (!article) return null;

      delete article.dataset.optimistic;
      delete article.dataset.optimisticText;
      article.dataset.messageTimestamp = messageTimestampKey(timestamp);
      article.dataset.messageFingerprint = messageFingerprint("user", segment.text, article.dataset.messageTimestamp);
      const meta = article.querySelector(".message-meta");
      if (meta) meta.textContent = formatTimestamp(timestamp);
      const body = article.querySelector(".message-body");
      return { article, body, compact: false, userDisplayText: body?.textContent || segment.text };
    }

    function upsertLiveUserSegment(event, segment, fallbackIndex, shouldScroll, timestamp) {
      const key = liveUserIdentity(event, segment, fallbackIndex, timestamp);
      const existing = liveUserMessages.get(key);
      if (existing) return updateLiveSegment(existing, "user", segment, shouldScroll, timestamp);

      const entry = optimisticUserEntry(segment, timestamp) || appendMessage("user", segment.text, true, shouldScroll, timestamp);
      if (!entry) return null;
      liveUserMessages.set(key, entry);
      return entry;
    }

    function upsertLiveAssistantSegment(event, roleName, segment, fallbackIndex, shouldScroll, timestamp) {
      const key = segmentIdentity(event, segment, fallbackIndex);
      const existing = liveAssistantSegments.get(key);
      if (existing) {
        const updated = updateLiveSegment(existing, roleName, segment, shouldScroll, timestamp);
        if (updated) return updated;
        forgetLiveEntry(existing);
        if (liveMessageAlreadyRendered(roleName, segment.text, messageTimestampKey(timestamp))) return null;
      }
      if (liveMessageAlreadyRendered(roleName, segment.text, messageTimestampKey(timestamp))) return null;

      const entry = segment.compact ?
        appendCompactMessage(roleName, segment.summary, segment.text, segment.expanded, true, shouldScroll, segment.rawDetails, timestamp, { summaryParts: segment.summaryParts, toolTranscript: segment.toolTranscript, open: segment.expanded, error: segment.error }) :
        appendMessage("assistant", segment.text, true, shouldScroll, timestamp, { thinking: segment.thinking });
      if (!entry) return null;
      liveAssistantSegments.set(key, entry);
      if (["bash", "read", "edit", "write"].includes(segment.toolName) && segment.toolCallId && !segment.isToolResult) liveBashToolCalls.set(segment.toolCallId, entry);
      if (segment.toolCallId && !segment.isToolResult && !["bash", "read", "edit", "write"].includes(segment.toolName)) liveToolExecutions.set(segment.toolCallId, entry);
      return entry;
    }

    function toolExecutionResult(event) {
      return event.type === "tool_execution_update" ? event.partialResult : event.result;
    }

    function subagentDetailsFromEvent(event) {
      return toolExecutionResult(event)?.details;
    }

    function subagentRunning(event) {
      return event.type !== "tool_execution_end";
    }

    function subagentResultFailed(result) {
      return result.exitCode !== 0 || result.stopReason === "error" || result.stopReason === "aborted";
    }

    function subagentResultRunning(details, result, index, running) {
      if (result.exitCode === -1) return true;
      if (!running) return false;
      if (result.exitCode !== 0) return false;
      if (result.stopReason === "stop") return false;
      if (details.mode === "parallel") return true;
      return index === details.results.length - 1;
    }

    function subagentResultIcon(result, resultRunning = false) {
      if (resultRunning || result.exitCode === -1) return "⏳";
      return subagentResultFailed(result) ? "✗" : "✓";
    }

    function subagentFinalOutput(messages = []) {
      for (let index = messages.length - 1; index >= 0; index -= 1) {
        const message = messages[index];
        if (message?.role !== "assistant") continue;
        const textPart = (message.content || []).find((part) => part?.type === "text" && part.text);
        if (textPart) return textPart.text;
      }
      return "";
    }

    function subagentDisplayItems(messages = []) {
      const items = [];
      messages.forEach((message) => {
        if (message?.role !== "assistant") return;
        (message.content || []).forEach((part) => {
          if (part.type === "text" && part.text) items.push(part.text.split("\n").slice(0, 3).join("\n"));
          if (part.type === "toolCall") return items.push(`→ ${formatToolCallPlain(part.name, part.arguments || {})}`);
        });
      });
      return items;
    }

    function subagentUsageText(usage = {}, model = "") {
      const parts = [];
      if (usage.turns) parts.push(`${usage.turns} turns`);
      if (usage.input) parts.push(`↑${compactUsageNumber(usage.input)}`);
      if (usage.output) parts.push(`↓${compactUsageNumber(usage.output)}`);
      if (usage.cacheRead) parts.push(`R${compactUsageNumber(usage.cacheRead)}`);
      if (usage.cacheWrite) parts.push(`W${compactUsageNumber(usage.cacheWrite)}`);
      if (usage.cost) parts.push(`$${Number(usage.cost).toFixed(3)}`);
      if (usage.contextTokens) parts.push(`ctx:${compactUsageNumber(usage.contextTokens)}`);
      if (model) parts.push(model);
      return parts.join(" ");
    }

    function compactUsageNumber(value) {
      const number = Number(value || 0);
      if (number < 1000) return String(Math.round(number));
      if (number < 1000000) return `${(number / 1000).toFixed(number < 10000 ? 1 : 0)}k`;
      return `${(number / 1000000).toFixed(1)}M`;
    }

    function subagentSummary(details, running = false) {
      if (!details?.results?.length) return "subagent";
      if (details.mode === "single" && details.results.length === 1) return `subagent ${details.results[0].agent}`;
      const done = details.results.filter((result, index) => result.exitCode !== -1 && !subagentResultRunning(details, result, index, running)).length;
      const total = details.results.length;
      return `subagent ${details.mode} ${done}/${total}`;
    }

    function subagentDisplayText(details, fallback, running = false) {
      if (!details?.results?.length) return fallback;
      const lines = [];
      details.results.forEach((result, index) => {
        if (index > 0) lines.push("");
        const resultRunning = subagentResultRunning(details, result, index, running);
        lines.push(`${subagentResultIcon(result, resultRunning)} ${result.agent} (${result.agentSource || "unknown"})`);
        const items = subagentDisplayItems(result.messages).slice(-10);
        if (items.length > 0) {
          lines.push(...items);
        } else {
          lines.push(subagentFinalOutput(result.messages) || result.errorMessage || result.stderr || "(running…)");
        }
        const usage = subagentUsageText(result.usage, result.model);
        if (usage) lines.push(usage);
      });
      return lines.join("\n");
    }

    function toolExecutionContentText(event) {
      const content = event.partialResult?.content || event.result?.content;
      if (!content) return "";
      return contentSegments(content, { toolName: "tool" }).map((segment) => segment.text).join("\n");
    }

    function toolExecutionText(event) {
      if (event.type === "tool_execution_start") return "(running…)";
      const fallback = toolExecutionContentText(event) || (event.type === "tool_execution_end" ? "(done)" : "(running…)");
      if (event.toolName === "subagent") return subagentDisplayText(subagentDetailsFromEvent(event), fallback, subagentRunning(event));
      return fallback;
    }

    function toolExecutionSummary(event) {
      if (event.toolName === "subagent") return subagentSummary(subagentDetailsFromEvent(event), subagentRunning(event));
      const status = event.type === "tool_execution_end" ? (event.isError ? "failed" : "done") : "running";
      return `${event.toolName || "tool"} ${status}`;
    }

    function toolExecutionRawDetails(event) {
      const result = toolExecutionResult(event);
      return result ? JSON.stringify(result, null, 2) : JSON.stringify({ args: event.args || {} }, null, 2);
    }

    function updateLiveToolExecution(entry, event, shouldScroll) {
      renderToolSummary(entry.summaryText, null, toolExecutionSummary(event));
      entry.body.textContent = toolExecutionText(event);
      if (entry.rawBody) entry.rawBody.textContent = toolExecutionRawDetails(event);
      if (event.toolName === "subagent") entry.details.open = subagentRunning(event);
      entry.article.classList.toggle("message--tool-error", event.isError === true);
      afterLiveOutputChange(shouldScroll);
      return entry;
    }

    function renderToolExecutionEvent(event) {
      if (!event.toolCallId || ["bash", "read", "edit", "write"].includes(event.toolName)) return;
      const shouldScroll = followLiveOutput();
      const existing = liveToolExecutions.get(event.toolCallId);
      if (existing) {
        updateLiveToolExecution(existing, event, shouldScroll);
        return;
      }

      const entry = appendCompactMessage("tool", toolExecutionSummary(event), toolExecutionText(event), true, true, shouldScroll, toolExecutionRawDetails(event), eventTimestamp(event), { error: event.isError === true, open: event.toolName === "subagent" && subagentRunning(event) });
      if (entry) liveToolExecutions.set(event.toolCallId, entry);
    }

    function renderMessageEvent(event) {
      const message = eventMessage(event);
      const segments = message?.content ? contentSegments(message.content, message) : [{ text: messageText(message), compact: false, summary: "", startIndex: 0, endIndex: 0 }].filter((segment) => segment.text);
      const roleName = liveEventRole(event, message);

      if (roleName === "assistant" && event.type === "message_start") resetLiveAssistantTracking();
      if (segments.length === 0) return;

      const shouldScroll = followLiveOutput();
      const timestamp = eventTimestamp(event);

      if (roleName !== "assistant") {
        segments.forEach((segment, index) => {
          const toolExecutionEntry = segment.toolCallId && liveToolExecutions.get(segment.toolCallId);
          const bashCallEntry = ["bash", "read", "edit", "write"].includes(segment.toolName) && segment.toolCallId && liveBashToolCalls.get(segment.toolCallId);
          if (toolExecutionEntry && segment.isToolResult) {
            toolExecutionEntry.body.textContent = segment.text;
            if (toolExecutionEntry.rawBody) toolExecutionEntry.rawBody.textContent = segment.rawDetails || "";
            renderToolSummary(toolExecutionEntry.summaryText, segment.summaryParts, segment.summary);
            toolExecutionEntry.article.classList.toggle("message--tool-error", segment.error === true);
            if (!markLiveEntryRendered(toolExecutionEntry, toolExecutionEntry.article.dataset.role || "toolResult", segment.text, timestamp)) return;
            afterLiveOutputChange(shouldScroll);
          } else if (bashCallEntry && segment.isToolResult) {
            const mergedText = segment.toolTranscript && segment.error !== true ? segment.text : [bashCallEntry.body.textContent, segment.text].filter(Boolean).join("\n\n");
            bashCallEntry.body.textContent = mergedText;
            if (bashCallEntry.rawBody) {
              bashCallEntry.rawBody.textContent = [bashCallEntry.rawBody.textContent, segment.rawDetails].filter(Boolean).join("\n\n");
            }
            bashCallEntry.article.classList.toggle("message--tool-error", segment.error === true);
            if (!markLiveEntryRendered(bashCallEntry, bashCallEntry.article.dataset.role || "assistant", mergedText)) return;
            afterLiveOutputChange(shouldScroll);
          } else if (roleName === "user" && !segment.compact) {
            upsertLiveUserSegment(event, segment, index, shouldScroll, timestamp);
          } else if (segment.compact) {
            appendCompactMessage(roleName, segment.summary, segment.text, segment.expanded, true, shouldScroll, segment.rawDetails, timestamp, { summaryParts: segment.summaryParts, toolTranscript: segment.toolTranscript, open: segment.expanded, error: segment.error });
          } else {
            appendMessage(roleName, segment.text, true, shouldScroll, timestamp);
          }
        });
        return;
      }

      liveAssistantSeen = true;
      segments.forEach((segment, index) => {
        const entry = upsertLiveAssistantSegment(event, roleName, segment, index, shouldScroll, timestamp);
        if (entry && !segment.compact) liveAssistantMessage = entry;
      });
    }

    function renderEvent(event) {
      if (event.type === "agent_start") {
        liveAgentRunning = true;
        setComposerState("running", "Pi is running…");
        showStatus("Pi is thinking…");
        return;
      }

      if (event.type === "turn_start") {
        setComposerState("running", "Pi is running…");
        showStatus("Pi is thinking…");
        return;
      }

      if (["message_start", "message_update", "message_end"].includes(event.type)) {
        renderMessageEvent(event);
        notifyFinalAssistantReply(event);
        return;
      }

      if (["tool_execution_start", "tool_execution_update", "tool_execution_end"].includes(event.type)) {
        renderToolExecutionEvent(event);
        return;
      }

      if (["custom", "custom_message", "session_info", "queue_update", "compaction_start", "compaction_end"].includes(event.type)) {
        updateSessionHeaderName(sessionTitleFromEvent(event));
        showStatus(eventStatusText(event));
        return;
      }

      if (event.type === "turn_end") {
        if (liveAssistantSeen) showStatus("Done");
        if (!liveAgentRunning) setComposerState("done", "Done");
        resetLiveAssistantTracking();
        return;
      }

      if (event.type === "agent_end") {
        liveAgentRunning = false;
        if (liveAssistantSeen) showStatus("Done");
        setComposerState("done", "Done");
        resetLiveAssistantTracking();
        return;
      }

      if (event.error) {
        appendMessage("error", event.error);
      }
    }

    function eventPollDelay() {
      if (document.hidden) return 10000;
      if (emptyEventPollCount >= 6) return 5000;
      if (emptyEventPollCount >= 2) return 2000;
      return 1000;
    }

    function resetEventPollBackoff() {
      emptyEventPollCount = 0;
    }

    function resetEventCursor() {
      lastEventSeq = Number(liveOutput?.dataset.eventsAfter || 0);
    }

    function scheduleNextEventPoll(delay = eventPollDelay()) {
      if (!liveOutput) return;
      clearTimeout(eventPollTimer);
      if (modalIsOpen()) return;
      eventPollTimer = setTimeout(() => pollEvents().catch(() => {}), delay);
    }

    function showReconnectBanner() {
      reconnectBanner?.classList.add("is-visible");
    }

    function hideReconnectBanner() {
      reconnectBanner?.classList.remove("is-visible");
    }

    function abortEventPoll() {
      if (eventPollAbortController) {
        eventPollAbortController.piSuppressedAbort = true;
        eventPollAbortController.abort();
      }
      eventPollAbortController = null;
      eventPollInFlight = false;
    }

    function composerDraft() {
      return {
        session: promptSessionInput?.value || "",
        message: promptTextarea?.value || "",
        images: pendingImages.map((entry) => entry.file)
      };
    }

    function restoreComposerDraft(draft) {
      if (!draft || promptSessionInput?.value !== draft.session) return;
      if (promptTextarea && draft.message) {
        promptTextarea.value = draft.message;
        resizePromptTextarea();
      }
      if (draft.images.length > 0) addImageFiles(draft.images);
    }

    async function refreshCurrentSessionPreservingComposer() {
      const draft = composerDraft();
      const refreshed = await switchSession(window.location.href, { push: false, focus: false });
      if (refreshed) restoreComposerDraft(draft);
      return refreshed;
    }

    async function reconnectSession() {
      hideReconnectBanner();
      await refreshCurrentSessionPreservingComposer();
    }

    async function refreshStaleSessionAfterResume(hiddenDuration = 0) {
      if (!liveOutput || document.hidden) return false;
      if (staleSessionRefreshInFlight) return true;

      const pollingGap = Date.now() - lastEventPollSuccessAt;
      if (hiddenDuration < staleSessionRefreshAfterMs && pollingGap < staleSessionRefreshAfterMs) return false;

      staleSessionRefreshInFlight = true;
      try {
        return await refreshCurrentSessionPreservingComposer();
      } finally {
        staleSessionRefreshInFlight = false;
      }
    }

    async function resumeEventPolling(hiddenDuration = 0) {
      if (!liveOutput) return;

      const resumeStartedAt = Date.now();
      clearTimeout(eventPollTimer);
      clearTimeout(eventPollResumeTimer);
      abortEventPoll();
      resetEventPollBackoff();
      hideReconnectBanner();
      if (await refreshStaleSessionAfterResume(hiddenDuration)) return;
      scheduleNextEventPoll(0);
      eventPollResumeTimer = setTimeout(() => {
        if (!document.hidden && lastEventPollSuccessAt < resumeStartedAt) showReconnectBanner();
      }, 5000);
    }

    async function pollEvents() {
      if (!liveOutput) return;
      if (modalIsOpen()) return;
      if (eventPollInFlight) return;

      const generation = sessionViewGeneration;
      const controller = new AbortController();
      const pollTimeout = setTimeout(() => controller.abort(), 12000);
      eventPollInFlight = true;
      eventPollAbortController = controller;
      try {
        const eventsUrl = new URL(liveOutput.dataset.eventsUrl, window.location.origin);
        eventsUrl.searchParams.set("after", lastEventSeq);
        const response = await fetch(eventsUrl, { signal: controller.signal });
        if (!response.ok || generation !== sessionViewGeneration) return;

        const payload = await response.json();
        if (generation !== sessionViewGeneration) return;
        lastEventPollSuccessAt = Date.now();
        hideReconnectBanner();
        if (payload.missed) {
          await refreshCurrentSessionPreservingComposer();
          return;
        }
        if (Number.isInteger(payload.last_seq)) {
          lastEventSeq = payload.last_seq;
        }
        emptyEventPollCount = payload.events.length > 0 ? 0 : emptyEventPollCount + 1;
        if (payload.events.length > 0 && composerState?.dataset.state === "running" && !waitingForOutputSince) startWaitingForOutput();
        updateWaitingForOutputStatus();
        payload.events.forEach((event) => {
          updateStatusFromEvent(event);
          renderEvent(event);
        });
        if (payload.events.length > 0) refreshSessionStatus(generation).catch(() => {});
      } catch (_error) {
        if (!controller.piSuppressedAbort && generation === sessionViewGeneration && !document.hidden) showReconnectBanner();
      } finally {
        clearTimeout(pollTimeout);
        if (eventPollAbortController === controller) eventPollAbortController = null;
        if (generation === sessionViewGeneration) {
          eventPollInFlight = false;
          scheduleNextEventPoll();
        }
      }
    }

    async function submitPrompt(event) {
      event.preventDefault();

      if (promptTextarea?.disabled) return;

      const steering = composerState?.dataset.state === "running";
      if (steering && pendingImages.length > 0) {
        showStatus("Steering messages cannot include images", true);
        return;
      }

      const generation = sessionViewGeneration;
      const switchGeneration = sessionSwitchGeneration;
      const submittedSession = promptSessionInput?.value;
      const message = promptTextarea.value.trim();
      if (!message && pendingImages.length === 0) return;

      const formData = new FormData(promptForm);
      formData.set("message", message);
      pendingImages.forEach((entry) => formData.append("images[]", entry.file, entry.file.name || "image"));
      if (steering) formData.set("streaming_behavior", "steer");

      const renameCommand = steering ? null : sessionNameSlashCommand(message);
      if (!renameCommand) {
        if (!steering) resetLiveAssistantTracking();
        resetEventPollBackoff();
        scheduleNextEventPoll(0);
        appendMessage("user", [message, pendingImages.length > 0 ? `[${imageAttachmentLabel(pendingImages.length)}]` : ""].filter(Boolean).join("\n"), true, true, new Date(), { optimistic: true, optimisticText: message });
      }
      promptTextarea.value = "";
      clearAttachments();
      commandList?.classList.remove("is-visible");
      commandList?.removeAttribute("open");
      if (commandFilter) commandFilter.value = "";
      commandList?.querySelectorAll(".command").forEach((command) => { command.hidden = false; });
      resizePromptTextarea();
      if (shouldAutofocusPrompt()) promptTextarea.focus();
      setComposerState("sending", renameCommand ? "Renaming…" : steering ? "Queueing steer…" : "Sending…");
      showStatus(renameCommand ? "Renaming session…" : steering ? "Queueing steer…" : "Sending…", true);

      const response = await fetch(promptForm.action, { method: "POST", body: formData, headers: { "Accept": "application/json" }, redirect: "manual" });
      if (generation !== sessionViewGeneration || switchGeneration !== sessionSwitchGeneration || submittedSession !== promptSessionInput?.value) return;

      if (!response.ok && response.type !== "opaqueredirect") {
        setComposerState("error", "Prompt failed");
        showStatus("Prompt failed to send", true);
      } else if (response.ok) {
        const payload = await response.json().catch(() => null);
        if (generation !== sessionViewGeneration || switchGeneration !== sessionSwitchGeneration || submittedSession !== promptSessionInput?.value) return;
        if (payload?.command === "rename") {
          if (payload.error) {
            setComposerState("error", payload.error);
            showStatus(payload.error, true);
            return;
          }
          if (payload?.session && promptSessionInput && payload.session !== promptSessionInput.value) {
            await switchSession(payload.redirect || `/?session=${encodeURIComponent(payload.session)}`, { push: true, focus: true });
            return;
          }
          updateSessionHeaderName(payload.name);
          setComposerState("done", "Renamed");
          showStatus(eventStatusText({ type: "session_info", name: payload.name }), true);
          refreshSidebar().catch(() => {});
          return;
        }
        if (payload?.session && promptSessionInput && payload.session !== promptSessionInput.value) {
          await switchSession(payload.redirect || `/?session=${encodeURIComponent(payload.session)}`, { push: true, focus: true });
          return;
        }
        setComposerState("running", "Pi is running…");
        if (payload?.steer) showStatus("Sent to queue", true);
      } else {
        setComposerState("running", "Pi is running…");
      }
      scrollToBottom();
    }

    async function submitAbort(event) {
      event.preventDefault();
      if (!abortForm || abortForm.dataset.submitting === "true") return;

      abortForm.dataset.submitting = "true";
      showSessionSwitching();
      try {
        const response = await fetch(abortForm.action, { method: "POST", body: new FormData(abortForm), headers: { "Accept": "application/json" } });
        if (!response.ok) showStatus("Stop failed", true);
      } catch (_error) {
        showStatus("Stop failed", true);
      } finally {
        delete abortForm.dataset.submitting;
        hideSessionSwitching();
        scheduleNextEventPoll(0);
        refreshSidebar().catch(() => {});
      }
    }

    function bindCommandFilter() {
      commandFilter?.addEventListener("input", () => {
        const query = commandFilter.value.trim().toLowerCase();
        commandList?.querySelectorAll(".command").forEach((command) => {
          command.hidden = query && !command.dataset.commandText.toLowerCase().includes(query);
        });
      });
    }

    async function ensureCommandsLoaded() {
      const list = commandList;
      const generation = sessionSwitchGeneration;
      if (!list || list.dataset.loaded === "true") return;
      const url = list.dataset.commandsUrl;
      if (!url || list.dataset.loading === "true") return;

      list.dataset.loading = "true";
      try {
        const response = await fetch(url);
        if (!response.ok || commandList !== list || !list.isConnected || generation !== sessionSwitchGeneration || list.dataset.commandsUrl !== url) return;
        const html = await response.text();
        if (commandList !== list || !list.isConnected || generation !== sessionSwitchGeneration || list.dataset.commandsUrl !== url) return;
        list.outerHTML = html;
        commandList = document.getElementById("command-list");
        commandFilter = commandList?.querySelector(".command-filter") || null;
        bindCommandFilter();
        if (promptTextarea?.value.startsWith("/")) {
          commandList?.classList.add("is-visible");
          commandList?.setAttribute("open", "");
        }
      } catch (_error) {
      } finally {
        delete list.dataset.loading;
      }
    }

    function bindSessionControls() {
      bindCommandFilter();

      promptTextarea?.addEventListener("keydown", (event) => {
        if (event.key === "Enter" && !event.shiftKey && shouldAutofocusPrompt()) {
          event.preventDefault();
          promptForm.requestSubmit();
        }
      });

      promptTextarea?.addEventListener("paste", (event) => {
        const items = [...(event.clipboardData?.items || [])];
        const files = items.map((item) => item.kind === "file" ? item.getAsFile() : null).filter(Boolean);
        if (addImageFiles(files)) event.preventDefault();
      });

      promptForm?.addEventListener("dragover", (event) => {
        if ([...(event.dataTransfer?.items || [])].some((item) => item.type.startsWith("image/"))) {
          event.preventDefault();
        }
      });

      promptForm?.addEventListener("drop", (event) => {
        const files = event.dataTransfer?.files || [];
        const hasImage = [...files].some((file) => file.type.startsWith("image/"));
        if (!hasImage) return;

        event.preventDefault();
        if (!addImageFiles(files) && composerState?.dataset.state === "running") showStatus("Steering messages cannot include images", true);
      });

      imageInput?.addEventListener("change", () => {
        addImageFiles(imageInput.files || []);
        imageInput.value = "";
      });

      conversationScroll?.addEventListener("scroll", () => {
        const currentScrollTop = conversationScroll.scrollTop;
        if (!programmaticScroll) {
          if (currentScrollTop > lastConversationScrollTop) conversationScrollDirection = "down";
          if (currentScrollTop < lastConversationScrollTop) conversationScrollDirection = "up";
          autoScrollEnabled = nearConversationBottom();
          forceBottomAutoScroll = false;
          updateConversationJumpControlsReveal();
        }
        lastConversationScrollTop = currentScrollTop;
        updateScrollJumpButtons();
      }, { passive: true });
      jumpToFirstButton?.addEventListener("click", () => scrollToTop());
      jumpToLatestButton?.addEventListener("click", () => scrollToBottom("auto", { force: true }));
      reconnectButton?.addEventListener("click", reconnectSession);
      conversationPanel?.addEventListener("click", (event) => {
        const turnButton = event.target.closest(".message-turn-button");
        if (!turnButton) return;

        event.preventDefault();
        const messages = userMessages();
        const currentIndex = messages.indexOf(turnButton.closest('[data-role="user"].message'));
        const targetIndex = turnButton.dataset.direction === "previous" ? currentIndex - 1 : currentIndex + 1;
        const target = messages[targetIndex];
        if (!target) return;
        scrollToUserMessage(target);
      });
      conversationPanel?.addEventListener("click", (event) => {
        if (!event.target.closest("[data-collapse-details]")) return;
        const details = event.target.closest("details.message-details");
        if (details) details.open = false;
      });

      promptTextarea?.addEventListener("input", () => {
        resizePromptTextarea();
        if (!commandList) return;

        if (promptTextarea.value.startsWith("/")) {
          ensureCommandsLoaded();
          commandList?.classList.add("is-visible");
          commandList?.setAttribute("open", "");
        } else {
          commandList?.classList.remove("is-visible");
          commandList?.removeAttribute("open");
        }
      });

      promptForm?.addEventListener("submit", submitPrompt);
      abortForm?.addEventListener("submit", submitAbort);
    }

    async function copyText(text) {
      if (navigator.clipboard?.writeText && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return true;
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.left = "-9999px";
      textarea.style.top = "0";
      document.body.append(textarea);
      textarea.select();

      try {
        return document.execCommand("copy");
      } finally {
        textarea.remove();
      }
    }

    function resetSessionViewState() {
      sessionViewGeneration += 1;
      clearTimeout(eventPollTimer);
      clearTimeout(sidebarRefreshTimer);
      clearTimeout(eventPollResumeTimer);
      abortEventPoll();
      if (scheduledAutoScrollFrame) cancelAnimationFrame(scheduledAutoScrollFrame);
      eventPollTimer = null;
      sidebarRefreshTimer = null;
      eventPollResumeTimer = null;
      scheduledAutoScrollFrame = null;
      resetLiveAssistantTracking();
      liveAgentRunning = false;
      resetEventPollBackoff();
      stopWaitingForOutput();
      lastEventSeq = 0;
      autoScrollEnabled = true;
      forceBottomAutoScroll = false;
      hideReconnectBanner();
      clearAttachments();
    }

    function sidebarFragmentUrl(url = window.location.href) {
      const target = new URL(url, window.location.href);
      const sidebarUrl = new URL("/sidebar", window.location.origin);
      target.searchParams.forEach((value, key) => sidebarUrl.searchParams.append(key, value));
      if (!sidebarUrl.searchParams.has("session")) {
        const selectedSession = sessionSidebar?.querySelector("a.session.selected[data-session-path]")?.dataset.sessionPath;
        if (selectedSession) sidebarUrl.searchParams.set("session", selectedSession);
      }
      return sidebarUrl;
    }

    function scheduleSidebarRefresh(delay = 2500) {
      clearTimeout(sidebarRefreshTimer);
      if (document.hidden || modalIsOpen()) return;
      sidebarRefreshTimer = setTimeout(() => refreshSidebar().catch(() => {}), delay);
    }

    function sidebarAssistantResponseCounts(root = sessionSidebar) {
      const counts = new Map();
      root?.querySelectorAll("a.session[data-session-path][data-assistant-response-count]").forEach((link) => {
        const sessionPath = link.dataset.sessionPath;
        const count = Number(link.dataset.assistantResponseCount || 0);
        counts.set(sessionPath, Math.max(counts.get(sessionPath) || 0, count));
      });
      return counts;
    }

    function notifyBackgroundFinalReplies(previousAssistantCounts) {
      sessionSidebar?.querySelectorAll("a.session[data-session-path][data-assistant-response-count]").forEach((link) => {
        const sessionPath = link.dataset.sessionPath;
        const previousCount = previousAssistantCounts.get(sessionPath);
        const currentCount = Number(link.dataset.assistantResponseCount || 0);
        if (previousCount == null || currentCount <= previousCount) return;
        if (sessionPath === currentSessionPath()) return;

        const key = [sessionPath, currentCount].join(":");
        if (notifiedFinalReplyKeys.has(key)) return;
        notifiedFinalReplyKeys.add(key);
        const name = link.querySelector(".session-title")?.textContent.trim() || "a background session";
        const body = notificationReplyPreview(link.dataset.latestAssistantResponsePreview);
        showPiNotification(name, body, sessionUrl(sessionPath), `pi-final-reply:${sessionPath}`).catch(() => {});
      });
    }

    function sidebarScrollContainer() {
      return sessionSidebar?.querySelector(".session-sidebar-content") || sessionSidebar;
    }

    function recentlyInteractedWithSidebar() {
      return Date.now() - lastSidebarInteractionAt < 1000;
    }

    function sidebarProjectFilterActive() {
      return document.activeElement?.matches("[data-sidebar-project-filter]");
    }

    function updateHeaderFromSelectedSidebarSession() {
      const selectedTitle = sessionSidebar?.querySelector("a.session.selected .session-title")?.textContent.trim();
      if (selectedTitle) updateSessionHeaderName(selectedTitle);
    }

    function replaceNewSessionModalHtml(html) {
      const currentModal = document.querySelector('[data-modal="new-session-modal"]');
      if (!html || !currentModal) return;

      currentModal.outerHTML = html;
    }

    function replaceSidebarHtml(html, { scrollTop = sidebarScrollContainer()?.scrollTop || 0, notify = true } = {}) {
      const previousAssistantCounts = sidebarAssistantResponseCounts();
      sessionSidebar.outerHTML = html;
      sessionSidebar = document.querySelector(".session-sidebar");
      if (notify) notifyBackgroundFinalReplies(previousAssistantCounts);
      const refreshedScrollContainer = sidebarScrollContainer();
      if (refreshedScrollContainer) refreshedScrollContainer.scrollTop = scrollTop;
      updateHeaderFromSelectedSidebarSession();
      bindSidebarScrollTracking();
    }

    async function refreshSidebar(generation = sessionViewGeneration) {
      if (modalIsOpen()) return;
      if (sidebarProjectFilterActive() || recentlyInteractedWithSidebar()) {
        scheduleSidebarRefresh(1000);
        return;
      }

      const sidebarGeneration = ++sidebarUpdateGeneration;
      const response = await fetch(sidebarFragmentUrl());
      if (!response.ok || generation !== sessionViewGeneration || sidebarGeneration !== sidebarUpdateGeneration) return;
      const html = await response.text();
      if (generation !== sessionViewGeneration || sidebarGeneration !== sidebarUpdateGeneration || !sessionSidebar) return;
      if (sidebarProjectFilterActive()) {
        scheduleSidebarRefresh(1000);
        return;
      }
      const previousScrollTop = sidebarScrollContainer()?.scrollTop || 0;
      replaceSidebarHtml(html, { scrollTop: previousScrollTop });
      scheduleSidebarRefresh();
    }

    async function changeSidebarProjectFilter(select) {
      if (!select) return;

      const targetUrl = new URL(window.location.href);
      if (select.value) {
        targetUrl.searchParams.set("project", select.value);
      } else {
        targetUrl.searchParams.delete("project");
      }
      targetUrl.searchParams.delete("sidebar_sessions_limit");

      const viewGeneration = sessionViewGeneration;
      const switchGeneration = sessionSwitchGeneration;
      const sidebarGeneration = ++sidebarUpdateGeneration;
      const [sidebarResponse, modalResponse] = await Promise.all([
        fetch(sidebarFragmentUrl(targetUrl.href)),
        fetch(newSessionModalUrl(targetUrl.href))
      ]);
      if (!sidebarResponse.ok || !modalResponse.ok || !sessionSidebar) throw new Error("Project filter refresh failed");
      if (viewGeneration !== sessionViewGeneration || switchGeneration !== sessionSwitchGeneration || sidebarGeneration !== sidebarUpdateGeneration) return;
      const [html, modalHtml] = await Promise.all([sidebarResponse.text(), modalResponse.text()]);
      if (viewGeneration !== sessionViewGeneration || switchGeneration !== sessionSwitchGeneration || sidebarGeneration !== sidebarUpdateGeneration || !sessionSidebar) return;
      replaceSidebarHtml(html, { scrollTop: 0, notify: false });
      replaceNewSessionModalHtml(modalHtml);
      history.pushState(history.state, "", targetUrl.href);
      scheduleSidebarRefresh();
    }

    async function loadMoreSidebarSessions(button) {
      if (!button || button.classList.contains("is-loading")) return;

      const viewGeneration = sessionViewGeneration;
      const switchGeneration = sessionSwitchGeneration;
      const sidebarGeneration = ++sidebarUpdateGeneration;
      const previousScrollTop = sidebarScrollContainer()?.scrollTop || 0;
      const originalLabel = button.querySelector(".sidebar-load-more-label")?.textContent || "Load more";
      button.classList.add("is-loading");
      button.setAttribute("aria-busy", "true");
      const label = button.querySelector(".sidebar-load-more-label");
      if (label) label.textContent = "Loading…";

      try {
        const targetUrl = new URL(button.href, window.location.href);
        const response = await fetch(sidebarFragmentUrl(targetUrl.href));
        if (!response.ok || !sessionSidebar || viewGeneration !== sessionViewGeneration || switchGeneration !== sessionSwitchGeneration || sidebarGeneration !== sidebarUpdateGeneration) return;
        const html = await response.text();
        if (!sessionSidebar || viewGeneration !== sessionViewGeneration || switchGeneration !== sessionSwitchGeneration || sidebarGeneration !== sidebarUpdateGeneration) return;
        replaceSidebarHtml(html, { scrollTop: previousScrollTop });
        history.replaceState(history.state, "", targetUrl.href);
        scheduleSidebarRefresh();
      } catch (_error) {
      } finally {
        if (viewGeneration === sessionViewGeneration && switchGeneration === sessionSwitchGeneration) scheduleSidebarRefresh();
        if (button.isConnected) {
          button.classList.remove("is-loading");
          button.removeAttribute("aria-busy");
          const currentLabel = button.querySelector(".sidebar-load-more-label");
          if (currentLabel) currentLabel.textContent = originalLabel;
        }
      }
    }

    function sessionFragmentUrl(url) {
      const target = new URL(url, window.location.href);
      const fragmentUrl = new URL("/session_fragment", window.location.origin);
      target.searchParams.forEach((value, key) => fragmentUrl.searchParams.append(key, value));
      return fragmentUrl;
    }

    function newSessionModalUrl(url) {
      const target = new URL(url, window.location.href);
      const modalUrl = new URL("/new_session_modal", window.location.origin);
      target.searchParams.forEach((value, key) => modalUrl.searchParams.append(key, value));
      return modalUrl;
    }

    function showSessionSwitching() {
      document.body.classList.add("session-switching");
    }

    function hideSessionSwitching() {
      document.body.classList.remove("session-switching");
    }

    async function switchSession(url, { push = true, focus = true } = {}) {
      const switchGeneration = ++sessionSwitchGeneration;
      let navigatingAway = false;
      showSessionSwitching();
      resetSessionViewState();
      try {
        const response = await fetch(sessionFragmentUrl(url), { headers: { "Accept": "application/json" } });
        if (switchGeneration !== sessionSwitchGeneration) return false;
        if (!response.ok) {
          navigatingAway = true;
          window.location.href = url;
          return false;
        }

        const payload = await response.json();
        if (switchGeneration !== sessionSwitchGeneration) return false;
        resetSessionViewState();
        sessionSidebar.outerHTML = payload.sidebar_html;
        conversationPanel.outerHTML = payload.conversation_html;
        replaceNewSessionModalHtml(payload.new_session_modal_html);
        bindSessionDom();
        bindSessionControls();
        if (push) history.pushState({ session: payload.session }, payload.title || "", payload.url || url);
        document.title = payload.title ? `${payload.title} · Pi Web Gateway` : "Pi Web Gateway";
        closeMobileSessionSidebar();
        initializeSessionView({ focus });
        return true;
      } catch (_error) {
        navigatingAway = true;
        window.location.href = url;
        return false;
      } finally {
        if (!navigatingAway && switchGeneration === sessionSwitchGeneration) hideSessionSwitching();
      }
    }

    function enterSessionShortcutMode() {
      document.body.classList.add("session-shortcuts-visible");
    }

    function exitSessionShortcutMode() {
      document.body.classList.remove("session-shortcuts-visible");
    }

    function currentSessionPath() {
      return promptSessionInput?.value || new URLSearchParams(window.location.search).get("session") || "";
    }

    function showAllSessionsActive() {
      return new URLSearchParams(window.location.search).get("show_all_sessions") === "1";
    }

    function activeSidebarSessionsLimit() {
      return new URLSearchParams(window.location.search).get("sidebar_sessions_limit") || "";
    }

    async function openRecentSessionShortcut(shortcut) {
      const link = sessionSidebar?.querySelector(`.recent-session[data-session-shortcut="${shortcut}"]`);
      if (!link) return false;
      exitSessionShortcutMode();
      if (currentSessionPath() === link.dataset.sessionPath) return true;
      const switched = await switchSession(link.href, { push: true, focus: true });
      if (!switched || currentSessionPath() !== link.dataset.sessionPath) window.location.href = link.href;
      return switched;
    }

    function sessionShortcutsVisible() {
      return document.body.classList.contains("session-shortcuts-visible");
    }

    function recentSessionShortcutFromEvent(event) {
      if (/^[1-9]$/.test(event.key)) return event.key;
      return event.code.match(/^Digit([1-9])$/)?.[1] || event.code.match(/^Numpad([1-9])$/)?.[1] || null;
    }

    function closeMobileSessionSidebar() {
      const toggle = document.getElementById("mobile-session-toggle");
      if (toggle) toggle.checked = false;
    }

    function modalIsOpen() {
      return !!document.querySelector("[data-modal]:not([hidden])");
    }

    function openModal(modal) {
      if (!modal) return;
      modal.hidden = false;
      clearTimeout(eventPollTimer);
      clearTimeout(sidebarRefreshTimer);
      clearTimeout(browserAccessPollTimer);
      browserAccessPollTimer = null;
      abortEventPoll();
      document.body.classList.add("modal-open");
      modal.querySelector("input, select, textarea, button")?.focus();
    }

    function closeModal(modal) {
      if (!modal) return;
      modal.hidden = true;
      document.body.classList.toggle("modal-open", modalIsOpen());
      if (!modalIsOpen() && !document.hidden) {
        scheduleNextEventPoll(0);
        scheduleSidebarRefresh(0);
        if (document.body.dataset.browserAccessEnabled === "true" && !browserAccessPollTimer) pollBrowserAccessRequests();
      }
    }

    function setCwdValidationState(form, state, message) {
      const status = form?.querySelector("[data-new-session-cwd-message]");
      const submit = form?.querySelector("[data-new-session-submit]");
      if (!status || !submit) return;
      status.textContent = message;
      status.classList.toggle("is-valid", state === "valid");
      status.classList.toggle("is-invalid", state === "invalid");
      submit.disabled = state !== "valid";
    }

    function validateNewSessionCwd(form, { delay = 250 } = {}) {
      const input = form?.querySelector("[data-new-session-cwd-input]");
      const validationEndpoint = form?.dataset.cwdValidationUrl;
      if (!input || !validationEndpoint) return;

      clearTimeout(cwdValidationTimer);
      cwdValidationController?.abort();
      const cwd = input.value.trim();
      if (!cwd) {
        setCwdValidationState(form, "invalid", "Enter an existing directory.");
        return;
      }

      setCwdValidationState(form, "pending", "Checking…");
      cwdValidationTimer = setTimeout(async () => {
        const controller = new AbortController();
        cwdValidationController = controller;
        try {
          const validationUrl = new URL(validationEndpoint, window.location.origin);
          validationUrl.searchParams.set("cwd", cwd);
          const response = await fetch(validationUrl, { headers: { "Accept": "application/json" }, signal: controller.signal });
          const payload = await response.json().catch(() => null);
          if (controller.signal.aborted || input.value.trim() !== cwd) return;
          if (response.ok && payload?.valid) {
            input.value = payload.cwd || cwd;
            setCwdValidationState(form, "valid", "Directory exists.");
          } else {
            setCwdValidationState(form, "invalid", payload?.error || "Path must be an existing directory.");
          }
        } catch (_error) {
          if (!controller.signal.aborted) setCwdValidationState(form, "invalid", "Could not validate this path.");
        } finally {
          if (cwdValidationController === controller) cwdValidationController = null;
        }
      }, delay);
    }

    function normalLeftClick(event) {
      return event.button === 0 && !event.metaKey && !event.ctrlKey && !event.shiftKey && !event.altKey;
    }

    document.addEventListener("click", (event) => {
      const opener = event.target.closest("[data-modal-open]");
      if (opener) {
        event.preventDefault();
        openModal(document.querySelector(`[data-modal="${opener.dataset.modalOpen}"]`));
        return;
      }

      const closer = event.target.closest("[data-modal-close]");
      if (closer) {
        event.preventDefault();
        closeModal(closer.closest("[data-modal]"));
        return;
      }

      const modal = event.target.matches("[data-modal]") ? event.target : null;
      if (modal) closeModal(modal);
    });

    document.addEventListener("input", (event) => {
      const input = event.target.closest("[data-new-session-cwd-input]");
      if (!input) return;
      const form = input.closest("form");
      const select = form?.querySelector("[data-new-session-known-cwd]");
      if (select && select.value !== input.value.trim()) select.value = "";
      validateNewSessionCwd(form);
    });

    document.addEventListener("change", (event) => {
      const select = event.target.closest("[data-new-session-known-cwd]");
      if (!select) return;
      const form = select.closest("form");
      const input = form?.querySelector("[data-new-session-cwd-input]");
      if (!input) return;
      input.value = select.value;
      validateNewSessionCwd(form, { delay: 0 });
    });

    document.addEventListener("submit", async (event) => {
      const form = event.target.closest(".new-session-cwd-form");
      if (!form) return;

      event.preventDefault();
      const submit = form.querySelector("[data-new-session-submit]");
      if (submit?.disabled || form.dataset.submitting === "true") return;

      const formData = new FormData(form);
      if (showAllSessionsActive()) {
        formData.set("show_all_sessions", "1");
      } else {
        formData.delete("show_all_sessions");
      }
      const sidebarSessionsLimit = activeSidebarSessionsLimit();
      if (sidebarSessionsLimit) {
        formData.set("sidebar_sessions_limit", sidebarSessionsLimit);
      } else {
        formData.delete("sidebar_sessions_limit");
      }
      const modal = form.closest("[data-modal]");
      const originalSubmitText = submit?.textContent || "Start session";
      form.dataset.submitting = "true";
      if (submit) {
        submit.disabled = true;
        submit.textContent = "Starting…";
      }
      showSessionSwitching();
      try {
        const response = await fetch(form.action, { method: "POST", body: formData, headers: { "Accept": "application/json" } });
        if (!response.ok) {
          const payload = await response.json().catch(() => null);
          setCwdValidationState(form, "invalid", payload?.error || "Path must be an existing directory.");
          if (submit) submit.textContent = originalSubmitText;
          return;
        }
        const payload = await response.json();
        closeModal(modal);
        await switchSession(payload.redirect || `/?session=${encodeURIComponent(payload.session)}`, { push: true, focus: true });
      } catch (_error) {
        setCwdValidationState(form, "invalid", "Could not start the session. Try again.");
        if (submit) {
          submit.disabled = false;
          submit.textContent = originalSubmitText;
        }
      } finally {
        delete form.dataset.submitting;
        hideSessionSwitching();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modalIsOpen()) {
        event.preventDefault();
        closeModal(document.querySelector("[data-modal]:not([hidden])"));
        return;
      }

      if (modalIsOpen()) return;

      if (event.key === "Control") {
        enterSessionShortcutMode();
        return;
      }

      if (!sessionShortcutsVisible()) return;
      if (event.key === "Escape") {
        event.preventDefault();
        exitSessionShortcutMode();
        return;
      }

      if (!event.ctrlKey) return;
      const shortcut = recentSessionShortcutFromEvent(event);
      if (shortcut) {
        event.preventDefault();
        openRecentSessionShortcut(shortcut).catch(() => {});
      }
    });

    document.addEventListener("keyup", (event) => {
      if (event.key === "Control") exitSessionShortcutMode();
    });

    window.addEventListener("blur", exitSessionShortcutMode);

    document.addEventListener("click", (event) => {
      if (!event.target.closest(".session-sidebar")) exitSessionShortcutMode();
    });

    document.addEventListener("change", async (event) => {
      const select = event.target.closest("[data-sidebar-project-filter]");
      if (!select) return;

      await changeSidebarProjectFilter(select).catch(() => select.form?.submit());
    });

    document.addEventListener("click", async (event) => {
      const button = event.target.closest("[data-sidebar-load-more]");
      if (!button || !normalLeftClick(event)) return;

      event.preventDefault();
      await loadMoreSidebarSessions(button);
    });

    document.addEventListener("click", async (event) => {
      const link = event.target.closest(".session-sidebar a.session");
      exitSessionShortcutMode();
      if (!link || !normalLeftClick(event)) return;

      event.preventDefault();
      if (link.classList.contains("selected")) {
        closeMobileSessionSidebar();
        return;
      }

      await switchSession(link.href, { push: true, focus: true });
    });

    document.addEventListener("submit", async (event) => {
      const form = event.target.closest('form[action="/sessions/new"]');
      if (!form) return;

      event.preventDefault();
      const switchGeneration = sessionSwitchGeneration;
      const viewGeneration = sessionViewGeneration;
      let navigatingAway = false;
      showSessionSwitching();
      try {
        const formData = new FormData(form);
        const sidebarSessionsLimit = activeSidebarSessionsLimit();
        if (sidebarSessionsLimit) {
          formData.set("sidebar_sessions_limit", sidebarSessionsLimit);
        } else {
          formData.delete("sidebar_sessions_limit");
        }
        const response = await fetch(form.action, { method: "POST", body: formData, headers: { "Accept": "application/json" } });
        if (switchGeneration !== sessionSwitchGeneration || viewGeneration !== sessionViewGeneration) return;
        if (!response.ok) {
          navigatingAway = true;
          form.submit();
          return;
        }

        const payload = await response.json();
        if (switchGeneration !== sessionSwitchGeneration || viewGeneration !== sessionViewGeneration) return;
        await switchSession(payload.redirect || `/?session=${encodeURIComponent(payload.session)}`, { push: true, focus: true });
      } finally {
        if (!navigatingAway && switchGeneration === sessionSwitchGeneration && viewGeneration === sessionViewGeneration) hideSessionSwitching();
      }
    });

    document.addEventListener("click", async (event) => {
      const button = event.target.closest(".copy-button");
      if (!button) return;

      const article = button.closest(".message");
      const body = article?.querySelector(".message-body");
      const text = body?.innerText || body?.textContent;
      if (!text) return;

      const original = button.textContent;
      try {
        const copied = await copyText(text);
        button.textContent = copied ? "Copied" : "Copy failed";
      } catch (_error) {
        button.textContent = "Copy failed";
      }
      setTimeout(() => { button.textContent = original; }, 1200);
    });

    document.addEventListener("click", (event) => {
      const command = event.target.closest(".command");
      if (!command || !commandList?.contains(command) || !promptTextarea) return;

      promptTextarea.value = `/${command.dataset.commandName} `;
      resizePromptTextarea();
      promptTextarea.focus();
    });

    function browserAccessElements() {
      return {
        overlay: document.querySelector("[data-browser-access-overlay]"),
        title: document.querySelector("[data-browser-access-title]"),
        meta: document.querySelector("[data-browser-access-meta]"),
        allow: document.querySelector("[data-browser-access-allow]"),
        deny: document.querySelector("[data-browser-access-deny]")
      };
    }

    async function pollBrowserAccessRequests() {
      if (modalIsOpen()) return;
      try {
        const response = await fetch("/browser-access/pending", { headers: { "Accept": "application/json" } });
        if (response.ok) {
          const payload = await response.json();
          showBrowserAccessRequest((payload.requests || [])[0]);
        }
      } catch (_error) {
      } finally {
        if (!modalIsOpen()) browserAccessPollTimer = setTimeout(pollBrowserAccessRequests, 3000);
      }
    }

    function showBrowserAccessRequest(request) {
      const elements = browserAccessElements();
      browserAccessOverlay = elements.overlay;
      if (!elements.overlay) return;
      if (!request) {
        browserAccessCurrentCode = null;
        elements.overlay.classList.remove("is-visible");
        return;
      }

      browserAccessCurrentCode = request.code;
      elements.title.textContent = `New browser requests access: ${request.code}`;
      elements.meta.textContent = [request.ip, request.user_agent].filter(Boolean).join(" · ");
      elements.overlay.classList.add("is-visible");
    }

    async function resolveBrowserAccessRequest(action) {
      if (!browserAccessCurrentCode) return;
      const formData = new FormData();
      formData.set("code", browserAccessCurrentCode);
      await fetch(`/browser-access/${action}`, { method: "POST", body: formData, headers: { "Accept": "application/json" } });
      showBrowserAccessRequest(null);
      clearTimeout(browserAccessPollTimer);
      browserAccessPollTimer = null;
      pollBrowserAccessRequests();
    }

    document.addEventListener("click", (event) => {
      if (event.target.closest("[data-browser-access-allow]")) resolveBrowserAccessRequest("approve").catch(() => {});
      if (event.target.closest("[data-browser-access-deny]")) resolveBrowserAccessRequest("deny").catch(() => {});
    });

    function initializeSessionView({ focus = true } = {}) {
      ensureNotificationWorker().catch(() => {});
      if (document.body.dataset.browserAccessEnabled === "true" && !browserAccessPollTimer) pollBrowserAccessRequests();
      if (liveOutput) {
        resetEventCursor();
        const initialComposerState = liveOutput.dataset.composerState;
        const initialComposerStateSince = Number(liveOutput.dataset.composerStateSince || 0);
        liveAgentRunning = liveOutput.dataset.agentRunning === "true";
        if (initialComposerState === "running") setComposerState(initialComposerState, "Pi is running…", initialComposerStateSince);
        scheduleNextEventPoll(0);
        requestAnimationFrame(() => {
          updatePromptPlaceholder();
          resizePromptTextarea();
          if (focus && shouldAutofocusPrompt()) promptTextarea?.focus();
          applyAutoScroll("auto");
        });
      }
      scheduleSidebarRefresh();
    }

    window.addEventListener("resize", updatePromptPlaceholder);
    window.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        hiddenAt = Date.now();
        return;
      }

      const hiddenDuration = hiddenAt ? Date.now() - hiddenAt : 0;
      hiddenAt = null;
      if (hiddenDuration > 5000) {
        resumeEventPolling(hiddenDuration).catch(() => {});
      } else {
        scheduleNextEventPoll(0);
      }
      scheduleSidebarRefresh();
    });
    window.addEventListener("pageshow", () => resumeEventPolling().catch(() => {}));
    window.addEventListener("focus", () => resumeEventPolling().catch(() => {}));
    window.addEventListener("online", () => resumeEventPolling().catch(() => {}));
    window.addEventListener("popstate", () => switchSession(window.location.href, { push: false, focus: false }));

    bindSessionDom();
    bindSessionControls();
    initializeSessionView();
  </script>
</body>
</html>
