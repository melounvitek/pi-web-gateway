<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pi Web Gateway</title>
  <style>
    body { margin: 0; font-family: system-ui, sans-serif; color: #1f2937; }
    .layout { display: grid; grid-template-columns: 22rem 1fr; min-height: 100vh; }
    aside { border-right: 1px solid #e5e7eb; padding: 1rem; overflow-y: auto; background: #f9fafb; }
    main { padding: 1.5rem; overflow-y: auto; }
    h1 { font-size: 1.25rem; margin: 0 0 1rem; }
    h2 { font-size: 0.9rem; margin: 1.25rem 0 0.5rem; color: #4b5563; overflow-wrap: anywhere; }
    a.session { display: block; padding: 0.6rem; margin: 0.25rem 0; border-radius: 0.5rem; color: inherit; text-decoration: none; }
    a.session:hover, a.session.selected { background: #e5e7eb; }
    .session-title { font-weight: 600; overflow-wrap: anywhere; }
    .session-meta { font-size: 0.8rem; color: #6b7280; margin-top: 0.2rem; }
    .empty { color: #6b7280; }
    .message, .event { border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 0.9rem; margin-bottom: 0.75rem; }
    .event { background: #f8fafc; }
    .status { color: #6b7280; font-size: 0.85rem; margin-bottom: 0.75rem; }
    .role { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #4b5563; margin-bottom: 0.4rem; }
    .live-heading { margin-top: 1.5rem; }
    pre { white-space: pre-wrap; overflow-wrap: anywhere; margin: 0; font-family: inherit; }
    .prompt-form { display: grid; gap: 0.5rem; margin: 1rem 0; }
    textarea { width: 100%; box-sizing: border-box; font: inherit; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; }
    button { justify-self: end; padding: 0.5rem 0.9rem; border: 0; border-radius: 0.5rem; background: #2563eb; color: white; font-weight: 600; cursor: pointer; }
  </style>
</head>
<body>
  <div class="layout">
    <aside>
      <h1>Pi Sessions</h1>
      <% if @groups.empty? %>
        <p class="empty">No sessions found.</p>
      <% end %>

      <% @groups.each do |cwd, sessions| %>
        <h2><%= h cwd %></h2>
        <% sessions.each do |session| %>
          <a class="session <%= "selected" if selected?(session) %>" href="/?session=<%= h Rack::Utils.escape(session.path) %>">
            <div class="session-title"><%= h session.display_name %></div>
            <div class="session-meta">
              <%= h session.message_count %> messages · updated <%= h format_time(session.modified_at) %>
            </div>
          </a>
        <% end %>
      <% end %>
    </aside>

    <main>
      <% if @selected_session %>
        <h1><%= h @selected_session.display_name %></h1>
        <p class="session-meta">
          <%= h @selected_session.cwd %><br>
          <%= h @selected_session.path %>
        </p>

        <% if @messages.empty? %>
          <p class="empty">No messages in this session.</p>
        <% end %>

        <% @messages.each do |message| %>
          <article class="message">
            <div class="role"><%= h message.role %></div>
            <pre><%= h message.text %></pre>
          </article>
        <% end %>

        <section id="live-output" data-events-url="/events?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
          <h2 class="live-heading">Live output</h2>
          <p class="empty" id="live-empty">Waiting for Pi events…</p>
        </section>

        <form method="post" action="/prompt" class="prompt-form">
          <input type="hidden" name="session" value="<%= h @selected_session.path %>">
          <textarea name="message" rows="4" placeholder="Ask Pi…"></textarea>
          <button type="submit">Send</button>
        </form>
      <% else %>
        <h1>No session selected</h1>
        <p class="empty">Create a Pi session first, then refresh this page.</p>
      <% end %>
    </main>
  </div>
  <script>
    const liveOutput = document.getElementById("live-output");
    const liveEmpty = document.getElementById("live-empty");
    const promptForm = document.querySelector(".prompt-form");
    const main = document.querySelector("main");
    let liveMessage = null;
    let statusLine = null;

    function scrollToBottom() {
      main?.scrollTo({ top: main.scrollHeight, behavior: "smooth" });
    }

    function removeLiveEmpty() {
      liveEmpty?.remove();
    }

    function contentText(content) {
      return (Array.isArray(content) ? content : [content]).map((part) => {
        if (!part) return "";
        if (typeof part === "string") return part;
        if (part.text) return part.text;
        if (part.thinking) return part.thinking;
        if (part.type === "toolCall") return `[tool: ${part.name || "tool"}]`;
        if (part.type === "toolResult") return part.output || part.result || "[tool result]";
        return "";
      }).filter(Boolean).join("\n");
    }

    function eventMessage(event) {
      return event.message || event.delta || event.item || event;
    }

    function messageText(message) {
      if (!message) return "";
      if (typeof message === "string") return message;
      if (message.text) return message.text;
      if (message.content) return contentText(message.content);
      return "";
    }

    function appendMessage(roleName, text, className = "message") {
      removeLiveEmpty();

      const article = document.createElement("article");
      article.className = className;

      const role = document.createElement("div");
      role.className = "role";
      role.textContent = roleName;

      const body = document.createElement("pre");
      body.textContent = text;

      article.append(role, body);
      liveOutput.append(article);
      scrollToBottom();
      return { article, body };
    }

    function showStatus(text) {
      removeLiveEmpty();
      if (!statusLine) {
        statusLine = document.createElement("div");
        statusLine.className = "status";
        liveOutput.append(statusLine);
      }
      statusLine.textContent = text;
      scrollToBottom();
    }

    function renderMessageEvent(event) {
      const message = eventMessage(event);
      const text = messageText(message);
      if (!text) return;

      if (!liveMessage || event.type === "message_start") {
        liveMessage = appendMessage(message.role || "assistant", text, "event");
      } else {
        liveMessage.body.textContent = text;
        scrollToBottom();
      }
    }

    function renderEvent(event) {
      if (["agent_start", "turn_start"].includes(event.type)) {
        showStatus("Pi is thinking…");
        return;
      }

      if (["message_start", "message_update", "message_end"].includes(event.type)) {
        renderMessageEvent(event);
        return;
      }

      if (["turn_end", "agent_end"].includes(event.type)) {
        showStatus("Done");
        liveMessage = null;
        return;
      }

      if (event.error) {
        appendMessage("error", event.error, "event");
      }
    }

    async function pollEvents() {
      if (!liveOutput) return;

      const response = await fetch(liveOutput.dataset.eventsUrl);
      if (!response.ok) return;

      const payload = await response.json();
      payload.events.forEach(renderEvent);
    }

    promptForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const textarea = promptForm.querySelector("textarea");
      const message = textarea.value.trim();
      if (!message) return;

      const formData = new FormData(promptForm);
      formData.set("message", message);

      appendMessage("user", message);
      textarea.value = "";
      showStatus("Sending…");

      const response = await fetch(promptForm.action, { method: "POST", body: formData, redirect: "manual" });
      if (!response.ok && response.type !== "opaqueredirect") {
        showStatus("Prompt failed to send");
      }
      scrollToBottom();
    });

    if (liveOutput) {
      setInterval(() => pollEvents().catch(() => {}), 1000);
      scrollToBottom();
    }
  </script>
</body>
</html>
