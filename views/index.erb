<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pi Web Gateway</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#18181e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Pi Gateway">
  <style>
    :root { color-scheme: dark; --bg: #18181e; --sidebar: #1e1e24; --panel: #1e1e24; --panel-soft: #282832; --panel-softer: #3a3a4a; --border: #505050; --text: #d4d4d4; --muted: #808080; --muted-soft: #666666; --accent: #8abeb7; --accent-hover: #00d7ff; --success: #b5bd68; --danger: #cc6666; --danger-soft: #3c2828; --code: #18181e; --link: #81a2be; --warning: #ffff00; --button-text: #18181e; }
    html, body { height: 100%; }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--text); background: var(--bg); overflow: hidden; }
    .app-shell { display: grid; grid-template-columns: 22rem minmax(0, 1fr); height: 100vh; min-height: 0; }
    body.session-only .app-shell { grid-template-columns: minmax(0, 1fr); }
    .session-sidebar { min-height: 0; display: flex; flex-direction: column; border-right: 1px solid var(--border); padding: 1rem; overflow: hidden; background: var(--sidebar); }
    .session-sidebar-content { flex: 1 1 auto; min-height: 0; overflow-y: auto; scrollbar-gutter: stable; }
    .conversation-panel { display: grid; grid-template-rows: auto minmax(0, 1fr) auto; min-width: 0; min-height: 0; background: var(--panel); }
    .session-header { position: sticky; top: 0; z-index: 2; display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 1.5rem 0.75rem; border-bottom: 1px solid var(--border); background: rgba(30, 30, 36, 0.96); backdrop-filter: blur(8px); box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18); }
    .session-header-title { flex: 1 1 auto; min-width: 0; display: grid; gap: 0.15rem; }
    .session-header h1 { min-width: 0; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .session-header-project { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--muted); font-size: 0.84rem; font-weight: 650; }
    .session-header-actions { flex: 0 0 auto; display: flex; align-items: center; gap: 0.45rem; }
    .session-header-actions form { margin: 0; }
    .session-header-action { padding: 0.42rem 0.65rem; font-size: 0.82rem; }
    .session-header-window-action { display: inline-flex; align-items: center; justify-content: center; min-width: 2.1rem; min-height: 2.1rem; border-radius: 0.55rem; background: var(--panel-softer); color: var(--text); font-weight: 800; line-height: 1; text-decoration: none; }
    .session-header-window-action:hover { background: var(--border); }
    .conversation-scroll { min-height: 0; overflow-y: auto; overflow-x: hidden; scrollbar-gutter: stable; padding: 1.5rem; }
    .conversation-scroll:focus-visible { outline: none; box-shadow: inset 0 0 0 2px rgba(138, 190, 183, 0.22); }
    .conversation-history-status { margin: 0 0 0.85rem; color: var(--muted); font-size: 0.84rem; text-align: center; }
    .composer { position: sticky; bottom: 0; padding: 0.75rem 1.5rem 1rem; border-top: 1px solid var(--border); background: rgba(30, 30, 36, 0.97); box-shadow: 0 -10px 24px rgba(0, 0, 0, 0.16); }
    .composer-inner { display: grid; gap: 0.6rem; }
    .attachment-tray { display: none; flex-wrap: wrap; gap: 0.5rem; padding: 0.5rem; border: 1px dashed var(--border); border-radius: 0.55rem; background: var(--panel-soft); }
    .attachment-tray.has-attachments { display: flex; }
    .attachment { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.25rem 0.4rem; border-radius: 0.45rem; background: var(--panel-softer); color: var(--muted); font-size: 0.82rem; }
    .attachment img { width: 2rem; height: 2rem; border-radius: 0.35rem; object-fit: cover; }
    .attachment button { padding: 0.1rem 0.35rem; background: transparent; border: 1px solid var(--border); color: var(--muted); }
    .attachment button:hover { color: var(--text); background: var(--panel-soft); transform: none; }
    .composer-input-row { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: end; gap: 0.55rem; }
    .image-input { position: fixed; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
    .attach-button { display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; min-width: 2.75rem; min-height: 2.75rem; padding: 0; border-radius: 0.55rem; background: var(--panel-softer); color: var(--text); font-weight: 800; cursor: pointer; }
    .attach-button:hover { background: var(--border); }
    h1 { font-size: 1.25rem; line-height: 1.2; margin: 0 0 1rem; letter-spacing: -0.01em; }
    h2 { font-size: 0.78rem; margin: 0; color: var(--muted-soft); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-sidebar-header { display: block; }
    .sidebar-title { min-width: 0; }
    .sidebar-server-origin { margin: -0.55rem 0 1rem; color: var(--muted); font-size: 0.78rem; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-session-search { display: none; align-items: center; gap: 0.4rem; margin: -0.25rem 0 0.5rem; }
    .sidebar-session-search.is-open { display: flex; }
    .sidebar-session-search input { flex: 1 1 auto; min-width: 0; padding: 0.5rem 0.65rem; color: var(--text); font-size: 0.84rem; background: rgba(40, 40, 50, 0.72); }
    .sidebar-search-toggle { min-width: 1.65rem; padding: 0.2rem 0.45rem; font-size: 1rem; }
    .sidebar-search-toggle.is-active { border: 1px solid rgba(138, 190, 183, 0.72); background: rgba(138, 190, 183, 0.18); color: var(--accent-hover); box-shadow: 0 0 0 2px rgba(138, 190, 183, 0.12); }
    .sidebar-project-filter-form { margin: 0 0 0.65rem; }
    .sidebar-filter-row { display: flex; align-items: center; gap: 0.45rem; }
    .sidebar-project-filter { flex: 1 1 auto; min-width: 0; padding: 0.5rem 0.65rem; color: var(--muted); font-size: 0.84rem; font-weight: 700; background: rgba(40, 40, 50, 0.72); }
    .sidebar-filter-spinner { display: none; flex: 0 0 auto; width: 0.9rem; height: 0.9rem; border: 2px solid rgba(138, 190, 183, 0.24); border-top-color: var(--accent); border-radius: 999px; animation: session-switch-spin 800ms linear infinite; }
    .session-sidebar.is-filtering .sidebar-filter-spinner { display: inline-block; }
    .session-sidebar.is-filtering .sidebar-project-filter, .session-sidebar.is-filtering .sidebar-filters-clear { opacity: 0.72; pointer-events: none; }
    .sidebar-filters-clear { flex: 0 0 auto; color: var(--muted); font-size: 0.76rem; font-weight: 800; text-decoration: none; white-space: nowrap; }
    .sidebar-filters-clear:hover { color: var(--text); text-decoration: underline; }
    .recent-sessions { margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(80, 80, 80, 0.7); }
    .recent-sessions-header { display: flex; align-items: center; gap: 0.4rem; margin: 0.75rem 0 0.5rem; }
    .recent-sessions-header h2 { flex: 1; min-width: 0; }
    .cwd-header { display: flex; align-items: center; gap: 0.4rem; margin: 1.25rem 0 0.5rem; }
    .cwd-header h2 { flex: 1; min-width: 0; }
    .cwd-toggle { display: inline-block; margin: 0.35rem 0 0.5rem; font-size: 0.8rem; color: var(--muted); text-decoration: none; }
    .cwd-toggle:hover { color: var(--text); text-decoration: underline; }
    .sidebar-load-more { display: flex; align-items: center; justify-content: center; gap: 0.45rem; margin: 0.7rem 0 0.5rem; padding: 0.6rem 0.75rem; border-radius: 0.6rem; background: var(--panel-softer); color: var(--text); font-size: 0.84rem; font-weight: 800; text-decoration: none; }
    .sidebar-load-more:hover { background: var(--border); }
    .sidebar-load-more-spinner { display: none; width: 0.95rem; height: 0.95rem; border: 2px solid rgba(138, 190, 183, 0.25); border-top-color: var(--accent); border-radius: 999px; animation: session-switch-spin 800ms linear infinite; }
    .sidebar-load-more.is-loading { pointer-events: none; opacity: 0.82; }
    .sidebar-load-more.is-loading .sidebar-load-more-spinner { display: inline-block; }
    a.session { position: relative; display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 0.5rem; padding: 0.65rem 0.75rem; margin: 0.25rem 0; border-radius: 0.6rem; color: inherit; text-decoration: none; border: 1px solid transparent; transition: background 120ms ease, border-color 120ms ease, transform 120ms ease; }
    a.session:hover { background: var(--panel-soft); border-color: var(--border); transform: translateX(1px); }
    a.session.selected { background: linear-gradient(90deg, rgba(138, 190, 183, 0.22), rgba(138, 190, 183, 0.08)); border-color: rgba(138, 190, 183, 0.55); }
    a.session.selected::before { content: ""; position: absolute; left: -1rem; top: 0.7rem; bottom: 0.7rem; width: 4px; border-radius: 999px; background: var(--accent); }
    a.session.unread .session-title { color: var(--text); font-weight: 800; }
    a.session.unread .session-indicators::before { content: "new"; padding: 0.1rem 0.35rem; border: 1px solid rgba(138, 190, 183, 0.45); border-radius: 999px; color: var(--accent); background: rgba(138, 190, 183, 0.08); font-size: 0.62rem; font-weight: 800; line-height: 1; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-content { min-width: 0; }
    .session-indicators { display: inline-flex; align-items: center; justify-content: flex-end; gap: 0.35rem; min-width: 0.7rem; }
    .session-fork-indicator { display: inline-flex; align-items: center; justify-content: center; min-width: 1.15rem; height: 1.15rem; border: 1px solid rgba(240, 199, 164, 0.34); border-radius: 999px; background: rgba(240, 199, 164, 0.08); color: #f0c7a4; font-size: 0.86rem; font-weight: 900; line-height: 1; }
    .session-shortcut { display: none; align-items: center; justify-content: center; width: 1.35rem; height: 1.35rem; border: 1px solid rgba(138, 190, 183, 0.55); border-radius: 999px; background: rgba(138, 190, 183, 0.14); color: var(--accent); font-size: 0.76rem; font-weight: 800; line-height: 1; font-variant-numeric: tabular-nums; }
    body.session-shortcuts-visible .recent-session .session-shortcut { display: inline-flex; }
    .session-title { font-weight: 650; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-notification-toggle { width: 100%; justify-self: stretch; display: grid; grid-template-columns: auto minmax(0, 1fr) auto; align-items: center; gap: 0.55rem; margin-top: 1.25rem; padding: 0.6rem 0.65rem; border: 1px solid transparent; border-radius: 0.6rem; background: var(--panel-softer); color: var(--text); font-size: 0.84rem; font-weight: 800; text-align: left; }
    .sidebar-notification-toggle:hover { background: var(--border); }
    .sidebar-notification-icon { display: inline-flex; align-items: center; justify-content: center; color: var(--muted); }
    .sidebar-notification-label { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-notification-state { min-width: 4.4rem; padding: 0.18rem 0.45rem; border: 1px solid rgba(128, 128, 128, 0.28); border-radius: 999px; background: rgba(128, 128, 128, 0.1); color: var(--muted); font-size: 0.7rem; font-weight: 900; line-height: 1.15; text-align: center; text-transform: uppercase; letter-spacing: 0.04em; }
    .sidebar-notification-toggle.is-enabled { border-color: rgba(138, 190, 183, 0.38); background: rgba(138, 190, 183, 0.1); }
    .sidebar-notification-toggle.is-enabled .sidebar-notification-icon, .sidebar-notification-toggle.is-enabled .sidebar-notification-state { color: var(--accent); }
    .sidebar-notification-toggle.is-enabled .sidebar-notification-state { border-color: rgba(138, 190, 183, 0.48); background: rgba(138, 190, 183, 0.16); }
    .sidebar-notification-toggle.is-disabled { color: var(--muted); }
    .sidebar-notification-toggle.is-blocked .sidebar-notification-state { border-color: rgba(204, 102, 102, 0.42); background: rgba(204, 102, 102, 0.12); color: #ffb4b6; }
    .session-project { display: inline-block; max-width: 100%; margin-top: 0.32rem; padding: 0.1rem 0.42rem; border: 1px solid rgba(138, 190, 183, 0.28); border-radius: 999px; background: rgba(138, 190, 183, 0.08); color: var(--accent); font-size: 0.72rem; font-weight: 800; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; vertical-align: top; }
    .session-relation-tree { max-width: min(42rem, 100%); margin-top: 0.45rem; padding: 0.55rem 0.65rem; border: 1px solid rgba(138, 190, 183, 0.22); border-radius: 0.7rem; background: rgba(8, 13, 32, 0.42); color: var(--muted); font-size: 0.78rem; line-height: 1.35; }
    .session-relation-tree-heading { cursor: pointer; color: #f0c7a4; font-size: 0.7rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; }
    .session-relation-tree[open] .session-relation-tree-heading { margin-bottom: 0.35rem; }
    .session-relation-tree-root, .session-relation-tree-children { margin: 0; padding: 0; list-style: none; }
    .session-relation-tree-children { margin-left: 0.8rem; padding-left: 0.85rem; border-left: 1px solid rgba(138, 190, 183, 0.28); }
    .session-relation-tree-node { margin: 0.18rem 0; }
    .session-relation-tree-item { min-width: 0; display: flex; align-items: center; gap: 0.4rem; }
    .session-relation-tree-children > .session-relation-tree-node > .session-relation-tree-item::before { content: "└"; flex: 0 0 auto; color: rgba(138, 190, 183, 0.7); font-weight: 900; }
    .session-relation-tree-title { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--accent); text-decoration: none; }
    .session-relation-tree-title:hover { text-decoration: underline; }
    .session-relation-tree-node.is-current > .session-relation-tree-item .session-relation-tree-title { color: var(--text); font-weight: 900; }
    .session-relation-current-marker { flex: 0 0 auto; padding: 0.08rem 0.35rem; border-radius: 999px; background: rgba(138, 190, 183, 0.16); color: var(--accent); font-size: 0.62rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-activity { margin-top: 0.24rem; color: var(--muted); font-size: 0.78rem; line-height: 1.25; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .session-activity strong { color: var(--text); font-weight: 800; }
    .session-activity--running { color: var(--accent); font-weight: 800; }
    .session-meta { font-size: 0.8rem; color: var(--muted); margin-top: 0.2rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-icon-button { flex: 0 0 auto; min-height: 1.65rem; padding: 0.2rem 0.55rem; border-radius: 999px; line-height: 1; }
    .session-rename { display: none; gap: 0.35rem; grid-template-columns: minmax(0, 1fr) auto; margin: 0.3rem 0 0.55rem; }
    a.session.selected + .session-rename { display: grid; }
    .session-rename input { min-width: 0; padding: 0.45rem 0.55rem; font-size: 0.82rem; }
    .session-rename button { padding: 0.45rem 0.6rem; font-size: 0.82rem; }
    .session-running-indicator, .session-compacting-indicator { display: inline-flex; align-items: center; gap: 0.3rem; color: var(--success); font-size: 0.75rem; font-weight: 700; }
    .session-running-indicator::before, .session-compacting-indicator::before { content: ""; width: 0.5rem; height: 0.5rem; border-radius: 999px; background: var(--success); box-shadow: 0 0 0 4px rgba(181, 189, 104, 0.16); animation: progress-blink 1000ms ease-in-out infinite; }
    .session-compacting-indicator::before { background: var(--warning); box-shadow: 0 0 0 4px rgba(255, 255, 0, 0.14); }
    .empty { color: var(--muted); background: var(--panel-soft); border: 1px solid var(--border); border-radius: 0.75rem; padding: 1rem; }
    .empty-state { max-width: 34rem; margin: 2rem auto; text-align: center; }
    .empty-state-title { margin: 0 0 0.45rem; color: var(--text); font-size: 1.2rem; font-weight: 800; }
    .empty-state p { margin: 0; }
    .empty-state-actions { display: flex; justify-content: center; margin-top: 1rem; }
    .sidebar-empty { display: grid; gap: 0.85rem; }
    .sidebar-empty-action { width: 100%; justify-self: stretch; }
    .message { position: relative; min-width: 0; max-width: 100%; border: 1px solid var(--border); border-radius: 0.9rem; padding: 0.9rem; margin-bottom: 0.85rem; box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12); scroll-margin-top: 3.5rem; }
    .message--user { margin-left: 10%; background: #343541; border-color: rgba(69, 133, 255, 0.72); color: #d4d4d4; }
    .message--assistant { margin-right: 10%; background: #080d20; border-color: rgba(69, 133, 255, 0.32); color: #f0c7a4; }
    .message--thinking { margin-right: 16%; background: #080d20; border-color: rgba(69, 133, 255, 0.22); border-style: dashed; color: #7f7f88; box-shadow: none; }
    .message--status { background: rgba(24, 24, 30, 0.72); color: var(--muted); box-shadow: none; }
    .message--tool, .message--tool-call { background: rgba(28, 38, 32, 0.82); border-color: rgba(138, 190, 183, 0.24); border-style: dashed; color: rgba(216, 222, 216, 0.74); box-shadow: none; }
    .message--tool-transcript { background: rgba(28, 38, 32, 0.82); border-color: rgba(138, 190, 183, 0.24); border-style: dashed; color: rgba(216, 222, 216, 0.74); font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
    .message--tool .role, .message--tool-call .role, .message--tool-transcript .role { color: var(--accent); }
    .message--tool-transcript .message-details-summary { color: rgba(216, 222, 216, 0.82); }
    .message--tool-transcript .message-body { display: grid; grid-template-columns: minmax(100%, max-content); color: rgba(216, 222, 216, 0.62); font-size: 0.92rem; line-height: 1.35; tab-size: 2; white-space: pre; overflow-wrap: normal; word-break: normal; }
    .tool-diff-line { display: block; margin: 0 -0.25rem; padding: 0 0.25rem; border-left: 2px solid transparent; }
    .tool-diff-line--add { border-left-color: rgba(181, 189, 104, 0.75); background: rgba(181, 189, 104, 0.12); color: #d8f0a0; }
    .tool-diff-line--remove { border-left-color: rgba(204, 102, 102, 0.8); background: rgba(204, 102, 102, 0.12); color: #f0b0a8; }
    .tool-diff-line--meta { color: var(--accent); font-weight: 700; }
    .message-body--edit-preview .tool-diff-line--preview-heading { margin-top: 0.45rem; padding-top: 0.45rem; border-top: 1px solid rgba(138, 190, 183, 0.18); color: var(--accent); font-weight: 800; }
    .message-body--edit-preview .tool-diff-line--preview-heading:first-child { margin-top: 0; padding-top: 0; border-top: 0; }
    .message-body--edit-preview .tool-diff-line--preview-ellipsis { font-style: italic; opacity: 0.78; }
    .tool-diff-line--context { color: rgba(216, 222, 216, 0.68); }
    .tool-command { color: var(--text); font-weight: 800; }
    .tool-path { color: var(--accent); font-weight: 500; }
    .tool-range { color: var(--warning); font-weight: 600; }
    .message--error, .message--tool-error { background: var(--danger-soft); border-color: rgba(242, 63, 66, 0.55); color: #ffb4b6; }
    .message--compact { padding: 0.75rem 0.9rem; box-shadow: none; }
    .message--live { box-shadow: 0 0 0 1px rgba(138, 190, 183, 0.45) inset, 0 6px 18px rgba(0, 0, 0, 0.12); }
    .message--assistant.message--streaming { border-color: rgba(138, 190, 183, 0.72); animation: streaming-bubble-pulse 1600ms ease-in-out infinite; }
    .message--assistant.message--streaming .message-body--markdown > :last-child:not(pre):not(ul):not(ol)::after,
    .message--assistant.message--streaming .message-body--markdown > ul:last-child > li:last-child::after,
    .message--assistant.message--streaming .message-body--markdown > ol:last-child > li:last-child::after,
    .message--assistant.message--streaming .message-body--markdown > blockquote:last-child > :last-child::after { content: ""; display: inline-block; width: 2px; height: 1em; margin-left: 0.12rem; background: var(--accent-hover); vertical-align: -0.12em; animation: streaming-caret-blink 1000ms steps(1) infinite; }
    .message-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
    .message--user .message-header { margin-bottom: 0.75rem; }
    .role { font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
    .message--error .role { color: #ffb4b6; }
    .message-meta { font-size: 0.75rem; color: var(--muted-soft); }
    .message-details { min-width: 0; max-width: 100%; }
    .message-details-summary { margin-bottom: 0.5rem; font-weight: 700; color: var(--muted); }
    .message--tool .message-details-summary, .message--tool-transcript .message-details-summary { max-width: 100%; overflow-x: auto; white-space: nowrap; }
    .message--compact .message-details-summary:last-child { margin-bottom: 0; }
    .message--tool .message-body, .message--tool-transcript .message-body { max-width: 100%; overflow-x: auto; }
    .compact-summary { margin-left: 0.25rem; }
    .tool-output-collapse { display: grid; gap: 0.4rem; }
    .tool-output-collapse-control { display: flex; align-items: center; gap: 0.5rem; color: var(--muted); font-size: 0.82rem; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
    .tool-output-toggle { justify-self: start; min-height: 0; padding: 0.15rem 0.45rem; border: 1px solid rgba(138, 190, 183, 0.28); background: transparent; color: var(--accent); font-size: 0.78rem; }
    .tool-output-toggle:hover { background: rgba(138, 190, 183, 0.12); color: var(--text); transform: none; }
    .tool-output-hidden-count--mobile { display: none; }
    .tool-output-line { display: block; min-height: 1.35em; }
    @media (max-width: 720px) {
      .tool-output-hidden-count--desktop, .tool-output-tail-desktop-extra { display: none; }
      .tool-output-hidden-count--mobile { display: inline; }
    }
    .message-body--thinking { font-size: 0.95rem; font-style: italic; line-height: 1.45; color: var(--muted); }
    .message-body--markdown { max-width: 100%; overflow-x: auto; line-height: 1.6; overflow-wrap: anywhere; }
    .message-body--markdown[data-rendering="pending"]:empty::before { content: "…"; color: var(--muted); }
    .message-body--markdown > :first-child { margin-top: 0; }
    .message-body--markdown > :last-child { margin-bottom: 0; }
    .message-body--markdown h1, .message-body--markdown h2, .message-body--markdown h3 { margin: 1rem 0 0.4rem; color: var(--text); }
