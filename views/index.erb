<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pi Web Gateway</title>
  <style>
    html, body { height: 100%; }
    body { margin: 0; font-family: system-ui, sans-serif; color: #1f2937; overflow: hidden; }
    .app-shell { display: grid; grid-template-columns: 22rem minmax(0, 1fr); height: 100vh; min-height: 0; }
    .session-sidebar { min-height: 0; border-right: 1px solid #e5e7eb; padding: 1rem; overflow-y: auto; background: #f9fafb; }
    .conversation-panel { display: grid; grid-template-rows: auto minmax(0, 1fr) auto; min-width: 0; min-height: 0; background: #ffffff; }
    .session-header { position: sticky; top: 0; z-index: 2; padding: 1rem 1.5rem 0.75rem; border-bottom: 1px solid #e5e7eb; background: #ffffff; }
    .conversation-scroll { min-height: 0; overflow-y: auto; padding: 1.5rem; scroll-behavior: smooth; }
    .composer { position: sticky; bottom: 0; padding: 0.75rem 1.5rem 1rem; border-top: 1px solid #e5e7eb; background: #ffffff; }
    h1 { font-size: 1.25rem; margin: 0 0 1rem; }
    h2 { font-size: 0.85rem; margin: 1.25rem 0 0.5rem; color: #4b5563; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cwd-group { margin-bottom: 0.75rem; }
    .cwd-toggle { display: inline-block; margin: 0.35rem 0 0.5rem; font-size: 0.8rem; color: #2563eb; text-decoration: none; }
    .cwd-toggle:hover { text-decoration: underline; }
    a.session { display: block; padding: 0.6rem; margin: 0.25rem 0; border-radius: 0.5rem; color: inherit; text-decoration: none; }
    a.session:hover, a.session.selected { background: #e5e7eb; }
    .session-title { font-weight: 600; overflow-wrap: anywhere; }
    .session-meta { font-size: 0.8rem; color: #6b7280; margin-top: 0.2rem; }
    .empty { color: #6b7280; }
    .message { border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 0.9rem; margin-bottom: 0.75rem; }
    .message--user { margin-left: 10%; background: #eff6ff; border-color: #bfdbfe; }
    .message--assistant { margin-right: 10%; background: #ffffff; }
    .message--status { background: #f8fafc; color: #4b5563; }
    .message--tool { background: #f9fafb; border-style: dashed; color: #374151; }
    .message--error, .message--tool-error { background: #fef2f2; border-color: #fecaca; color: #991b1b; }
    .message--compact { padding: 0.75rem 0.9rem; }
    .message--live { box-shadow: 0 0 0 1px #dbeafe inset; }
    .message-header { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.4rem; }
    .role { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #4b5563; }
    .message--error .role { color: #991b1b; }
    .message-meta { font-size: 0.75rem; color: #6b7280; }
    .message-details summary { cursor: pointer; font-weight: 700; color: #4b5563; }
    .message-details[open] summary { margin-bottom: 0.5rem; }
    .compact-summary { margin-left: 0.25rem; }
    .message-body--markdown { line-height: 1.55; overflow-wrap: anywhere; }
    .message-body--markdown > :first-child { margin-top: 0; }
    .message-body--markdown > :last-child { margin-bottom: 0; }
    .message-body--markdown h1, .message-body--markdown h2, .message-body--markdown h3 { margin: 1rem 0 0.4rem; color: #111827; }
    .message-body--markdown h1 { font-size: 1.35rem; }
    .message-body--markdown h2 { font-size: 1.15rem; white-space: normal; overflow: visible; text-overflow: clip; }
    .message-body--markdown h3 { font-size: 1rem; }
    .message-body--markdown ul, .message-body--markdown ol { padding-left: 1.4rem; }
    .message-body--markdown blockquote { margin: 0.75rem 0; padding-left: 1rem; border-left: 3px solid #d1d5db; color: #4b5563; }
    .message-body--markdown code { padding: 0.1rem 0.25rem; border-radius: 0.25rem; background: #f3f4f6; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.92em; }
    .message-body--markdown pre { padding: 0.75rem; border-radius: 0.5rem; background: #111827; color: #f9fafb; overflow-x: auto; white-space: pre; }
    .message-body--markdown pre code { padding: 0; background: transparent; color: inherit; }
    .message-body--markdown a { color: #2563eb; }
    .message--tool-error .message-details summary { color: #991b1b; }
    .live-heading { margin-top: 1.5rem; }
    pre { white-space: pre-wrap; overflow-wrap: anywhere; margin: 0; font-family: inherit; }
    .prompt-form, .inline-form { display: grid; gap: 0.5rem; margin: 0; }
    .session-actions { display: flex; flex-wrap: wrap; align-items: end; gap: 0.5rem; margin: 1rem 0 0; }
    .session-actions form { margin: 0; }
    .command-list { border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 0.75rem; margin: 1rem 0 0; }
    .command-list h3 { font-size: 0.8rem; text-transform: uppercase; color: #4b5563; margin: 0.75rem 0 0.25rem; }
    .command-list h3:first-child { margin-top: 0; }
    .command { font-size: 0.9rem; margin: 0.25rem 0; }
    .command code { font-weight: 700; }
    input, textarea { box-sizing: border-box; font: inherit; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; }
    textarea { width: 100%; resize: vertical; }
    button { justify-self: end; padding: 0.5rem 0.9rem; border: 0; border-radius: 0.5rem; background: #2563eb; color: white; font-weight: 600; cursor: pointer; }
    button.secondary { background: #4b5563; }
    button.danger { background: #dc2626; }
  </style>
</head>
<body>
  <div class="app-shell">
    <aside class="session-sidebar">
      <h1>Pi Sessions</h1>
      <% if @groups.empty? %>
        <p class="empty">No sessions found.</p>
      <% end %>

      <% @groups.each do |cwd, sessions| %>
        <section class="cwd-group">
          <h2 title="<%= h cwd %>"><%= h cwd %></h2>
          <% visible_sidebar_sessions(cwd, sessions).each do |session| %>
            <a class="session <%= "selected" if selected?(session) %>" href="/?session=<%= h Rack::Utils.escape(session.path) %>">
              <div class="session-title"><%= h session.display_name %></div>
              <div class="session-meta">
                <%= h session.message_count %> messages · updated <%= h format_time(session.modified_at) %>
              </div>
            </a>
          <% end %>

          <% if sidebar_group_overflow?(cwd, sessions) %>
            <a class="cwd-toggle" href="<%= h sidebar_group_url(cwd, expanded: true) %>">Show all <%= h sessions.length %></a>
          <% elsif expanded_cwd?(cwd) && sessions.length > 5 %>
            <a class="cwd-toggle" href="<%= h sidebar_group_url(cwd, expanded: false) %>">Show fewer</a>
          <% end %>
        </section>
      <% end %>
    </aside>

    <main class="conversation-panel">
      <% if @selected_session %>
        <header class="session-header">
          <h1><%= h @selected_session.display_name %></h1>
          <p class="session-meta">
            <%= h @selected_session.cwd %><br>
            <%= h @selected_session.path %>
          </p>

          <div class="session-actions">
            <form method="post" action="/sessions/new">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <button type="submit">New session in this cwd</button>
            </form>

            <form method="post" action="/abort">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <button type="submit" class="danger">Abort</button>
            </form>

            <form method="post" action="/compact">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <input type="text" name="instructions" placeholder="Optional compact instructions">
              <button type="submit" class="secondary">Compact</button>
            </form>

            <form method="post" action="/rename">
              <input type="hidden" name="session" value="<%= h @selected_session.path %>">
              <input type="text" name="name" placeholder="Session name">
              <button type="submit" class="secondary">Rename</button>
            </form>
          </div>

          <%# Temporarily hidden until command discovery UI is redesigned. %>
          <% if false %>
            <% commands_by_source = @commands.group_by { |command| command["source"] || "other" } %>
            <% if @commands.any? %>
              <section class="command-list">
                <% ["extension", "prompt", "skill", "other"].each do |source| %>
                  <% next unless commands_by_source[source]&.any? %>
                  <h3><%= h source %> commands</h3>
                  <% commands_by_source[source].each do |command| %>
                    <div class="command">
                      <code>/<%= h command["name"] %></code>
                      <% if command["description"].to_s != "" %>
                        — <%= h command["description"] %>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </section>
            <% end %>
          <% end %>
        </header>

        <section class="conversation-scroll" id="conversation-scroll">
          <% if @messages.empty? %>
            <p class="empty">No messages in this session.</p>
          <% end %>

          <% @messages.each do |message| %>
            <article class="<%= h message_article_class(message) %>" data-role="<%= h message.role %>">
              <header class="message-header">
                <div class="role"><%= h message_role_label(message.role) %></div>
                <% if message_metadata(message) %>
                  <div class="message-meta"><%= h message_metadata(message) %></div>
                <% end %>
              </header>
              <% if message.compact %>
                <details class="message-details" <%= "open" if message.expanded %>>
                  <summary><span class="compact-summary"><%= h message.summary %></span></summary>
                  <pre class="message-body"><%= h message.text %></pre>
                </details>
              <% else %>
                <% if message.role == "assistant" %>
                  <div class="message-body message-body--markdown"><%= render_message_body(message) %></div>
                <% else %>
                  <pre class="message-body"><%= render_message_body(message) %></pre>
                <% end %>
              <% end %>
            </article>
          <% end %>

          <section id="live-output" data-events-url="/events?session=<%= h Rack::Utils.escape(@selected_session.path) %>">
            <h2 class="live-heading">Live output</h2>
            <p class="empty" id="live-empty">Waiting for Pi events…</p>
          </section>
        </section>

        <form method="post" action="/prompt" class="prompt-form composer">
          <input type="hidden" name="session" value="<%= h @selected_session.path %>">
          <textarea name="message" rows="4" placeholder="Ask Pi… use /command for extension commands, prompt templates, and skills"></textarea>
          <button type="submit">Send</button>
        </form>
      <% else %>
        <header class="session-header">
          <h1>No session selected</h1>
        </header>
        <section class="conversation-scroll" id="conversation-scroll">
          <p class="empty">Create a Pi session first, then refresh this page.</p>
        </section>
      <% end %>
    </main>
  </div>
  <script>
    const liveOutput = document.getElementById("live-output");
    const liveEmpty = document.getElementById("live-empty");
    const promptForm = document.querySelector(".prompt-form");
    const conversationScroll = document.getElementById("conversation-scroll");
    let liveAssistantMessage = null;
    let liveAssistantSegments = new Map();
    let liveAssistantSeen = false;
    let liveBashToolCalls = new Map();
    let statusLine = null;

    function nearConversationBottom() {
      if (!conversationScroll) return false;
      return conversationScroll.scrollHeight - conversationScroll.scrollTop - conversationScroll.clientHeight < 120;
    }

    function scrollToBottom(behavior = "smooth") {
      conversationScroll?.scrollTo({ top: conversationScroll.scrollHeight, behavior });
    }

    function removeLiveEmpty() {
      liveEmpty?.remove();
    }

    function compactContentPart(part) {
      return part && typeof part === "object" && ["thinking", "toolCall", "toolResult"].includes(part.type);
    }

    function bashCommandLine(part) {
      const args = part?.arguments || {};
      const timeout = args.timeout ? ` (timeout ${args.timeout}s)` : "";
      return `$ ${args.command || ""}${timeout}`;
    }

    function contentPartText(part) {
      if (!part) return "";
      if (typeof part === "string") return part;
      if (part.text) return part.text;
      if (part.type === "thinking" || part.thinking) return part.thinking || "";
      if (part.type === "toolCall") {
        if (part.name === "bash") return bashCommandLine(part);
        const args = part.arguments ? `\n${JSON.stringify(part.arguments, null, 2)}` : "";
        return `[tool: ${part.name || "tool"}]${args}`;
      }
      if (part.type === "toolResult") return part.output || part.result || "[tool result]";
      return "";
    }

    function contentPartLabel(part) {
      if (!part || typeof part !== "object") return null;
      if (part.type === "thinking" || part.thinking) return part.thinking ? "thinking" : null;
      if (part.type === "toolCall" && part.name === "bash") return bashCommandLine(part);
      if (part.type === "toolCall" || part.type === "toolResult") return part.name || part.toolName || "tool";
      return null;
    }

    function contentSegments(content, message = {}) {
      const parts = Array.isArray(content) ? content : [content];
      const groups = [];
      parts.forEach((part, index) => {
        const compact = message.role === "toolResult" || compactContentPart(part);
        const bashCall = part && typeof part === "object" && part.type === "toolCall" && part.name === "bash";
        const lastGroup = groups[groups.length - 1];
        if (!bashCall && !compact && lastGroup && lastGroup.compact === false) {
          lastGroup.parts.push(part);
          lastGroup.endIndex = index;
        } else {
          groups.push({ compact, parts: [part], startIndex: index, endIndex: index });
        }
      });

      return groups.map((group) => {
        const text = group.parts.map(contentPartText).filter(Boolean).join("\n");
        const labels = group.parts.map(contentPartLabel).filter(Boolean);
        const toolPart = group.parts.find((part) => part && typeof part === "object" && ["toolCall", "toolResult"].includes(part.type));
        return {
          text,
          compact: group.compact,
          summary: message.toolName || [...new Set(labels)].join(" + ") || "tool output",
          expanded: message.isError === true,
          startIndex: group.startIndex,
          endIndex: group.endIndex,
          toolCallId: message.toolCallId || toolPart?.id || toolPart?.toolCallId,
          toolName: message.toolName || toolPart?.name || toolPart?.toolName,
          isToolResult: message.role === "toolResult" || toolPart?.type === "toolResult"
        };
      }).filter((segment) => segment.text);
    }

    function eventMessage(event) {
      return event.message || event.delta || event.item || event;
    }

    function messageText(message) {
      if (!message) return "";
      if (typeof message === "string") return message;
      if (message.text) return message.text;
      if (message.content) return contentSegments(message.content, message).map((segment) => segment.text).join("\n");
      return "";
    }

    function messageRoleKey(roleName) {
      if (["assistant", "user", "error"].includes(roleName)) return roleName;
      if (["tool", "toolResult"].includes(roleName)) return "tool";
      return "status";
    }

    function messageRoleLabel(roleName) {
      if (roleName === "toolResult") return "tool result";
      if (["custom", "session_info"].includes(roleName)) return "status";
      return roleName || "status";
    }

    function liveEventRole(event, message) {
      if (["custom", "custom_message", "session_info", "queue_update", "compaction_start", "compaction_end"].includes(event.type)) {
        return "status";
      }

      const role = message?.role;
      if (["assistant", "user", "tool", "toolResult", "error"].includes(role)) return role;
      if (["custom", "system", "status"].includes(role)) return "status";
      if (["message_start", "message_update", "message_end"].includes(event.type)) return "assistant";
      return "status";
    }

    function eventStatusText(event) {
      if (event.type === "session_info" && event.name) return `Session renamed to “${event.name}”`;
      if (event.type === "custom_message" && event.content) return event.content;
      if (event.type === "custom" && event.customType) return `${event.customType} updated`;
      if (event.type === "queue_update") return "Queued follow-up work updated";
      if (event.type === "compaction_start") return "Compaction started";
      if (event.type === "compaction_end") return event.aborted ? "Compaction aborted" : "Compaction finished";
      return event.message || event.text || event.type || "Status update";
    }

    async function renderAssistantMarkdown(body, text) {
      body.dataset.plainText = text;
      const formData = new FormData();
      formData.set("text", text);
      const response = await fetch("/markdown", { method: "POST", body: formData });
      if (!response.ok || body.dataset.plainText !== text) return;

      const payload = await response.json();
      if (body.dataset.plainText === text) body.innerHTML = payload.html;
    }

    function appendMessage(roleName, text, live = true, forceScroll = false) {
      removeLiveEmpty();
      const shouldScroll = forceScroll || nearConversationBottom();
      const roleKey = messageRoleKey(roleName);

      const article = document.createElement("article");
      article.className = `message message--${roleKey}${live ? " message--live" : ""}`;
      article.dataset.role = roleName;

      const header = document.createElement("header");
      header.className = "message-header";

      const role = document.createElement("div");
      role.className = "role";
      role.textContent = messageRoleLabel(roleName);

      const body = document.createElement(roleName === "assistant" ? "div" : "pre");
      body.className = roleName === "assistant" ? "message-body message-body--markdown" : "message-body";
      body.textContent = text;
      if (roleName === "assistant") renderAssistantMarkdown(body, text).catch(() => {});

      header.append(role);
      article.append(header, body);
      liveOutput.append(article);
      if (shouldScroll) scrollToBottom();
      return { article, body, compact: false };
    }

    function appendCompactMessage(roleName, summary, text, expanded = false, live = true, forceScroll = false) {
      removeLiveEmpty();
      const shouldScroll = forceScroll || nearConversationBottom();
      const roleKey = messageRoleKey(roleName);

      const article = document.createElement("article");
      article.className = `message message--${roleKey} message--compact${expanded ? " message--tool-error" : ""}${live ? " message--live" : ""}`;
      article.dataset.role = roleName;

      const header = document.createElement("header");
      header.className = "message-header";
      const role = document.createElement("div");
      role.className = "role";
      role.textContent = messageRoleLabel(roleName);
      header.append(role);

      const details = document.createElement("details");
      details.className = "message-details";
      details.open = expanded;
      const summaryElement = document.createElement("summary");
      const summaryText = document.createElement("span");
      summaryText.className = "compact-summary";
      summaryText.textContent = summary;
      summaryElement.append(summaryText);
      const body = document.createElement("pre");
      body.className = "message-body";
      body.textContent = text;
      details.append(summaryElement, body);

      article.append(header, details);
      liveOutput.append(article);
      if (shouldScroll) scrollToBottom();
      return { article, body, summaryText, compact: true };
    }

    function showStatus(text, forceScroll = false) {
      if (!statusLine) {
        statusLine = appendMessage("status", text, true, forceScroll);
      } else {
        const shouldScroll = forceScroll || nearConversationBottom();
        statusLine.body.textContent = text;
        if (shouldScroll) scrollToBottom();
      }
    }

    function resetLiveAssistantTracking() {
      liveAssistantMessage = null;
      liveAssistantSegments = new Map();
      liveBashToolCalls = new Map();
      liveAssistantSeen = false;
    }

    function segmentIdentity(event, segment, fallbackIndex) {
      const update = event.assistantMessageEvent || {};
      if (segment.toolCallId) return `${segment.toolCallId}-${segment.compact ? "compact" : "text"}`;
      const contentIndex = segment.startIndex ?? update.contentIndex ?? fallbackIndex;
      return `${contentIndex}-${segment.compact ? "compact" : "text"}`;
    }

    function updateLiveSegment(entry, roleName, segment, shouldScroll) {
      if (entry.compact !== segment.compact) return null;

      if (segment.compact) {
        entry.summaryText.textContent = segment.summary;
        entry.body.textContent = segment.text;
      } else {
        entry.body.textContent = segment.text;
        if (roleName === "assistant") renderAssistantMarkdown(entry.body, segment.text).catch(() => {});
      }

      if (shouldScroll) scrollToBottom();
      return entry;
    }

    function upsertLiveAssistantSegment(event, roleName, segment, fallbackIndex, shouldScroll) {
      const key = segmentIdentity(event, segment, fallbackIndex);
      const existing = liveAssistantSegments.get(key);
      const updated = existing && updateLiveSegment(existing, roleName, segment, shouldScroll);
      if (updated) return updated;

      const entry = segment.compact ?
        appendCompactMessage(roleName, segment.summary, segment.text, segment.expanded, true, shouldScroll) :
        appendMessage("assistant", segment.text, true, shouldScroll);
      liveAssistantSegments.set(key, entry);
      if (segment.toolName === "bash" && segment.toolCallId && !segment.isToolResult) liveBashToolCalls.set(segment.toolCallId, entry);
      return entry;
    }

    function renderMessageEvent(event) {
      const message = eventMessage(event);
      const segments = message?.content ? contentSegments(message.content, message) : [{ text: messageText(message), compact: false, summary: "", startIndex: 0, endIndex: 0 }].filter((segment) => segment.text);
      const roleName = liveEventRole(event, message);

      if (roleName === "assistant" && event.type === "message_start") resetLiveAssistantTracking();
      if (segments.length === 0) return;

      const shouldScroll = nearConversationBottom();

      if (roleName === "user") {
        return;
      }

      if (roleName !== "assistant") {
        segments.forEach((segment) => {
          const bashCallEntry = segment.toolName === "bash" && segment.toolCallId && liveBashToolCalls.get(segment.toolCallId);
          if (bashCallEntry && segment.isToolResult) {
            bashCallEntry.body.textContent = [bashCallEntry.body.textContent, segment.text].filter(Boolean).join("\n\n");
            bashCallEntry.article.classList.toggle("message--tool-error", segment.expanded);
            if (shouldScroll) scrollToBottom();
          } else if (segment.compact) {
            appendCompactMessage(roleName, segment.summary, segment.text, segment.expanded, true, shouldScroll);
          } else {
            appendMessage(roleName, segment.text, true, shouldScroll);
          }
        });
        return;
      }

      liveAssistantSeen = true;
      segments.forEach((segment, index) => {
        const entry = upsertLiveAssistantSegment(event, roleName, segment, index, shouldScroll);
        if (!segment.compact) liveAssistantMessage = entry;
      });
    }

    function renderEvent(event) {
      if (["agent_start", "turn_start"].includes(event.type)) {
        showStatus("Pi is thinking…");
        return;
      }

      if (["message_start", "message_update", "message_end"].includes(event.type)) {
        renderMessageEvent(event);
        return;
      }

      if (["custom", "custom_message", "session_info", "queue_update", "compaction_start", "compaction_end"].includes(event.type)) {
        showStatus(eventStatusText(event));
        return;
      }

      if (["turn_end", "agent_end"].includes(event.type)) {
        if (liveAssistantSeen) showStatus("Done");
        resetLiveAssistantTracking();
        return;
      }

      if (event.error) {
        appendMessage("error", event.error);
      }
    }

    async function pollEvents() {
      if (!liveOutput) return;

      const response = await fetch(liveOutput.dataset.eventsUrl);
      if (!response.ok) return;

      const payload = await response.json();
      payload.events.forEach(renderEvent);
    }

    promptForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const textarea = promptForm.querySelector("textarea");
      const message = textarea.value.trim();
      if (!message) return;

      const formData = new FormData(promptForm);
      formData.set("message", message);

      resetLiveAssistantTracking();
      appendMessage("user", message, true, true);
      textarea.value = "";
      showStatus("Sending…", true);

      const response = await fetch(promptForm.action, { method: "POST", body: formData, redirect: "manual" });
      if (!response.ok && response.type !== "opaqueredirect") {
        showStatus("Prompt failed to send", true);
      }
      scrollToBottom();
    });

    if (liveOutput) {
      setInterval(() => pollEvents().catch(() => {}), 1000);
      requestAnimationFrame(() => scrollToBottom("auto"));
    }
  </script>
</body>
</html>
