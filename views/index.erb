<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GRIPi</title>
  <link rel="icon" href="/app-icon.svg" type="image/svg+xml">
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#18181e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="GRIPi">
  <link rel="stylesheet" href="/assets/app.css?v=<%= h settings.gateway_instance_id %>">
</head>
<body class="<%= session_only? ? "session-only" : "" %>" data-browser-access-enabled="<%= browser_access_enabled? ? "true" : "false" %>" data-workspace-access-enabled="<%= multi_user_mode? ? "true" : "false" %>" data-gateway-instance-id="<%= h settings.gateway_instance_id %>" data-home-dir="<%= h Dir.home %>">
  <div class="app-shell">
    <% unless session_only? %>
      <input type="checkbox" class="mobile-session-toggle" id="mobile-session-toggle">
      <%= erb :_sidebar, layout: false %>
      <label for="mobile-session-toggle" class="mobile-sidebar-backdrop" aria-label="Hide sessions"></label>
    <% end %>

    <%= erb :_conversation, layout: false %>
  </div>
  <%= erb :_new_session_modal, layout: false %>
  <%= erb :_fork_session_modal, layout: false %>
  <%= erb :_model_settings_modal, layout: false %>
  <div class="session-switch-overlay" role="status" aria-live="polite" aria-label="Loading">
    <div class="session-switch-indicator"><span class="session-switch-spinner" aria-hidden="true"></span> Loading…</div>
  </div>
  <div class="browser-access-overlay" data-browser-access-overlay aria-live="polite">
    <div class="browser-access-card">
      <div class="browser-access-title" data-browser-access-title></div>
      <div class="browser-access-meta" data-browser-access-meta></div>
      <div class="browser-access-actions">
        <button class="secondary" type="button" data-browser-access-deny>Deny</button>
        <button type="button" data-browser-access-allow>Allow</button>
      </div>
    </div>
  </div>
  <div class="browser-access-overlay" data-workspace-access-overlay aria-live="polite">
    <div class="browser-access-card">
      <div class="browser-access-title" data-workspace-access-title></div>
      <div class="browser-access-meta" data-workspace-access-meta></div>
      <div class="browser-access-actions">
        <button class="secondary" type="button" data-workspace-access-deny>Deny</button>
        <button type="button" data-workspace-access-allow>Allow</button>
      </div>
    </div>
  </div>
  <script type="module" src="/assets/app.js?v=<%= h settings.gateway_instance_id %>"></script>
</body>
</html>
