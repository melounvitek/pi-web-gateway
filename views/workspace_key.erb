<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pi Web Gateway User Token</title>
  <style>
    :root { color-scheme: dark; --bg: #18181e; --panel: #1e1e24; --panel-soft: #282832; --border: #505050; --text: #d4d4d4; --muted: #808080; --accent: #8abeb7; --danger: #cc6666; --button-text: #18181e; }
    *, *::before, *::after { box-sizing: border-box; }
    body { min-height: 100vh; margin: 0; display: grid; place-items: center; padding: 1rem; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--text); background: var(--bg); }
    main { width: min(32rem, 100%); display: grid; gap: 1rem; padding: 1.25rem; border: 1px solid var(--border); border-radius: 1rem; background: var(--panel); box-shadow: 0 16px 36px rgba(0, 0, 0, 0.28); }
    h1 { margin: 0; font-size: 1.35rem; }
    p { margin: 0; color: var(--muted); line-height: 1.5; }
    form { display: grid; gap: 0.6rem; margin: 0; }
    input { width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 0.55rem; color: var(--text); background: var(--panel-soft); font: inherit; }
    button { justify-self: start; padding: 0.55rem 0.9rem; border: 0; border-radius: 0.55rem; background: var(--accent); color: var(--button-text); font-weight: 800; cursor: pointer; }
    .secondary { background: var(--panel-soft); color: var(--text); }
    .code { display: inline-flex; justify-content: center; padding: 0.8rem 1rem; border: 1px solid rgba(138, 190, 183, 0.5); border-radius: 0.75rem; background: rgba(138, 190, 183, 0.12); color: var(--accent); font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 1.2rem; font-weight: 800; overflow-wrap: anywhere; word-break: break-all; }
    .error { padding: 0.7rem; border: 1px solid rgba(204, 102, 102, 0.5); border-radius: 0.65rem; color: #ffb4b6; background: rgba(204, 102, 102, 0.14); }
    .warning { padding: 0.7rem; border: 1px solid rgba(204, 102, 102, 0.5); border-radius: 0.65rem; color: #ffd3d4; background: rgba(204, 102, 102, 0.14); }
    .muted { font-size: 0.9rem; }
    .actions { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  </style>
</head>
<% if @workspace_pending_request %>
<body data-workspace-status-url="/workspace-access/status?code=<%= h Rack::Utils.escape(@workspace_pending_request.fetch("code")) %>">
  <main>
    <h1>Waiting for workspace approval</h1>
    <p>An approved user needs to approve this token before it can show sessions.</p>
    <div class="code"><%= h @workspace_pending_request.fetch("code") %></div>
    <p class="muted" data-workspace-status-message>Keep this page open. It will continue automatically after approval.</p>
    <form method="get" action="/">
      <button type="submit">Try again</button>
    </form>
  </main>
  <script>
    async function pollWorkspaceStatus() {
      try {
        const response = await fetch(document.body.dataset.workspaceStatusUrl, { headers: { "Accept": "application/json" } });
        if (!response.ok) return;
        const payload = await response.json();
        if (payload.status === "approved") window.location = <%= JSON.generate(@workspace_return_to || "/") %>;
        if (payload.status === "denied") document.querySelector("[data-workspace-status-message]").textContent = "Workspace request denied. Try again with a different token.";
      } catch (_error) {}
      setTimeout(pollWorkspaceStatus, 2000);
    }
    pollWorkspaceStatus();
  </script>
</body>
<% elsif @generated_workspace_token %>
<body>
  <main>
    <h1>Your user token</h1>
    <p class="warning">This is a sensitive and private token. Store it somewhere safe now. It can’t be recovered or shown again.</p>
    <div class="code" data-generated-token><%= h @generated_workspace_token %></div>
    <div class="actions">
      <button type="button" data-copy-token>Copy token</button>
    </div>
    <form method="post" action="/workspace-key">
      <input type="hidden" name="return_to" value="<%= h(@workspace_return_to || request.fullpath) %>">
      <input type="hidden" name="workspace_key" value="<%= h @generated_workspace_token %>">
      <% if @workspace_bootstrap_required %><input type="password" name="admin_password" placeholder="Admin password" autocomplete="current-password"><% end %>
      <button type="submit"><%= @workspace_bootstrap_required ? "Create first user" : "Ask for access" %></button>
    </form>
    <% if @workspace_bootstrap_required %><p class="muted">First user setup can also be approved manually by editing <code><%= h settings.workspace_access_path %></code>.</p><% end %>
  </main>
  <script>
    document.querySelector("[data-copy-token]")?.addEventListener("click", async () => {
      const token = document.querySelector("[data-generated-token]")?.textContent || "";
      try { await navigator.clipboard.writeText(token); } catch (_error) {}
    });
  </script>
</body>
<% else %>
<body>
  <main>
    <h1>User token</h1>
    <p>Enter your private user token. Approved tokens open immediately.</p>
    <p class="muted">New tokens need approval before they can open a session list.</p>
    <% if @workspace_bootstrap_required %><p class="muted">Create the first user with the admin password, or manually approve the token in <code><%= h settings.workspace_access_path %></code>.</p><% end %>
    <% if @workspace_key_error %><div class="error"><%= h @workspace_key_error %></div><% end %>
    <% if @workspace_bootstrap_pending_request %><p class="muted">A pending request was written with code <code><%= h @workspace_bootstrap_pending_request.fetch("code") %></code>. To approve manually, copy that pending request into <code>approved_workspaces</code> in <code><%= h settings.workspace_access_path %></code>.</p><% end %>

    <form method="post" action="/workspace-key">
      <input type="hidden" name="return_to" value="<%= h(@workspace_return_to || request.fullpath) %>">
      <input type="password" name="workspace_key" placeholder="User token" autocomplete="current-password" autofocus>
      <% if @workspace_bootstrap_required %><input type="password" name="admin_password" placeholder="Admin password" autocomplete="current-password"><% end %>
      <button type="submit"><%= @workspace_bootstrap_required ? "Open first user" : "Open" %></button>
    </form>

    <form method="post" action="/workspace-token/generate">
      <input type="hidden" name="return_to" value="<%= h(@workspace_return_to || request.fullpath) %>">
      <button class="secondary" type="submit">First time here? Generate your token</button>
    </form>
  </main>
</body>
<% end %>
</html>
