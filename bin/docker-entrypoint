#!/usr/bin/env bash
set -euo pipefail

config_dir="${PI_GATEWAY_CONFIG_DIR:-$HOME/.config/pi-web-gateway}"
env_file="${PI_GATEWAY_ENV_PATH:-$config_dir/env}"

if [ "${1:-}" = "/app/bin/start" ] || [ "${1:-}" = "bin/start" ]; then
  mkdir -p "$(dirname "$env_file")" "$HOME/.pi/agent/sessions" "$HOME/.pi/web-gateway" /work

  if [ -z "${PI_GATEWAY_ADMIN_PASSWORD:-}" ]; then
    if ! grep -q '^PI_GATEWAY_ADMIN_PASSWORD=' "$env_file" 2>/dev/null; then
      touch "$env_file"
      chmod 600 "$env_file"
      password="$(ruby -rsecurerandom -e 'puts SecureRandom.hex(12)')"
      if [ -s "$env_file" ]; then
        printf '\n' >> "$env_file"
      fi
      printf 'PI_GATEWAY_ADMIN_PASSWORD=%s\n' "$password" >> "$env_file"
      echo "Generated PI_GATEWAY_ADMIN_PASSWORD in $env_file"
    fi
    unset PI_GATEWAY_ADMIN_PASSWORD
  fi
fi

exec "$@"
