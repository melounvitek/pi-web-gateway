#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
root="$(cd -- "$script_dir/.." && pwd)"
binary="$root/tmp/gripi"
host="${1:-${GRIPI_HOST:-127.0.0.1}}"

if ! command -v mise >/dev/null 2>&1 && [[ -n "${HOME:-}" && -x "$HOME/.local/bin/mise" ]]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

pending="$root/tmp/.gripi-update-pending"
pending_binary="$pending/gripi"
pending_revision="$pending/revision"

if [[ -L "$root/tmp" || -L "$binary" || -L "$pending" || -L "$pending_binary" || -L "$pending_revision" ]]; then
  printf 'Refusing symlinked gateway path at %s\n' "$binary" >&2
  exit 1
fi
if [[ -e "$pending" ]]; then
  if [[ ! -d "$pending" ]]; then
    printf 'Invalid pending gateway cutover at %s\n' "$pending" >&2
    exit 1
  fi
  revision=""
  current_revision=""
  if [[ -f "$pending_revision" ]]; then
    IFS= read -r revision < "$pending_revision" || true
  fi
  current_revision="$(cd "$root" && git rev-parse HEAD 2>/dev/null || true)"
  if [[ "$revision" =~ ^[0-9a-f]{40,64}$ && "$revision" == "$current_revision" ]]; then
    if [[ -f "$pending_binary" && -x "$pending_binary" ]]; then
      mv -f -- "$pending_binary" "$binary"
    elif [[ ! -x "$binary" ]]; then
      printf 'Invalid pending gateway binary at %s\n' "$pending_binary" >&2
      exit 1
    fi
    rm -f -- "$pending_revision"
    rmdir -- "$pending"
  else
    rm -rf -- "$pending"
  fi
fi
if [[ ! -x "$binary" ]]; then
  mkdir -p -- "$root/tmp"
  temporary="$(mktemp "$binary.new.XXXXXX")"
  trap 'rm -f -- "$temporary"' EXIT
  (cd "$root" && mise exec -- go build -o "$temporary" ./cmd/gripi)
  mv -f -- "$temporary" "$binary"
  trap - EXIT
fi
if [[ -n "${GRIPI_RESTART_PATH:-}" ]]; then
  restart_path="$GRIPI_RESTART_PATH"
elif [[ -n "${HOME:-}" ]]; then
  restart_path="$HOME/.pi/gripi/restart-request"
else
  printf 'HOME or GRIPI_RESTART_PATH must be set\n' >&2
  exit 1
fi

rm -f -- "$restart_path"
set +e
(cd "$root" && APP_ENV=production GRIPI_BIND_HOST="$host" "$binary")
status=$?
set -e
if [[ -e "$restart_path" ]]; then
  rm -- "$restart_path"
  exec "${BASH_SOURCE[0]}" "$@"
fi
exit "$status"
