# Copy to .env and adjust for your machine.

# Host directory exposed to Pi and the gateway as /work.
# For one project, set this to that repository. For many projects, set it to a parent code directory.
PI_WORKSPACE=./workspace

# Gateway HTTP bind address and port on the host. Use 0.0.0.0 only when you want remote access.
PI_GATEWAY_BIND=127.0.0.1
PI_GATEWAY_PORT=4567

# Optional. If blank, the container generates and persists one in gateway_config.
PI_GATEWAY_ADMIN_PASSWORD=

# Optional comma-separated Rack permitted hosts for production host authorization.
PI_GATEWAY_PERMITTED_HOSTS=

# Match files created in mounted workspaces to your host user.
HOST_UID=1000
HOST_GID=1000

# Image build knobs.
RUBY_VERSION=4.0.2
NODE_MAJOR=24
PI_VERSION=latest
PI_GATEWAY_IMAGE=pi-web-gateway:local

# Optional provider/API credentials. You can also run `docker compose run --rm pi pi`
# and use /login to store credentials in the pi_data volume.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=
